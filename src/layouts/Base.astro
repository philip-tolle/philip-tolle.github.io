---
import '@fontsource/marcellus';
import '@fontsource/jost/300.css';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '@fontsource/jost/600.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  accent?: 'green' | 'blue' | 'amber';
}

const {
  title,
  description = 'KI-Beratung, Bildung und Begleitung für das Gastgewerbe in Mainfranken. NextCourse begleitet inhabergeführte Hotels und Restaurants dabei, KI sinnvoll einzusetzen — mit messbaren Ergebnissen.',
  accent = 'green',
} = Astro.props;

const ogImage = new URL('/og.jpg', Astro.site);
const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'NextCourse',
  legalName: 'NextCourse UG (haftungsbeschränkt)',
  url: Astro.site?.toString(),
  logo: ogImage.toString(),
  email: 'tolle@nextcourse-academy.de',
  telephone: '+49 151 20220983',
  slogan: 'Menschliche Kompetenz. Digitale Kraft.',
  description: 'Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung, Kurse und Begleitung aus Würzburg.',
  address: { '@type': 'PostalAddress', streetAddress: 'Karmelitenstraße 24', postalCode: '97070', addressLocality: 'Würzburg', addressCountry: 'DE' },
  areaServed: 'Mainfranken',
  founder: { '@type': 'Person', name: 'Philip Tolle', sameAs: 'https://www.linkedin.com/in/philiptolle/' },
  sameAs: ['https://www.linkedin.com/in/philiptolle/'],
});
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="strict-origin-when-cross-origin">
{import.meta.env.PROD && (
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self' https://formsubmit.co; base-uri 'self'; object-src 'none'; upgrade-insecure-requests" />
)}
<title>{title}</title>
<meta name="description" content={description}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:locale" content="de_DE">
<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="NextCourse">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content={ogImage}>
<link rel="icon" href="/favicon.png" type="image/png">
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="alternate" type="application/rss+xml" title="NextCourse Blog" href="/rss.xml">
<meta name="generator" content={Astro.generator}>
<script type="application/ld+json" set:html={orgSchema}></script>
<slot name="head" />
</head>
<body>
<canvas id="ambient" aria-hidden="true"></canvas>

<a class="skiplink" href="#main">Zum Inhalt springen</a>

<noscript><style is:inline>
  /* Ohne JS: Stepper-Schritte und Ampel-Antworten vollständig anzeigen */
  .stepdetail article[hidden]{display:flex}
  .ampelrow p[hidden]{display:block}
</style></noscript>

<div class="site">
  <Header />
  <main id="main" class:list={[accent !== 'green' && `acc-${accent}`]}>
    <slot />
  </main>
  <Footer />
</div>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Ambient-Wellenfeld: dezente Linien auf Papier ---------- */
  const canvas = document.getElementById('ambient') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, t = 0;
  function size() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas.width = window.innerWidth * dpr;
    H = canvas.height = window.innerHeight * dpr;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
  }
  function draw() {
    ctx.clearRect(0, 0, W, H);
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const lines = 10;
    const sc = window.scrollY * 0.0012;
    const darkHome = document.documentElement.matches('.home-theme[data-home-theme="dark"]');
    for (let i = 0; i < lines; i++) {
      const yBase = H * 0.22 + (H * 0.68 / lines) * i;
      const amp = (30 + i * 4) * dpr;
      const phase = t * 0.007 + sc + i * 0.5;
      ctx.beginPath();
      for (let x = 0; x <= W; x += 9 * dpr) {
        const y = yBase
          + Math.sin(x * 0.0014 / dpr + phase) * amp
          + Math.sin(x * 0.0006 / dpr - phase * 0.55) * amp * 0.55;
        if (x === 0) { ctx.moveTo(x, y); } else { ctx.lineTo(x, y); }
      }
      const isAmber = (i === 7);
      ctx.strokeStyle = darkHome
        ? 'rgba(255,255,255,' + (isAmber ? 0.15 : 0.028 + i * 0.005) + ')'
        : isAmber
          ? 'rgba(229,162,84,0.16)'
          : 'rgba(185,136,92,' + (0.03 + i * 0.005) + ')';
      ctx.lineWidth = (isAmber ? 1.4 : 1) * dpr;
      ctx.stroke();
    }
    t++;
    if (!reduced) { requestAnimationFrame(draw); }
  }
  size();
  if (reduced) { t = 80; draw(); } else { requestAnimationFrame(draw); }
  window.addEventListener('resize', () => { size(); if (reduced) { draw(); } });
  window.addEventListener('nextcourse:home-theme', () => {
    if (reduced) { t = 80; draw(); }
  });

  /* ---------- Reveal + Stagger ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: .15 });
  document.querySelectorAll('.stagger').forEach((group) => {
    Array.from(group.children).forEach((child, i) => {
      if (child instanceof HTMLElement && child.classList.contains('reveal')) {
        child.style.transitionDelay = (i * 90) + 'ms';
      }
    });
  });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  /* ---------- Header ---------- */
  const header = document.getElementById('header')!;
  function headerScroll() {
    header.classList.toggle('solid', window.scrollY > 40);
  }
  window.addEventListener('scroll', headerScroll, { passive: true });
  headerScroll();

  /* ---------- Münzen: Tilt + wandernder Lichtreflex ---------- */
  if (window.matchMedia('(hover:hover) and (pointer:fine)').matches && !reduced) {
    document.querySelectorAll<HTMLElement>('.coin[data-tilt]').forEach((coin) => {
      coin.addEventListener('pointermove', (e) => {
        const r = coin.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - .5;
        const y = (e.clientY - r.top) / r.height - .5;
        coin.style.transform = 'perspective(600px) rotateX(' + (-y * 10).toFixed(2) +
          'deg) rotateY(' + (x * 10).toFixed(2) + 'deg)';
        coin.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
        coin.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
      });
      coin.addEventListener('pointerleave', () => {
        coin.style.transform = '';
        coin.style.setProperty('--gx', '50%');
        coin.style.setProperty('--gy', '35%');
      });
    });
  }

  /* ---------- Kurslinie: Holzlogo läuft weich auf Viewport-Mitte mit ---------- */
  document.querySelectorAll<HTMLElement>('.kurs').forEach((kurs) => {
    const path = kurs.querySelector('.kurs__path') as SVGPathElement | null;
    const svg = kurs.querySelector('.kurs__line') as SVGSVGElement | null;
    const pen = kurs.querySelector('.kurs__pen') as HTMLElement | null;
    if (!path || !svg || !pen) { return; }
    const len = path.getTotalLength();
    path.style.strokeDasharray = String(len);

    let lineX = 0;
    let sectionH = 1;
    const measure = () => {
      const kr = kurs.getBoundingClientRect();
      const sr = svg.getBoundingClientRect();
      lineX = (sr.left - kr.left) + (65 / 130) * sr.width;
      sectionH = kr.height || 1;
    };
    const applyY = (y: number) => {
      pen.style.transform = 'translate(' + lineX.toFixed(1) + 'px,' + y.toFixed(1) + 'px) translate(-50%,-50%)';
      path.style.strokeDashoffset = String(len * (1 - Math.min(1, y / sectionH)));
    };

    let targetY = 0;
    let curY = 0;
    let raf: number | null = null;
    let started = false;
    const tick = () => {
      curY += (targetY - curY) * 0.16;
      if (Math.abs(targetY - curY) < 0.4) { curY = targetY; applyY(curY); raf = null; return; }
      applyY(curY);
      raf = requestAnimationFrame(tick);
    };
    const onScroll = () => {
      const kr = kurs.getBoundingClientRect();
      targetY = Math.max(0, Math.min(sectionH, window.innerHeight / 2 - kr.top));
      pen.style.opacity = '1';
      if (!started) { started = true; curY = targetY; applyY(curY); return; }
      if (raf === null) { raf = requestAnimationFrame(tick); }
    };

    measure();
    onScroll();
    if (reduced) { return; }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { measure(); onScroll(); }, { passive: true });
    window.addEventListener('load', () => { measure(); onScroll(); });
  });

  /* ---------- Deckblätter: Angebote aufklappen ---------- */
  document.querySelectorAll<HTMLButtonElement>('.deckblatt[aria-controls]').forEach((btn) => {
    const panel = document.getElementById(btn.getAttribute('aria-controls') as string);
    if (!panel) { return; }
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      panel.hidden = open;
      window.dispatchEvent(new Event('resize'));
    });
  });

  /* ---------- Angebotsseiten: Stepper ---------- */
  const stepBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.stepbtn'));
  const stepPanels = Array.from(document.querySelectorAll<HTMLElement>('.stepdetail article'));
  const stepCount = document.getElementById('stepcount');
  const stepPrev = document.getElementById('stepprev') as HTMLButtonElement | null;
  const stepNext = document.getElementById('stepnext') as HTMLButtonElement | null;
  if (stepBtns.length && stepPanels.length && stepCount && stepPrev && stepNext) {
    let current = 0;
    const pad = (n: number) => String(n).padStart(2, '0');
    const showStep = (i: number) => {
      current = Math.max(0, Math.min(stepPanels.length - 1, i));
      stepBtns.forEach((b, k) => b.setAttribute('aria-current', k === current ? 'true' : 'false'));
      stepPanels.forEach((p, k) => { p.hidden = k !== current; });
      stepCount.textContent = 'Schritt ' + pad(current + 1) + ' / ' + pad(stepPanels.length);
      /* aria-disabled statt disabled: ein fokussierter Button darf den Fokus nicht verlieren */
      stepPrev.setAttribute('aria-disabled', current === 0 ? 'true' : 'false');
      stepNext.setAttribute('aria-disabled', current === stepPanels.length - 1 ? 'true' : 'false');
    };
    stepBtns.forEach((b) => b.addEventListener('click', () => showStep(parseInt(b.dataset.step!, 10))));
    stepPrev.addEventListener('click', () => showStep(current - 1));
    stepNext.addEventListener('click', () => showStep(current + 1));
    showStep(0);
  }

  /* ---------- Angebotsseiten: Ampel-Akkordeon (eine Zeile offen) ---------- */
  const ampelRows = Array.from(document.querySelectorAll<HTMLElement>('.ampelrow'));
  ampelRows.forEach((row) => {
    const btn = row.querySelector('button')!;
    const panel = row.querySelector('p')!;
    btn.addEventListener('click', () => {
      const willOpen = panel.hidden;
      ampelRows.forEach((r) => {
        r.classList.remove('is-open');
        r.querySelector('p')!.hidden = true;
        r.querySelector('button')!.setAttribute('aria-expanded', 'false');
        r.querySelector('.ampelrow__right b')!.textContent = '+';
      });
      if (willOpen) {
        row.classList.add('is-open');
        panel.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        row.querySelector('.ampelrow__right b')!.textContent = '–';
      }
    });
  });

  /* ---------- Angebots-Kompass: Bereichs-Wahl schaltet das Panel um ---------- */
  const kompBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.kompbtn'));
  const kompLists = Array.from(document.querySelectorAll<HTMLElement>('.komp__panel .komp__set[data-bereich]'));
  const kompPanel = document.getElementById('komp-panel');
  kompBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const schliessen = btn.getAttribute('aria-pressed') === 'true';
      kompBtns.forEach((b) => b.setAttribute('aria-pressed', !schliessen && b === btn ? 'true' : 'false'));
      if (kompPanel) { kompPanel.hidden = schliessen; }
      kompLists.forEach((ul) => { ul.hidden = schliessen || ul.dataset.bereich !== btn.dataset.bereich; });
    });
  });

  /* ---------- Fußzeile: Jahr ---------- */
  const year = document.getElementById('year');
  if (year) { year.textContent = String(new Date().getFullYear()); }
</script>
</body>
</html>

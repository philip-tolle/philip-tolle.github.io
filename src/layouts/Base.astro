---
import '@fontsource/marcellus';
import '@fontsource/jost/300.css';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '@fontsource/jost/600.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  accent?: 'green' | 'blue' | 'amber';
}

const {
  title,
  description = 'KI-Beratung, Bildung und Begleitung für das Gastgewerbe in Mainfranken. NextCourse begleitet inhabergeführte Hotels und Restaurants dabei, KI sinnvoll einzusetzen — mit messbaren Ergebnissen.',
  accent = 'green',
} = Astro.props;

const ogImage = new URL('/og.jpg', Astro.site);
const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'NextCourse',
  legalName: 'NextCourse UG (haftungsbeschränkt)',
  url: Astro.site?.toString(),
  logo: ogImage.toString(),
  email: 'tolle@nextcourse-academy.de',
  telephone: '+49 151 20220983',
  slogan: 'Menschliche Kompetenz. Digitale Kraft.',
  description: 'Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung, Kurse und Begleitung aus Würzburg.',
  address: { '@type': 'PostalAddress', streetAddress: 'Karmelitenstraße 24', postalCode: '97070', addressLocality: 'Würzburg', addressCountry: 'DE' },
  areaServed: 'Mainfranken',
  founder: { '@type': 'Person', name: 'Philip Tolle', sameAs: 'https://www.linkedin.com/in/philiptolle/' },
  sameAs: ['https://www.linkedin.com/in/philiptolle/'],
});
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="strict-origin-when-cross-origin">
{import.meta.env.PROD && (
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self' https://formsubmit.co; base-uri 'self'; object-src 'none'; upgrade-insecure-requests" />
)}
<title>{title}</title>
<meta name="description" content={description}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:locale" content="de_DE">
<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="NextCourse">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content={ogImage}>
<link rel="icon" href="/favicon.png" type="image/png">
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="alternate" type="application/rss+xml" title="NextCourse Blog" href="/rss.xml">
<meta name="generator" content={Astro.generator}>
<script type="application/ld+json" set:html={orgSchema}></script>
<slot name="head" />
</head>
<body>
<canvas id="ambient" aria-hidden="true"></canvas>

<a class="skiplink" href="#main">Zum Inhalt springen</a>

<div class="site">
  <Header />
  <main id="main" class:list={[accent !== 'green' && `acc-${accent}`]}>
    <slot />
  </main>
  <Footer />
</div>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Ambient-Wellenfeld: dezente Linien auf Papier ---------- */
  const canvas = document.getElementById('ambient') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, t = 0;
  function size() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas.width = window.innerWidth * dpr;
    H = canvas.height = window.innerHeight * dpr;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
  }
  function draw() {
    ctx.clearRect(0, 0, W, H);
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const lines = 10;
    const sc = window.scrollY * 0.0012;
    for (let i = 0; i < lines; i++) {
      const yBase = H * 0.22 + (H * 0.68 / lines) * i;
      const amp = (30 + i * 4) * dpr;
      const phase = t * 0.007 + sc + i * 0.5;
      ctx.beginPath();
      for (let x = 0; x <= W; x += 9 * dpr) {
        const y = yBase
          + Math.sin(x * 0.0014 / dpr + phase) * amp
          + Math.sin(x * 0.0006 / dpr - phase * 0.55) * amp * 0.55;
        if (x === 0) { ctx.moveTo(x, y); } else { ctx.lineTo(x, y); }
      }
      const isAmber = (i === 7);
      ctx.strokeStyle = isAmber
        ? 'rgba(229,162,84,0.16)'
        : 'rgba(185,136,92,' + (0.03 + i * 0.005) + ')';
      ctx.lineWidth = (isAmber ? 1.4 : 1) * dpr;
      ctx.stroke();
    }
    t++;
    if (!reduced) { requestAnimationFrame(draw); }
  }
  size();
  if (reduced) { t = 80; draw(); } else { requestAnimationFrame(draw); }
  window.addEventListener('resize', () => { size(); if (reduced) { draw(); } });

  /* ---------- Reveal + Stagger ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: .15 });
  document.querySelectorAll('.stagger').forEach((group) => {
    Array.from(group.children).forEach((child, i) => {
      if (child instanceof HTMLElement && child.classList.contains('reveal')) {
        child.style.transitionDelay = (i * 90) + 'ms';
      }
    });
  });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  /* ---------- Header ---------- */
  const header = document.getElementById('header')!;
  function headerScroll() {
    header.classList.toggle('solid', window.scrollY > 40);
  }
  window.addEventListener('scroll', headerScroll, { passive: true });
  headerScroll();

  /* ---------- Münzen: Tilt + wandernder Lichtreflex ---------- */
  if (window.matchMedia('(hover:hover) and (pointer:fine)').matches && !reduced) {
    document.querySelectorAll<HTMLElement>('.coin[data-tilt]').forEach((coin) => {
      coin.addEventListener('pointermove', (e) => {
        const r = coin.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - .5;
        const y = (e.clientY - r.top) / r.height - .5;
        coin.style.transform = 'perspective(600px) rotateX(' + (-y * 10).toFixed(2) +
          'deg) rotateY(' + (x * 10).toFixed(2) + 'deg)';
        coin.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
        coin.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
      });
      coin.addEventListener('pointerleave', () => {
        coin.style.transform = '';
        coin.style.setProperty('--gx', '50%');
        coin.style.setProperty('--gy', '35%');
      });
    });
  }

  /* ---------- Fußzeile: Jahr ---------- */
  const year = document.getElementById('year');
  if (year) { year.textContent = String(new Date().getFullYear()); }
</script>
</body>
</html>

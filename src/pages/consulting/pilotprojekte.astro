---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';

const bausteine = [
  {
    icon: 'gespraech',
    name: 'KI-Telefonassistent',
    text: 'Nie wieder ein verpasster Anruf: Der Assistent nimmt rund um die Uhr an, beantwortet Standardfragen und reicht Reservierungen sauber weiter.',
    effekt: '+77.000 €',
    tag: 'Schnellster Effekt',
  },
  {
    icon: 'ziel',
    name: 'Revenue Management',
    text: 'Dynamische Preise und Auslastungssteuerung heben die Belegung — der größte einzelne Hebel im ganzen Haus.',
    effekt: '+93.000 €',
    tag: 'Größter Hebel',
  },
  {
    icon: 'zeit',
    name: 'Digitale Dienstplanung',
    text: 'Schichtpläne automatisch und arbeitszeitkonform: weniger Überstunden, mehr Ruhe im Team.',
    effekt: '+28.000 €',
    tag: '',
  },
  {
    icon: 'kreislauf',
    name: 'Workflow-Automatisierung',
    text: 'Rechnung, Check-in, Housekeeping: wiederkehrende Abläufe laufen von selbst statt von Hand.',
    effekt: '+18.000 €',
    tag: '',
  },
  {
    icon: 'nachhaltigkeit',
    name: 'Wareneinsatzoptimierung',
    text: 'Bestände und Einkauf im Blick, Schwund runter — auch für Restaurants ganz ohne Zimmer.',
    effekt: '+14.000 €',
    tag: 'Auch Gastronomie',
  },
];
---
<Base
  title="Pilotprojekte — NextCourse Consulting"
  description="Pilotprojekte von NextCourse: klar umrissene KI-Projekte zum Festpreis — messbar, in Wochen statt Monaten und ohne den laufenden Betrieb lahmzulegen. Fünf Bausteine vom KI-Telefonassistenten bis zur Wareneinsatzoptimierung."
>
  <div class="pagehead">
    <span class="ghostglyph" aria-hidden="true">%</span>
    <div class="wrap" style="text-align:center">
      <p class="eyebrow eyebrow--c">Consulting · Pilotprojekte</p>
      <h1 style="max-width:none;margin:0 auto">Ein Baustein. Ein Festpreis. Ein messbares Ergebnis.</h1>
      <p class="voice" style="max-width:36em;margin:1.6rem auto 0">Pilotprojekte sind klar umrissene KI-Projekte zum Festpreis — messbar, in Wochen statt Monaten und ohne Ihren laufenden Betrieb lahmzulegen.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:1020px">

      <!-- Kennzahlen-Trio -->
      <div class="trio reveal">
        <div class="trio__cell"><span class="trio__big">5 Bausteine</span><span class="trio__sub">vom Telefon bis zum Wareneinsatz</span></div>
        <div class="trio__cell"><span class="trio__big">Fester Preis</span><span class="trio__sub">vorab vereinbart, keine offene Rechnung</span></div>
        <div class="trio__cell"><span class="trio__big">Messbar</span><span class="trio__sub">Wirkung in Zahlen, nicht in Versprechen</span></div>
      </div>

      <!-- Die fünf Bausteine -->
      <div class="mcsection reveal">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">Die fünf Bausteine</p>
        <p class="mcsection__hint">Jeder wirkt für sich — und baut auf dem vorherigen auf.</p>
        <div class="bsteine stagger">
          {bausteine.map((b) => (
            <div class="bstein reveal">
              <span class="bstein__ico" aria-hidden="true"><Icon name={b.icon} size={30} /></span>
              <div class="bstein__body">
                <h3>{b.name}</h3>
                <p>{b.text}</p>
              </div>
              <div class="bstein__meta">
                <span class="bstein__effekt">{b.effekt}<small>pro Jahr*</small></span>
                {b.tag && <span class="bstein__tag">{b.tag}</span>}
              </div>
            </div>
          ))}
        </div>
        <p class="bsteine__note">* Modellwerte des Referenzbetriebs (65 Zimmer, 1,6 Mio. € Umsatz). Ihre Zahlen klären wir im Erstgespräch.</p>
        <div style="text-align:center;margin-top:.4rem">
          <a class="arrowlink" href="/consulting/referenzbetrieb/">Die ganze Rechnung, Baustein für Baustein</a>
        </div>
      </div>

      <!-- Ablauf: interaktiver Stepper -->
      <div class="mcsection reveal">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">So läuft ein Pilotprojekt ab</p>
        <p class="mcsection__hint">Fünf Schritte — klicken Sie sich durch.</p>
        <div class="stepper" id="stepper">
          <span class="stepper__track" aria-hidden="true"></span>
          <button class="stepbtn" data-step="0" aria-current="true"><span class="stepbtn__num">01</span><span class="stepbtn__label">Scoping</span></button>
          <button class="stepbtn" data-step="1"><span class="stepbtn__num">02</span><span class="stepbtn__label">Festpreis-Angebot</span></button>
          <button class="stepbtn" data-step="2"><span class="stepbtn__num">03</span><span class="stepbtn__label">Umsetzung</span></button>
          <button class="stepbtn" data-step="3"><span class="stepbtn__num">04</span><span class="stepbtn__label">Messung</span></button>
          <button class="stepbtn" data-step="4"><span class="stepbtn__num">05</span><span class="stepbtn__label">Übergabe</span></button>
        </div>
        <div class="stepdetail" aria-live="polite">
          <article data-panel="0">
            <span class="stepdetail__num" aria-hidden="true">01</span>
            <div><h3>Scoping</h3>
            <p>Nach Erstgespräch oder Check legen wir gemeinsam den passenden Baustein, den Umfang und das Ziel fest — bewusst klein und klar abgegrenzt.</p></div>
          </article>
          <article data-panel="1" hidden>
            <span class="stepdetail__num" aria-hidden="true">02</span>
            <div><h3>Festpreis-Angebot</h3>
            <p>Sie erhalten ein klares Angebot: fester Umfang, fester Preis, faire Zahlungslogik. Was vereinbart ist, gilt — keine offene Rechnung am Ende.</p></div>
          </article>
          <article data-panel="2" hidden>
            <span class="stepdetail__num" aria-hidden="true">03</span>
            <div><h3>Umsetzung</h3>
            <p>Wir bauen und integrieren die Lösung bei Ihnen im Haus — Schritt für Schritt, ohne den laufenden Betrieb zu unterbrechen.</p></div>
          </article>
          <article data-panel="3" hidden>
            <span class="stepdetail__num" aria-hidden="true">04</span>
            <div><h3>Messung</h3>
            <p>Vorher, nachher: Wir machen die Wirkung sichtbar — in Belegung, gesparter Zeit oder gesenkten Kosten. Zahlen statt Bauchgefühl.</p></div>
          </article>
          <article data-panel="4" hidden>
            <span class="stepdetail__num" aria-hidden="true">05</span>
            <div><h3>Übergabe</h3>
            <p>Einweisung fürs Team, alles dokumentiert im digitalen Betriebshandbuch. Auf Wunsch bleiben wir als laufende Begleitung an Bord.</p></div>
          </article>
          <div class="stepdetail__foot">
            <span class="stepdetail__count" id="stepcount">Schritt 01 / 05</span>
            <div class="stepnav">
              <button id="stepprev" aria-label="Vorheriger Schritt">←</button>
              <button id="stepnext" aria-label="Nächster Schritt">→</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Festpreis-Logik -->
      <div class="mcsection reveal" style="text-align:center">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">Warum Festpreis</p>
        <h2 style="max-width:16em;margin:0 auto;font-size:clamp(1.7rem,4.5vw,2.4rem)">Sie wissen vorher, woran Sie sind.</h2>
        <p class="voice" style="max-width:30em;margin:1.4rem auto 0">Kein Stundenzähler, kein Scope-Creep, keine Überraschung auf der Schlussrechnung.</p>

        <div class="fixgrid">
          <div class="fixcell">
            <span class="fixcell__k">Fester Umfang</span>
            <p>Ein Baustein, klar abgegrenzt. Kein Feature-Wildwuchs, kein „das machen wir auch noch schnell".</p>
          </div>
          <div class="fixcell">
            <span class="fixcell__k">Fester Preis</span>
            <p>Der Preis steht vor dem Start. Was vereinbart ist, gilt — bis zur Übergabe.</p>
          </div>
          <div class="fixcell">
            <span class="fixcell__k">Faire Raten</span>
            <p>In drei Schritten statt alles auf einmal — Sie zahlen mit, während das Projekt Gestalt annimmt.</p>
          </div>
        </div>

        <div class="rates" aria-label="Zahlungslogik: 30 Prozent zum Start, 40 Prozent zur Projektmitte, 30 Prozent bei Abschluss">
          <div class="rate" style="flex:30"><b>30 %</b><span>zum Start</span></div>
          <div class="rate" style="flex:40"><b>40 %</b><span>Projektmitte</span></div>
          <div class="rate" style="flex:30"><b>30 %</b><span>bei Abschluss</span></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="ctabox reveal">
        <p class="ctabox__eyebrow">Nächster Schritt</p>
        <h3>Welcher Baustein bringt bei Ihnen zuerst Wirkung?</h3>
        <div class="btnrow" style="justify-content:center;margin-top:2rem">
          <a href="/kontakt/" class="btn">Pilotprojekt besprechen</a>
        </div>
        <p class="ctabox__note">Umfang und Festpreis klären wir im kostenlosen Erstgespräch.<br>
        Oder gleich einen <a href="https://cal.com/philip-tolle-yxp7ih/erstgesprach" target="_blank" rel="noopener" style="color:#F4ECDD">Termin fürs Erstgespräch buchen</a>.</p>
      </div>

      <p class="abgrenzung reveal">Ein Pilotprojekt ist bewusst klein gehalten: ein Baustein, ein klares Ziel. Es ist kein monatelanges IT-Projekt und kein Umbau Ihres ganzen Betriebs — sondern der schnellste Weg, KI im Alltag wirken zu sehen. Was danach dauerhaft trägt, klären wir in der Begleitung.</p>

      <div style="text-align:center;margin-top:2.4rem" class="reveal">
        <a class="arrowlink" href="/consulting/">Alle Consulting-Leistungen</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Kennzahlen-Trio */
  .trio{display:grid;gap:1px;background:var(--hairline);border:1px solid var(--hairline);
    border-radius:18px;overflow:hidden;max-width:820px;margin:0 auto}
  @media(min-width:700px){.trio{grid-template-columns:1fr 1fr 1fr}}
  .trio__cell{background:rgba(255,255,255,.6);padding:1.6rem 1.2rem;text-align:center;
    display:flex;flex-direction:column;gap:.25rem}
  .trio__big{font-family:var(--disp);font-size:clamp(1.5rem,3.5vw,2.1rem);color:var(--wood)}
  .trio__sub{font-size:.85rem;color:var(--faint);letter-spacing:.02em}

  .mcsection{margin-top:clamp(4rem,9vw,6rem)}
  .mcsection__hint{text-align:center;font-family:var(--serif);font-style:italic;
    color:var(--faint);font-size:1.1rem;margin:-.4rem 0 1.8rem}

  /* Bausteine-Liste */
  .bsteine{display:flex;flex-direction:column;gap:.9rem;max-width:840px;margin:0 auto}
  .bstein{display:grid;grid-template-columns:auto 1fr;gap:.4rem 1.3rem;align-items:start;
    background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);border-radius:18px;
    padding:1.5rem 1.7rem;backdrop-filter:blur(14px);
    box-shadow:var(--shadow);transition:transform .25s,box-shadow .25s}
  .bstein:hover{transform:translateY(-3px);box-shadow:var(--shadow),var(--glow)}
  .bstein__ico{grid-row:1 / span 2;width:52px;height:52px;border-radius:50%;flex:none;
    display:grid;place-items:center;color:var(--wood);
    background:radial-gradient(circle at 50% 30%,#FFFDF8,var(--paper2));
    border:1px solid var(--hairline)}
  .bstein__body h3{font-size:clamp(1.2rem,3vw,1.5rem);margin-bottom:.25rem}
  .bstein__body p{margin:0;color:var(--dim);font-size:.94rem;line-height:1.6}
  .bstein__meta{grid-column:2;display:flex;flex-wrap:wrap;align-items:center;gap:.7rem 1rem;
    margin-top:.7rem;padding-top:.7rem;border-top:1px solid var(--line)}
  .bstein__effekt{font-family:var(--disp);font-size:1.3rem;color:var(--green);
    font-variant-numeric:tabular-nums;display:inline-flex;align-items:baseline;gap:.4rem}
  .bstein__effekt small{font-family:var(--body);font-size:.72rem;letter-spacing:.08em;
    text-transform:uppercase;color:var(--faint)}
  .bstein__tag{font-family:var(--body);font-weight:500;font-size:.72rem;letter-spacing:.12em;
    text-transform:uppercase;color:var(--wood);border:1px solid var(--hairline);
    border-radius:999px;padding:.25em .8em;background:rgba(255,255,255,.55)}
  @media(min-width:620px){
    .bstein{grid-template-columns:auto 1fr auto}
    .bstein__ico{grid-row:1 / span 2}
    .bstein__meta{grid-column:3;grid-row:1 / span 2;flex-direction:column;align-items:flex-end;
      justify-content:center;margin-top:0;padding-top:0;border-top:0;text-align:right;
      border-left:1px solid var(--line);padding-left:1.4rem;min-width:130px}
  }
  .bsteine__note{max-width:44em;margin:1.4rem auto .4rem;text-align:center;
    font-size:.82rem;line-height:1.6;color:var(--faint)}

  /* Stepper */
  .stepper{position:relative;display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
  .stepper__track{position:absolute;top:2.7rem;left:8%;right:8%;height:1px;
    background:var(--hairline);z-index:0}
  .stepbtn{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;
    gap:.6rem;width:clamp(120px,17vw,180px);padding:1.3rem .8rem;border-radius:18px;
    cursor:pointer;background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    font-family:var(--body);transition:all .28s ease}
  .stepbtn__num{width:44px;height:44px;border-radius:50%;display:grid;place-items:center;
    background:var(--paper2);border:1px solid var(--hairline);font-family:var(--serif);
    font-style:italic;font-size:1.25rem;color:var(--wood);transition:all .28s ease}
  .stepbtn__label{font-size:.85rem;font-weight:500;color:var(--dim);text-align:center;
    transition:color .28s}
  .stepbtn[aria-current="true"]{background:rgba(185,136,92,.12);border-color:rgba(185,136,92,.55);
    box-shadow:0 16px 36px -18px rgba(150,110,60,.5)}
  .stepbtn[aria-current="true"] .stepbtn__num{background:var(--wood);border-color:var(--wood);color:var(--paper)}
  .stepbtn[aria-current="true"] .stepbtn__label{color:var(--ink)}
  .stepbtn:hover{transform:translateY(-2px)}

  .stepdetail{margin-top:1.4rem;background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    border-radius:22px;padding:clamp(1.8rem,4vw,2.6rem);
    backdrop-filter:blur(14px);box-shadow:var(--shadow)}
  .stepdetail article{display:flex;gap:1.8rem;align-items:flex-start;animation:stepin .35s ease both}
  .stepdetail article[hidden]{display:none}
  @keyframes stepin{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .stepdetail__num{font-family:var(--serif);font-style:italic;font-weight:500;
    font-size:clamp(3rem,7vw,4.4rem);line-height:.8;color:var(--wood);flex:none}
  .stepdetail h3{font-size:clamp(1.4rem,3.5vw,1.9rem);margin-bottom:.5rem}
  .stepdetail p{margin:0;color:var(--dim);line-height:1.65}
  .stepdetail__foot{margin-top:1.6rem;padding-top:1.3rem;border-top:1px solid var(--line);
    display:flex;align-items:center;justify-content:space-between;gap:1rem}
  .stepdetail__count{font-size:.75rem;letter-spacing:.26em;text-transform:uppercase;color:var(--faint)}
  .stepnav{display:flex;gap:.6rem}
  .stepnav button{width:46px;height:46px;border-radius:50%;cursor:pointer;font-size:1.1rem;
    background:transparent;border:1px solid rgba(38,34,27,.3);color:var(--dim);transition:all .2s}
  .stepnav button:last-child{background:var(--wood);border-color:var(--wood);color:var(--paper)}
  .stepnav button:disabled{opacity:.35;cursor:default}

  /* Festpreis-Logik */
  .fixgrid{display:grid;gap:1px;background:var(--hairline);border:1px solid var(--hairline);
    border-radius:20px;overflow:hidden;margin:2.6rem auto 0;max-width:900px;text-align:left}
  @media(min-width:760px){.fixgrid{grid-template-columns:repeat(3,1fr)}}
  .fixcell{background:rgba(255,255,255,.6);padding:1.7rem 1.8rem}
  .fixcell__k{display:block;font-family:var(--disp);font-size:1.3rem;color:var(--ink);margin-bottom:.5rem}
  .fixcell p{margin:0;font-size:.92rem;line-height:1.6;color:var(--dim)}

  .rates{display:flex;gap:.5rem;max-width:900px;margin:1.4rem auto 0}
  .rate{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.15rem;
    padding:1.1rem .6rem;border-radius:14px;background:rgba(185,136,92,.1);
    border:1px solid var(--hairline)}
  .rate b{font-family:var(--disp);font-weight:400;font-size:clamp(1.3rem,3.5vw,1.8rem);color:var(--wood)}
  .rate span{font-size:.76rem;letter-spacing:.08em;text-transform:uppercase;color:var(--faint);text-align:center}

  /* CTA-Box */
  .ctabox{margin-top:clamp(4rem,9vw,5.5rem);background:var(--ink);border-radius:26px;
    padding:clamp(2.6rem,6vw,3.8rem) clamp(1.6rem,5vw,3.5rem);text-align:center;
    box-shadow:0 40px 90px -50px rgba(60,45,25,.7)}
  .ctabox__eyebrow{font-size:.72rem;letter-spacing:.32em;text-transform:uppercase;
    color:rgba(229,162,84,.75);margin:0}
  .ctabox h3{margin:1.1rem auto 0;max-width:15em;font-size:clamp(1.8rem,4.5vw,2.5rem);
    line-height:1.12;color:#F4ECDD}
  .ctabox__note{margin:1.4rem 0 0;font-size:.82rem;letter-spacing:.04em;color:#8F8574;line-height:1.7}

  .abgrenzung{margin:2.4rem auto 0;max-width:46em;text-align:center;
    font-size:.85rem;line-height:1.65;color:var(--faint)}

  @media(prefers-reduced-motion:reduce){
    .stepdetail article{animation:none}
    .bstein{transition:none}
  }
</style>

<script>
  /* ---------- Stepper ---------- */
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.stepbtn'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.stepdetail article'));
  const count = document.getElementById('stepcount')!;
  const prev = document.getElementById('stepprev') as HTMLButtonElement;
  const next = document.getElementById('stepnext') as HTMLButtonElement;
  let current = 0;

  function showStep(i: number) {
    current = Math.max(0, Math.min(panels.length - 1, i));
    btns.forEach((b, k) => b.setAttribute('aria-current', k === current ? 'true' : 'false'));
    panels.forEach((p, k) => { p.hidden = k !== current; });
    count.textContent = 'Schritt 0' + (current + 1) + ' / 05';
    prev.disabled = current === 0;
    next.disabled = current === panels.length - 1;
  }
  btns.forEach((b) => b.addEventListener('click', () => showStep(parseInt(b.dataset.step!, 10))));
  prev.addEventListener('click', () => showStep(current - 1));
  next.addEventListener('click', () => showStep(current + 1));
  showStep(0);
</script>

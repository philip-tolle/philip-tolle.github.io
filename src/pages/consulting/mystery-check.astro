---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import philip from '../../assets/philip.png';
---
<Base
  title="Mystery Check — NextCourse Consulting"
  description="Der Mystery Check von NextCourse: Wir erleben Ihren Betrieb anonym wie ein Gast — von der digitalen Suche bis zum Nachkontakt. Guest-Journey-Ampel, konkrete Beobachtungen und 5–10 priorisierte Maßnahmen."
>
  <div class="pagehead">
    <span class="ghostglyph" aria-hidden="true">?</span>
    <div class="wrap" style="text-align:center">
      <p class="eyebrow eyebrow--c">Mystery Check · Guest Journey</p>
      <h1 style="max-width:none;margin:0 auto">Sehen Sie Ihren Betrieb mit den Augen Ihrer Gäste.</h1>
      <p class="voice" style="max-width:34em;margin:1.6rem auto 0">Der Mystery Check zeigt, wie Ihr Hotel oder Restaurant von der digitalen Suche bis zum Nachkontakt wirklich erlebt wird — und wo entlang der Guest Journey Reibung, Umsatzpotenzial und Qualitätslücken sichtbar werden.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:1020px">

      <!-- Kennzahlen-Trio -->
      <div class="trio reveal">
        <div class="trio__cell"><span class="trio__big">5 Phasen</span><span class="trio__sub">vom Erstkontakt bis Nachkontakt</span></div>
        <div class="trio__cell"><span class="trio__big">6 Kontaktpunkte</span><span class="trio__sub">als Guest-Journey-Ampel</span></div>
        <div class="trio__cell"><span class="trio__big">5–10 Maßnahmen</span><span class="trio__sub">priorisiert &amp; sofort umsetzbar</span></div>
      </div>

      <!-- Ablauf: interaktiver Stepper -->
      <div class="mcsection reveal">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">So läuft es ab</p>
        <p class="mcsection__hint">Fünf Phasen — klicken Sie sich durch.</p>
        <div class="stepper" id="stepper">
          <span class="stepper__track" aria-hidden="true"></span>
          <button class="stepbtn" data-step="0" aria-current="true"><span class="stepbtn__num">01</span><span class="stepbtn__label">Zielklärung</span></button>
          <button class="stepbtn" data-step="1"><span class="stepbtn__num">02</span><span class="stepbtn__label">Digitale Prüfung</span></button>
          <button class="stepbtn" data-step="2"><span class="stepbtn__num">03</span><span class="stepbtn__label">Mystery-Szenario</span></button>
          <button class="stepbtn" data-step="3"><span class="stepbtn__num">04</span><span class="stepbtn__label">Auswertung</span></button>
          <button class="stepbtn" data-step="4"><span class="stepbtn__num">05</span><span class="stepbtn__label">Übergabe</span></button>
        </div>
        <div class="stepdetail" aria-live="polite">
          <article data-panel="0">
            <span class="stepdetail__num" aria-hidden="true">01</span>
            <div><h3>Zielklärung</h3>
            <p>In einem kurzen Vorab-Call klären wir Betriebstyp, Fokus und das passende Mystery-Szenario. Sie legen fest, welche Bereiche geprüft werden dürfen und welche No-Go-Bereiche unangetastet bleiben.</p></div>
          </article>
          <article data-panel="1" hidden>
            <span class="stepdetail__num" aria-hidden="true">02</span>
            <div><h3>Digitale Prüfung</h3>
            <p>Wir prüfen Website, Google-Profil, Anfrageweg, Reservierung und Buchung — und wie schnell, klar und freundlich Anfragen über alle Kanäle beantwortet werden.</p></div>
          </article>
          <article data-panel="2" hidden>
            <span class="stepdetail__num" aria-hidden="true">03</span>
            <div><h3>Mystery-Szenario</h3>
            <p>Als echter Gast durchlaufen wir ein Hotel- oder Restaurant-Szenario entlang der gesamten Guest Journey: von der Anfrage über Service und Aufenthalt bis zum Nachkontakt.</p></div>
          </article>
          <article data-panel="3" hidden>
            <span class="stepdetail__num" aria-hidden="true">04</span>
            <div><h3>Auswertung</h3>
            <p>Alle Beobachtungen werden fair, konkret und nach Wirkung priorisiert dokumentiert — sauber getrennt in Beobachtung, mögliche Ursache und empfohlene Maßnahme.</p></div>
          </article>
          <article data-panel="4" hidden>
            <span class="stepdetail__num" aria-hidden="true">05</span>
            <div><h3>Übergabe</h3>
            <p>Im persönlichen Gespräch erhalten Sie die wichtigsten Erkenntnisse, die Guest-Journey-Ampel und Ihre nächsten Schritte — mit klarer Empfehlung, was zuerst Wirkung zeigt.</p></div>
          </article>
          <div class="stepdetail__foot">
            <span class="stepdetail__count" id="stepcount">Schritt 01 / 05</span>
            <div class="stepnav">
              <button id="stepprev" aria-label="Vorheriger Schritt">←</button>
              <button id="stepnext" aria-label="Nächster Schritt">→</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Guest-Journey-Ampel -->
      <div class="mcsection reveal">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">Guest-Journey-Ampel</p>
        <p class="mcsection__hint">Jeden Kontaktpunkt bewerten wir in Grün, Gelb oder Rot. Tippen Sie an, worauf wir dabei achten.</p>
        <div class="legend">
          <span><i class="dot dot--g"></i>Wirkt stark</span>
          <span><i class="dot dot--y"></i>Spürbare Reibung</span>
          <span><i class="dot dot--r"></i>Handlungsbedarf</span>
        </div>
        <div class="ampel">
          <div class="ampelrow">
            <button aria-expanded="false"><span>Digitale Auffindbarkeit</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Findet der Gast schnell, was er braucht?</p>
          </div>
          <div class="ampelrow">
            <button aria-expanded="false"><span>Anfrage und Antwort</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Wird klar, freundlich und verbindlich kommuniziert?</p>
          </div>
          <div class="ampelrow">
            <button aria-expanded="false"><span>Buchung oder Reservierung</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Führt der Weg reibungslos von der Anfrage zur Buchung?</p>
          </div>
          <div class="ampelrow">
            <button aria-expanded="false"><span>Erwartungsmanagement</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Passen Versprechen, Atmosphäre und Erlebnis zusammen?</p>
          </div>
          <div class="ampelrow">
            <button aria-expanded="false"><span>Service-Erlebnis vor Ort</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Wirkt der Service aufmerksam, professionell und gastfreundlich?</p>
          </div>
          <div class="ampelrow">
            <button aria-expanded="false"><span>Nachkontakt und Feedback</span><span class="ampelrow__right"><i class="dot dot--g"></i><i class="dot dot--y"></i><i class="dot dot--r"></i><b>+</b></span></button>
            <p hidden>Wird Feedback aktiv genutzt oder dem Zufall überlassen?</p>
          </div>
        </div>
      </div>

      <!-- Der Blick dahinter -->
      <div class="mcsection reveal" style="text-align:center">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">Der Blick dahinter</p>
        <h2 style="max-width:none;font-size:clamp(1.7rem,4.5vw,2.4rem)">Ich sehe, was Gästen auffällt — und Betrieben entgeht.</h2>
        <div class="coin" data-tilt style="--coin:140px;margin:2rem auto 0">
          <Image src={philip} alt="Philip Tolle, Gründer von NextCourse" width={340} format="webp" quality={82} />
        </div>
        <p class="voice" style="max-width:30em;margin:1.8rem auto 0">Ich habe ADHS. Im Alltag heißt das: Mein Kopf macht keine Pausen. Im Mystery Check heißt es: Ihrem Betrieb entgeht nichts.</p>
        <div class="traits">
          <div class="trait">
            <span class="coin coin--art" style="--coin:88px" aria-hidden="true">
              <svg viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 30 C 30 12, 70 12, 86 30 C 70 48, 30 48, 14 30 Z"/>
                <circle cx="50" cy="30" r="9"/>
              </svg>
            </span>
            <h3>Details, die auffallen</h3>
            <p>Der schiefe Aushang, die müde Begrüßung, der Moment zu lang in der Warteschleife — ich sehe es, ohne zu suchen.</p>
          </div>
          <div class="trait">
            <span class="coin coin--art" style="--coin:88px" aria-hidden="true">
              <svg viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="22" cy="16" r="4"/><circle cx="78" cy="12" r="4"/>
                <circle cx="34" cy="46" r="4"/><circle cx="70" cy="42" r="4"/>
                <path d="M26 18 L74 14 M25 19 L32 42 M37 44 L66 42 M74 16 L71 38"/>
              </svg>
            </span>
            <h3>Verbindungen sehen</h3>
            <p>Mein Kopf verknüpft ständig — was an der Rezeption beginnt, endet oft in der Küche. Solche Zusammenhänge bleiben anderen verborgen.</p>
          </div>
          <div class="trait">
            <span class="coin coin--art" style="--coin:88px" aria-hidden="true">
              <svg viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="50" cy="30" r="22"/><circle cx="50" cy="30" r="11"/>
                <circle cx="50" cy="30" r="2.5" fill="currentColor"/>
                <path d="M50 2 L50 8 M50 52 L50 58 M22 30 L28 30 M72 30 L78 30"/>
              </svg>
            </span>
            <h3>Hyperfokus</h3>
            <p>Wenn ich in Ihrem Betrieb bin, bin ich ganz da — stundenlang, mit voller Aufmerksamkeit für jede Kleinigkeit.</p>
          </div>
          <div class="trait">
            <span class="coin coin--art" style="--coin:88px" aria-hidden="true">
              <svg viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M50 52 C 20 34, 24 10, 42 12 C 48 13, 50 18, 50 20 C 50 18, 52 13, 58 12 C 76 10, 80 34, 50 52 Z"/>
                <path d="M32 30 L42 30 L46 22 L52 38 L56 30 L68 30"/>
              </svg>
            </span>
            <h3>Gespür für Menschen</h3>
            <p>Stimmungen bei Gästen und im Team spüre ich oft, bevor sie jemand ausspricht.</p>
          </div>
        </div>
        <p class="small faint" style="max-width:34em;margin:2rem auto 0">ADHS ist keine Schwäche — es ist der Grund, warum dieser Check anders ist als jede Checkliste.</p>
      </div>

      <!-- Das bekommen Sie -->
      <div class="mcsection reveal">
        <p class="eyebrow eyebrow--c" style="--acc:var(--wood)">Das bekommen Sie</p>
        <div class="dgrid">
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>Kompakter Mystery-Report</h3><p>Strukturierte Kurzfassung Ihrer Guest Journey aus echter Gästesicht.</p></div></div>
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>Guest-Journey-Ampel</h3><p>Grün, Gelb, Rot über alle sechs Kontaktpunkte hinweg.</p></div></div>
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>Konkrete Beobachtungen</h3><p>Was ein Gast erlebt — Situation, Wirkung und mögliche Ursache.</p></div></div>
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>5–10 priorisierte Maßnahmen</h3><p>Nach Wirkung und Aufwand sortiert, sofort umsetzbar.</p></div></div>
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>Quick Wins</h3><p>Sofort spürbare Hebel für Service, Kommunikation und Abläufe.</p></div></div>
          <div class="dcell"><span class="dcheck" aria-hidden="true">✓</span><div><h3>Empfehlung zum nächsten Schritt</h3><p>Ob Folgeprojekt, Schulung oder laufende Begleitung sinnvoll ist.</p></div></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="ctabox reveal">
        <p class="ctabox__eyebrow">Nächster Schritt</p>
        <h3>Finden wir heraus, wie Ihr Betrieb wirklich ankommt.</h3>
        <div class="btnrow" style="justify-content:center;margin-top:2rem">
          <a href="/kontakt/" class="btn">Mystery Check anfragen</a>
        </div>
        <p class="ctabox__price">Pilotangebot&ensp;<b>950 €</b>&ensp;<s>1.490 €</s></p>
        <p class="ctabox__note">Für inhabergeführte Hotels &amp; Restaurants in Mainfranken und Bayern.</p>
      </div>

      <p class="abgrenzung reveal">Der Mystery Check ist keine verdeckte Mitarbeiterkontrolle, kein vollständiges Organisationsaudit und keine Rechtsprüfung. Er ist ein pragmatischer Einstieg, der zeigt, wie Ihr Betrieb für Gäste tatsächlich erlebbar wird.</p>

      <div style="text-align:center;margin-top:2.4rem" class="reveal">
        <a class="arrowlink" href="/consulting/">Alle Consulting-Leistungen</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Kennzahlen-Trio */
  .trio{display:grid;gap:1px;background:var(--hairline);border:1px solid var(--hairline);
    border-radius:18px;overflow:hidden;max-width:820px;margin:0 auto}
  @media(min-width:700px){.trio{grid-template-columns:1fr 1fr 1fr}}
  .trio__cell{background:rgba(255,255,255,.6);padding:1.6rem 1.2rem;text-align:center;
    display:flex;flex-direction:column;gap:.25rem}
  .trio__big{font-family:var(--disp);font-size:clamp(1.5rem,3.5vw,2.1rem);color:var(--wood)}
  .trio__sub{font-size:.85rem;color:var(--faint);letter-spacing:.02em}

  .mcsection{margin-top:clamp(4rem,9vw,6rem)}
  .mcsection__hint{text-align:center;font-family:var(--serif);font-style:italic;
    color:var(--faint);font-size:1.1rem;margin:-.4rem 0 1.8rem}

  /* Stepper */
  .stepper{position:relative;display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
  .stepper__track{position:absolute;top:2.7rem;left:8%;right:8%;height:1px;
    background:var(--hairline);z-index:0}
  .stepbtn{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;
    gap:.6rem;width:clamp(120px,17vw,180px);padding:1.3rem .8rem;border-radius:18px;
    cursor:pointer;background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    font-family:var(--body);transition:all .28s ease}
  .stepbtn__num{width:44px;height:44px;border-radius:50%;display:grid;place-items:center;
    background:var(--paper2);border:1px solid var(--hairline);font-family:var(--serif);
    font-style:italic;font-size:1.25rem;color:var(--wood);transition:all .28s ease}
  .stepbtn__label{font-size:.85rem;font-weight:500;color:var(--dim);text-align:center;
    transition:color .28s}
  .stepbtn[aria-current="true"]{background:rgba(185,136,92,.12);border-color:rgba(185,136,92,.55);
    box-shadow:0 16px 36px -18px rgba(150,110,60,.5)}
  .stepbtn[aria-current="true"] .stepbtn__num{background:var(--wood);border-color:var(--wood);color:var(--paper)}
  .stepbtn[aria-current="true"] .stepbtn__label{color:var(--ink)}
  .stepbtn:hover{transform:translateY(-2px)}

  .stepdetail{margin-top:1.4rem;background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    border-radius:22px;padding:clamp(1.8rem,4vw,2.6rem);
    backdrop-filter:blur(14px);box-shadow:var(--shadow)}
  .stepdetail article{display:flex;gap:1.8rem;align-items:flex-start;animation:stepin .35s ease both}
  .stepdetail article[hidden]{display:none}
  @keyframes stepin{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .stepdetail__num{font-family:var(--serif);font-style:italic;font-weight:500;
    font-size:clamp(3rem,7vw,4.4rem);line-height:.8;color:var(--wood);flex:none}
  .stepdetail h3{font-size:clamp(1.4rem,3.5vw,1.9rem);margin-bottom:.5rem}
  .stepdetail p{margin:0;color:var(--dim);line-height:1.65}
  .stepdetail__foot{margin-top:1.6rem;padding-top:1.3rem;border-top:1px solid var(--line);
    display:flex;align-items:center;justify-content:space-between;gap:1rem}
  .stepdetail__count{font-size:.75rem;letter-spacing:.26em;text-transform:uppercase;color:var(--faint)}
  .stepnav{display:flex;gap:.6rem}
  .stepnav button{width:46px;height:46px;border-radius:50%;cursor:pointer;font-size:1.1rem;
    background:transparent;border:1px solid rgba(38,34,27,.3);color:var(--dim);transition:all .2s}
  .stepnav button:last-child{background:var(--wood);border-color:var(--wood);color:var(--paper)}
  .stepnav button:disabled{opacity:.35;cursor:default}

  /* Der Blick dahinter */
  .traits{display:grid;gap:1.8rem 1.4rem;margin-top:2.6rem;text-align:center}
  @media(min-width:700px){.traits{grid-template-columns:repeat(2,1fr)}}
  @media(min-width:1000px){.traits{grid-template-columns:repeat(4,1fr)}}
  .trait{display:flex;flex-direction:column;align-items:center;gap:.6rem}
  .trait h3{font-size:1.1rem;margin-top:.4rem}
  .trait p{margin:0;font-size:.88rem;line-height:1.55;color:var(--faint);max-width:24em}

  /* Ampel */
  .legend{display:flex;justify-content:center;gap:1.6rem;flex-wrap:wrap;margin-bottom:1.4rem;
    font-size:.88rem;color:var(--dim)}
  .legend span{display:inline-flex;align-items:center;gap:.5rem}
  .dot{width:11px;height:11px;border-radius:50%;display:inline-block}
  .dot--g{background:#7EA36B}.dot--y{background:#D6A94E}.dot--r{background:#C77B63}
  .ampel{display:flex;flex-direction:column;gap:.6rem;max-width:840px;margin:0 auto}
  .ampelrow{background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    border-radius:15px;overflow:hidden;transition:all .25s ease}
  .ampelrow.is-open{background:rgba(185,136,92,.09);border-color:rgba(185,136,92,.4)}
  .ampelrow button{width:100%;display:flex;align-items:center;justify-content:space-between;
    gap:1rem;padding:1.05rem 1.4rem;background:none;border:0;cursor:pointer;
    font-family:var(--body);font-size:1rem;color:var(--ink);text-align:left}
  .ampelrow__right{display:inline-flex;align-items:center;gap:1rem}
  .ampelrow__right .dot{width:10px;height:10px}
  .ampelrow__right b{width:22px;text-align:center;font-size:1.25rem;font-weight:300;color:var(--wood)}
  .ampelrow p{margin:0;padding:0 1.4rem 1.05rem;font-family:var(--serif);font-style:italic;
    font-size:1.15rem;color:var(--dim);animation:stepin .3s ease both}

  /* Deliverables */
  .dgrid{display:grid;gap:1px;background:var(--hairline);border:1px solid var(--hairline);
    border-radius:20px;overflow:hidden}
  @media(min-width:760px){.dgrid{grid-template-columns:1fr 1fr}}
  .dcell{background:rgba(255,255,255,.6);padding:1.7rem 1.9rem;display:flex;gap:1rem;
    align-items:flex-start}
  .dcheck{flex:none;width:30px;height:30px;border-radius:50%;background:rgba(185,136,92,.16);
    display:grid;place-items:center;color:var(--wood);font-size:.9rem;margin-top:2px}
  .dcell h3{font-size:1.15rem;margin-bottom:.25rem}
  .dcell p{margin:0;font-size:.9rem;line-height:1.55;color:var(--faint)}

  /* CTA-Box */
  .ctabox{margin-top:clamp(4rem,9vw,5.5rem);background:var(--ink);border-radius:26px;
    padding:clamp(2.6rem,6vw,3.8rem) clamp(1.6rem,5vw,3.5rem);text-align:center;
    box-shadow:0 40px 90px -50px rgba(60,45,25,.7)}
  .ctabox__eyebrow{font-size:.72rem;letter-spacing:.32em;text-transform:uppercase;
    color:rgba(229,162,84,.75);margin:0}
  .ctabox h3{margin:1.1rem auto 0;max-width:15em;font-size:clamp(1.8rem,4.5vw,2.5rem);
    line-height:1.12;color:#F4ECDD}
  .ctabox__price{margin:1.6rem 0 0;font-size:.95rem;letter-spacing:.03em;color:#B3A894}
  .ctabox__price b{color:#F4ECDD;font-weight:500;font-size:1.1rem}
  .ctabox__price s{opacity:.55}
  .ctabox__note{margin:.5rem 0 0;font-size:.82rem;letter-spacing:.04em;color:#8F8574}

  .abgrenzung{margin:2.4rem auto 0;max-width:46em;text-align:center;
    font-size:.85rem;line-height:1.65;color:var(--faint)}

  @media(prefers-reduced-motion:reduce){
    .stepdetail article,.ampelrow p{animation:none}
  }
</style>

<script>
  /* ---------- Stepper ---------- */
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.stepbtn'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.stepdetail article'));
  const count = document.getElementById('stepcount')!;
  const prev = document.getElementById('stepprev') as HTMLButtonElement;
  const next = document.getElementById('stepnext') as HTMLButtonElement;
  let current = 0;

  function showStep(i: number) {
    current = Math.max(0, Math.min(panels.length - 1, i));
    btns.forEach((b, k) => b.setAttribute('aria-current', k === current ? 'true' : 'false'));
    panels.forEach((p, k) => { p.hidden = k !== current; });
    count.textContent = 'Schritt 0' + (current + 1) + ' / 05';
    prev.disabled = current === 0;
    next.disabled = current === panels.length - 1;
  }
  btns.forEach((b) => b.addEventListener('click', () => showStep(parseInt(b.dataset.step!, 10))));
  prev.addEventListener('click', () => showStep(current - 1));
  next.addEventListener('click', () => showStep(current + 1));
  showStep(0);

  /* ---------- Ampel-Akkordeon (eine Zeile offen) ---------- */
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.ampelrow'));
  rows.forEach((row) => {
    const btn = row.querySelector('button')!;
    const panel = row.querySelector('p')!;
    btn.addEventListener('click', () => {
      const willOpen = panel.hidden;
      rows.forEach((r) => {
        r.classList.remove('is-open');
        r.querySelector('p')!.hidden = true;
        r.querySelector('button')!.setAttribute('aria-expanded', 'false');
        r.querySelector('.ampelrow__right b')!.textContent = '+';
      });
      if (willOpen) {
        row.classList.add('is-open');
        panel.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        row.querySelector('.ampelrow__right b')!.textContent = '–';
      }
    });
  });
</script>

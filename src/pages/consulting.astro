---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Kompass from '../components/Kompass.astro';
import Startkarte from '../components/Startkarte.astro';
import bannerConsulting from '../assets/banner-consulting-v4.png';
import logo from '../assets/nc-logo.png';

const angebote = [
  { id: 'checks', icon: 'blick', titel: 'Analyse & Checks', intro: 'Bevor sich etwas ändert, braucht es Klarheit. Unsere Checks zeigen ehrlich, wo Ihr Haus steht — aus Gästesicht und entlang der neuen KI-Pflichten.', items: [
    { icon: 'handbuch', text: 'EU AI Act Quick-Check' },
    { icon: 'blick', text: 'Mystery Check aus Gästesicht' },
    { icon: 'analyse', text: 'Modellrechnung am Referenzbetrieb' },
    { icon: 'ziel', text: 'Priorisierter Maßnahmenplan' },
  ] },
  { id: 'schulung', icon: 'lernen', titel: 'Schulung im Betrieb', intro: 'Veränderung trägt nur, wenn das Team sie versteht. Wir schulen direkt im Betrieb — mit Ihren Abläufen, nicht mit Folien von der Stange.', items: [
    { icon: 'gastlichkeit', text: 'Flying Academy — bei Ihnen im Haus' },
    { icon: 'ausbildung', text: 'EU AI Act Grundschulung (Art. 4)' },
    { icon: 'ki', text: 'KI-Praxis mit Ihren Anwendungsfällen' },
    { icon: 'gespraech', text: 'Individuell nach Absprache' },
  ] },
  { id: 'umsetzung', icon: 'ziel', titel: 'Umsetzung & Begleitung', intro: 'Aus Empfehlungen werden Projekte: klar geschnitten, zum Festpreis, messbar. Und wer dranbleiben will, bekommt laufende Begleitung.', items: [
    { icon: 'gespraech', text: 'KI-Telefonassistent & Co.' },
    { icon: 'ziel', text: 'Implementierungsprojekte zum Festpreis' },
    { icon: 'ki', text: 'CorporateLLM als Ausbaustufe' },
    { icon: 'kreislauf', text: 'Begleitung & Support — in Vorbereitung' },
  ] },
];

const stationen = [
  { num: '01', icon: 'blick', title: 'Der ehrliche Blick', text: 'Zwei Wege zu Klarheit — von außen als Gast oder entlang der neuen KI-Pflichten.', id: 'blick', offers: [
    { title: 'EU AI Act Quick-Check', text: 'Wo stehen Sie bei den neuen KI-Pflichten? Bestandsaufnahme und priorisierter Maßnahmenplan.', href: '/consulting/quick-check/' },
    { title: 'Mystery Check', text: 'Ihr Betrieb mit den Augen der Gäste — entlang der gesamten Guest Journey.', href: '/consulting/mystery-check/' },
  ] },
  { num: '02', icon: 'lernen', title: 'Flying Academy', text: 'Wir schulen Ihr Team bei Ihnen im Haus — mit Anwendungsfällen aus Ihrem Betrieb.', id: 'flying', offers: [
    { title: 'EU AI Act Grundschulung für Ihre Mitarbeiter', text: 'Die Schulungspflicht nach Art. 4 EU AI Act — kompakt bei Ihnen im Haus.', href: '/kontakt/' },
    { title: 'Individuelle Schulung nach Absprache', text: 'Inhalte und Umfang genau auf Ihren Betrieb zugeschnitten.', href: '/kontakt/' },
  ] },
  { num: '03', icon: 'ziel', title: 'Implementierungsprojekte', text: 'Klar umrissene Projekte zum Festpreis — messbar, ohne den Betrieb lahmzulegen.', id: 'impl', offers: [
    { title: 'KI-Telefonassistent', text: 'Rund um die Uhr erreichbar: nimmt Anrufe an, beantwortet Standardfragen, entlastet die Rezeption.', href: '/consulting/implementierungsprojekte/' },
    { title: 'CorporateLLM', text: 'Ein sicheres, unternehmenseigenes KI-Modell — Wissen, Prozesse und Kommunikation an einem Ort.', href: '/consulting/implementierungsprojekte/' },
  ] },
  { num: '04', icon: 'kreislauf', title: 'Begleitung & Support', text: 'Digitales Betriebshandbuch, laufender Support, Monitoring.', soon: true },
];
---
<Base
  title="Consulting — NextCourse"
  description="KI- und Digitalisierungsberatung für inhabergeführte Hotels und gehobene Individualgastronomie in Mainfranken: der ehrliche Blick (Quick-Check, Mystery Check), Flying Academy, Implementierungsprojekte und laufende Begleitung."
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerConsulting} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Consulting</p>
      <h1>Beratung, die ankommt.</h1>
      <p class="lead">NextCourse Consulting übersetzt Digitalisierung und KI in den Betriebsalltag: Wir zeigen, wo Ihr Haus steht, was sich wirklich lohnt — und setzen es messbar um, ohne den laufenden Betrieb zu stören.</p>
    </div>
  </div>

  <!-- Das bieten wir: bildschirmfüllendes Schaufenster -->
  <div class="floor">
    <div class="wrap" style="max-width:1060px">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Das bieten wir</p>
        <h2 class="reveal">Klarheit, Wissen, Umsetzung.</h2>
      </div>
      <Kompass bereiche={angebote} />
      <a class="scrollhint" href="#weg" aria-label="Weiter zu: So arbeiten wir">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <div class="floor--auto floor" id="weg" style="padding-top:clamp(4rem,8vw,6rem)">
    <div class="wrap">
      <div class="menuhead">
        <h2 class="sr-only">So arbeiten wir</h2>
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">So arbeiten wir</p>
        <p class="lead reveal">Schritt für Schritt — jeder baut auf dem vorherigen auf.</p>
      </div>

      <!-- Startpunkt: Erstgespräch, mittig und kompakt — hier beginnt die Linie -->
      <Startkarte frage="Wo steht Ihr Betrieb?" />

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {stationen.map((s) => (
          <div class="station">
            <span class="station__num" aria-hidden="true">{s.num}</span>
            {s.soon ? (
              <div class="offercard station__card deckblatt deckblatt--soon reveal">
                <span class="deckblatt__stamp" aria-hidden="true">In Vorbereitung</span>
                <Icon name={s.icon} size={38} class="station__icon" />
                <h3>{s.title}</h3>
                <p>{s.text}</p>
                <span class="sr-only">Dieser Baustein ist in Vorbereitung.</span>
              </div>
            ) : s.offers ? (
              <>
                <button type="button" class="offercard station__card deckblatt reveal" aria-expanded="false" aria-controls={`off-${s.id}`}>
                  <Icon name={s.icon} size={38} class="station__icon" />
                  <h3>{s.title}</h3>
                  <p>{s.text}</p>
                  <span class="deckblatt__toggle">Angebote ansehen
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </button>
                <div class="deckoffers" id={`off-${s.id}`} hidden>
                  {s.offers.map((o) => (
                    <a class="deckoffer" href={o.href}>
                      <h4>{o.title}</h4>
                      <p>{o.text}</p>
                      <span class="forkcard__go">Mehr erfahren</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a class="offercard station__card deckblatt reveal" href={s.href}>
                <Icon name={s.icon} size={38} class="station__icon" />
                <h3>{s.title}</h3>
                <p>{s.text}</p>
                <span class="forkcard__go">{s.link}</span>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Claim & Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="claim reveal">Menschliche Kompetenz.<span class="z2">Digitale Kraft.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">KI-Beratung, Bildung &amp; Begleitung für das Gastgewerbe in Mainfranken.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

---
import Base from '../layouts/Base.astro';
---
<Base
  title="Consulting — NextCourse"
  description="KI- und Digitalisierungsberatung für inhabergeführte Hotels und gehobene Individualgastronomie in Mainfranken: Quick-Check, Mystery Check, Pilotprojekte, Begleitung und Flying Academy."
>
  <div class="pagehead">
    <div class="wrap">
      <p class="eyebrow">Consulting</p>
      <h1>Digitalisierung, die im Betrieb ankommt.</h1>
      <p class="lead">Für inhabergeführte Hotels und gehobene Individualgastronomie in Mainfranken.</p>
    </div>
  </div>

  <div class="floor--auto floor">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">So arbeiten wir</p>
        <h2 class="reveal">Ihr nächster Kurs — vom ersten Gespräch bis zum laufenden System.</h2>
        <p class="lead reveal">Prozesse, HR, KI, Compliance und Führung in einem Paket — Schritt für Schritt, jeder baut auf dem vorherigen auf.</p>
      </div>

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__path" d="M65 0 C 105 140, 25 280, 65 420 C 105 560, 25 700, 65 840 C 105 980, 25 1120, 65 1260 C 100 1380, 35 1500, 65 1600"/>
        </svg>
        <div class="station">
          <span class="station__num" aria-hidden="true">01</span>
          <div class="offercard station__card reveal">
            <h3>Kostenloses Erstgespräch</h3>
            <p>Wir hören zu, Sie erzählen — am Telefon oder bei Ihnen im Haus. Danach wissen beide Seiten, ob es passt.</p>
            <a class="arrowlink" href="/kontakt/">Gespräch vereinbaren</a>
          </div>
        </div>
        <div class="station">
          <span class="station__num" aria-hidden="true">02</span>
          <div class="offercard station__card reveal">
            <h3>Der ehrliche Blick</h3>
            <p>Zwei Wege, Klarheit zu gewinnen — von außen als Gast oder entlang der neuen KI-Pflichten:</p>
            <div class="station__links">
              <a class="arrowlink" href="/consulting/quick-check/">EU AI Act Quick-Check</a>
              <a class="arrowlink" href="/consulting/mystery-check/">Mystery Check</a>
            </div>
          </div>
        </div>
        <div class="station">
          <span class="station__num" aria-hidden="true">03</span>
          <div class="offercard station__card reveal">
            <h3>Pilotprojekte</h3>
            <p>Klar umrissene Projekte zum Festpreis — messbar und ohne den laufenden Betrieb lahmzulegen.</p>
            <div class="chips" aria-label="Pilotprojekt-Bausteine">
              <span class="chip">KI-Telefonassistent</span>
              <span class="chip">Revenue Management</span>
              <span class="chip">Dienstplanung</span>
              <span class="chip">Workflow-Automatisierung</span>
              <span class="chip">Wareneinsatz</span>
            </div>
          </div>
        </div>
        <div class="station">
          <span class="station__num" aria-hidden="true">04</span>
          <div class="offercard station__card reveal">
            <h3>Begleitung &amp; Support</h3>
            <p>Nach dem Projekt fängt es erst an: digitales Betriebshandbuch, laufender Support, Monitoring — und die Pflichtthemen Hygiene, DSGVO und EU AI Act digital im Griff.</p>
          </div>
        </div>
      </div>

      <div class="offercard reveal" style="max-width:560px;margin:4rem auto 0;text-align:center">
        <h3>Und Ihr Team?</h3>
        <p>Flying Academy — wir schulen bei Ihnen im Haus, mit Anwendungsfällen aus Ihrem Betrieb.</p>
      </div>
    </div>
  </div>

  <!-- Ergebnis in Zahlen -->
  <div class="floor--auto floor">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal">Was dabei herauskommt</p>
        <h2 class="reveal">Zahlen aus dem Referenzbetrieb.</h2>
      </div>
      <div class="stats reveal">
        <div class="stat">
          <span class="stat__n" data-count="22000" data-suffix=" EUR">22.000 EUR</span>
          <span class="stat__l">Erstinvestition — alle fünf Bausteine</span>
        </div>
        <div class="stat">
          <span class="stat__n" data-count="230000" data-prefix="+" data-suffix=" EUR">+230.000 EUR</span>
          <span class="stat__l">Jahreseffekt aus Einsparungen und Zusatzumsatz</span>
        </div>
        <div class="stat">
          <span class="stat__n" data-count="700" data-prefix="&gt;" data-suffix=" %">&gt;700 %</span>
          <span class="stat__l">Return on Investment im ersten Jahr</span>
        </div>
      </div>
      <p class="bill__fine reveal" style="max-width:560px;margin:2rem auto 0">Modellwerte des Referenzbetriebs: 65 Zimmer, 1,6 Mio. EUR Jahresumsatz. Was bei Ihnen möglich ist, zeigt die Modellrechnung unten.</p>
    </div>
  </div>

  <!-- Modellrechnung (von der Startseite hierher verschoben) -->
  <div class="floor--auto floor">
    <div class="wrap">
      <p class="eyebrow reveal">Modellrechnung</p>
      <h2 class="reveal">Was wäre bei Ihnen möglich?</h2>
      <p class="lead reveal">Stellen Sie Ihren Betrieb ein — wir rechnen unsere Modellwerte auf Ihre Größe um. Ein erster Anhaltspunkt, kein Versprechen.</p>
      <div class="calc">
        <div class="calc__panel reveal">
          <div class="ctl">
            <label for="c-rooms">Zimmer im Haus <output id="o-rooms" for="c-rooms">65 Zimmer</output></label>
            <input type="range" id="c-rooms" min="20" max="150" step="5" value="65">
          </div>
          <div class="ctl">
            <label for="c-adr">Durchschnittlicher Zimmerpreis <output id="o-adr" for="c-adr">120 EUR</output></label>
            <input type="range" id="c-adr" min="80" max="250" step="5" value="120">
          </div>
          <p class="calc__note">Jeder Betrieb ist anders. Wo Ihre Hebel wirklich liegen, klären wir im Erstgespräch — auch für Restaurants ohne Zimmer.</p>
        </div>
        <div class="bill reveal" aria-live="polite">
          <p class="bill__head">Ihre Modellrechnung</p>
          <div class="bl"><b>KI-Telefonassistent</b><span class="dots"></span><span id="r-tel">+77.000 EUR</span></div>
          <div class="bl"><b>Revenue Management</b><span class="dots"></span><span id="r-rev">+93.000 EUR</span></div>
          <div class="bl"><b>Digitale Dienstplanung</b><span class="dots"></span><span id="r-plan">+28.000 EUR</span></div>
          <div class="bl"><b>Workflow-Automatisierung</b><span class="dots"></span><span id="r-flow">+18.000 EUR</span></div>
          <div class="bl"><b>Wareneinsatzoptimierung</b><span class="dots"></span><span id="r-ware">+14.000 EUR</span></div>
          <div class="bl bl--sum"><b>Jahreseffekt</b><span class="dots"></span><span id="r-sum">+230.000 EUR</span></div>
          <p class="bill__fine" id="r-note">Für 65 Zimmer bei 120 EUR Zimmerpreis — gerundet.</p>
          <p class="bill__fine">Modellbasis: Referenzbetrieb mit 65 Zimmern und 1,6 Mio. EUR Jahresumsatz — alle fünf Maßnahmen zusammen erzielen dort einen ROI von über 700 % im ersten Jahr.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Claim & Abschluss (von der Startseite hierher verschoben) -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="claim reveal">Menschliche Kompetenz.<span class="z2">Digitale Kraft.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">KI-Beratung, Bildung &amp; Begleitung für das Gastgewerbe in Mainfranken.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Kurslinie: zeichnet sich beim Scrollen ---------- */
  const kursPath = document.querySelector('.kurs__path') as SVGPathElement | null;
  const kurs = document.getElementById('kurs');
  if (kursPath && kurs) {
    const len = kursPath.getTotalLength();
    kursPath.style.strokeDasharray = String(len);
    if (reduced) {
      kursPath.style.strokeDashoffset = '0';
    } else {
      const update = () => {
        const r = kurs.getBoundingClientRect();
        const passed = Math.min(Math.max(window.innerHeight * 0.75 - r.top, 0), r.height);
        const p = passed / r.height;
        kursPath.style.strokeDashoffset = String(len * (1 - p));
      };
      window.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
      update();
    }
  }

  /* ---------- Ergebniszahlen zählen hoch ---------- */
  const fmt = new Intl.NumberFormat('de-DE');
  document.querySelectorAll<HTMLElement>('.stat__n[data-count]').forEach((el) => {
    const target = parseInt(el.dataset.count!, 10);
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    const render = (v: number) => { el.textContent = prefix + fmt.format(v) + suffix; };
    if (reduced) { render(target); return; }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) { return; }
        io.unobserve(el);
        const t0 = performance.now();
        const dur = 1500;
        const tick = (t: number) => {
          const p = Math.min((t - t0) / dur, 1);
          render(Math.round(target * (1 - Math.pow(1 - p, 3))));
          if (p < 1) { requestAnimationFrame(tick); }
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: .5 });
    io.observe(el);
  });

  /* ---------- ROI-Kalkulator ---------- */
  const BASE_ROOMS = 65, BASE_ADR = 120;
  const ITEMS = [
    { id: 'r-tel', base: 77000, mode: 'rev' },
    { id: 'r-rev', base: 93000, mode: 'rev' },
    { id: 'r-plan', base: 28000, mode: 'ops' },
    { id: 'r-flow', base: 18000, mode: 'ops' },
    { id: 'r-ware', base: 14000, mode: 'ops' },
  ];
  const slRooms = document.getElementById('c-rooms') as HTMLInputElement;
  const slAdr = document.getElementById('c-adr') as HTMLInputElement;
  function fmtEur(v: number) {
    return '+' + (Math.round(v / 1000) * 1000).toLocaleString('de-DE') + ' EUR';
  }
  function calc() {
    const rooms = parseInt(slRooms.value, 10);
    const adr = parseInt(slAdr.value, 10);
    const fRev = (rooms * adr) / (BASE_ROOMS * BASE_ADR);
    const fOps = rooms / BASE_ROOMS;
    let sum = 0;
    ITEMS.forEach((it) => {
      const v = it.base * (it.mode === 'rev' ? fRev : fOps);
      sum += v;
      document.getElementById(it.id)!.textContent = fmtEur(v);
    });
    document.getElementById('r-sum')!.textContent = fmtEur(sum);
    document.getElementById('o-rooms')!.textContent = rooms + ' Zimmer';
    document.getElementById('o-adr')!.textContent = adr + ' EUR';
    document.getElementById('r-note')!.textContent =
      'Für ' + rooms + ' Zimmer bei ' + adr + ' EUR Zimmerpreis — gerundet.';
  }
  slRooms.addEventListener('input', calc);
  slAdr.addEventListener('input', calc);
  calc();
</script>

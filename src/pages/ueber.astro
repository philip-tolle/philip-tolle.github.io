---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import philip from '../assets/philip.png';
import motivNeuseeland from '../assets/motiv-neuseeland.png';
---
<Base
  title="Über NextCourse — Aus der Branche. Für die Branche."
  description="Philip Tolle — Hotelfachmann, Restaurantmeister, Betriebswirt. NextCourse verbindet Herzlichkeit, Bildung und digitale Kompetenz, damit Betriebe zukunftsfähig werden und Menschen souveräner arbeiten."
>
  <div class="pagehead">
    <div class="wrap">
      <p class="eyebrow">Über NextCourse</p>
      <h1>Aus der Branche.<br>Für die Branche.</h1>
    </div>
  </div>

  <!-- Manifest -->
  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Das Manifest</p>
      <p class="voice reveal" style="font-size:clamp(1.25rem,2.8vw,1.55rem);max-width:36em;margin:0 auto">NextCourse steht für eine neue Art von Entwicklung im Gastgewerbe. Wir glauben, dass Technologie nicht gegen den Menschen arbeitet, sondern ihm Raum zurückgeben kann — für Gastfreundschaft, Führung, Qualität und echte Begegnung. Wir bilden, beraten und begleiten Betriebe und Menschen, damit sie Digitalisierung, KI und Veränderung souverän nutzen. Dabei geht es uns nie um Technik allein. Es geht um bessere Arbeit, stärkere Betriebe, mutigere Menschen — und eine Branche, die ihre Herzlichkeit bewahrt, während sie zukunftsfähig wird.</p>
    </div>
  </div>

  <!-- Philip: Profilkarte mit Umdreh-Foto -->
  <div class="floor--auto floor">
    <div class="wrap">
      <div class="profilkarte reveal">
        <div class="flip" id="flip" role="button" tabindex="0" aria-pressed="false"
          aria-label="Foto umdrehen: Stationen und Abschlüsse von Philip Tolle">
          <div class="flip__inner">
            <div class="flip__front">
              <Image src={philip} alt="Philip Tolle — Gründer und Geschäftsführer von NextCourse"
                width={720} format="webp" quality={85} />
              <span class="flip__hint" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 12 a9 9 0 1 0 3.5 -7"/>
                  <path d="M3 3 v6 h6"/>
                </svg>
              </span>
            </div>
            <div class="flip__back">
              <h3>Stationen &amp; Abschlüsse</h3>
              <ul class="quali quali--flip">
                <li>Gelernter Hotelfachmann</li>
                <li>Staatlich geprüfter Restaurantmeister (IHK)</li>
                <li>Staatlich geprüfter Betriebswirt für Hotellerie &amp; Gastronomie</li>
                <li>Sommelier</li>
                <li>Ausbildereignung (IHK)</li>
                <li>Barista Skills Foundation</li>
              </ul>
              <span class="flip__hint" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 12 a9 9 0 1 0 3.5 -7"/>
                  <path d="M3 3 v6 h6"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
        <div class="profilkarte__text">
          <p class="lead">Ich bin Philip Tolle — gelernter Hotelfachmann, Restaurantmeister (IHK), staatlich geprüfter Betriebswirt und seit über 13 Jahren im Gastgewerbe zuhause: vom Commis Sommelier in der Traube Tonbach (3 Michelin-Sterne) bis zum Restaurantleiter internationaler Häuser. NextCourse ist meine Antwort auf eine einfache Beobachtung: Dieser Beruf lebt von Menschen, die gerne Gastgeber sind — und zu viel ihrer Kraft versickert in Verwaltung.</p>
          <blockquote class="quote">„Wir nutzen die Herzlichkeit des Gastgebers und verstärken sie durch die Intelligenz der KI.“</blockquote>
          <p class="dim" style="margin-top:1.4rem">Und noch etwas gehört zu mir: Ich habe ADHS — einen Kopf, der Details, Verbindungen und Stimmungen wahrnimmt, die anderen entgehen. Warum das eine Stärke ist, zeigt sich am deutlichsten im <a href="/consulting/mystery-check/" style="color:var(--green);font-weight:500">Mystery Check</a>.</p>
          <div class="btnrow" style="margin-top:1.8rem">
            <a href="/kontakt/" class="btn">Lernen wir uns kennen</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Gründungsgeschichte -->
  <div class="floor--auto floor" id="geschichte">
    <div class="wrap">
      <div class="coin reveal" data-tilt style="--coin:128px;margin:0 auto 1.6rem">
        <Image src={motivNeuseeland} alt="Kupferstich einer sich entrollenden Farnspirale (Koru)" width={280} format="webp" quality={82} />
      </div>
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Die Gründungsgeschichte</p>
        <h2 class="reveal">Angefangen hat alles in Neuseeland.</h2>
        <p class="lead reveal">Warum NextCourse? Die Antwort beginnt am anderen Ende der Welt — und reicht bis heute. Hören Sie sich die Gründungsgeschichte an.</p>
      </div>
      <div class="audioplayer reveal">
        <button class="audioplayer__btn" type="button" aria-label="Gründungsgeschichte abspielen">
          <svg class="audioplayer__i-play" width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true"><path d="M5 3.5 L14 9 L5 14.5 Z"/></svg>
          <svg class="audioplayer__i-pause" width="16" height="16" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true" hidden><rect x="4" y="3" width="3.5" height="12" rx="1"/><rect x="10.5" y="3" width="3.5" height="12" rx="1"/></svg>
        </button>
        <div class="audioplayer__body">
          <div class="audioplayer__top">
            <span class="audioplayer__title">Die Gründungsgeschichte</span>
            <span class="audioplayer__time"><span class="audioplayer__cur">0:00</span> / <span class="audioplayer__dur">–:––</span></span>
          </div>
          <div class="audioplayer__bar"><span class="audioplayer__fill"></span></div>
        </div>
        <audio preload="metadata" src="/audio/gruendungsgeschichte.mp3"></audio>
      </div>
      <p class="audioplayer__note small faint reveal">Vorgelesen von einer KI-Stimme — die Geschichte ist echt.</p>
    </div>
  </div>

  <!-- Werte -->
  <div class="floor--auto floor">
    <div class="wrap">
      <p class="eyebrow reveal" style="--acc:var(--wood)">Wofür wir stehen</p>
      <h2 class="reveal">Fünf Werte, die jede Beratung und jede Schulung prägen.</h2>
      <div class="rows rows--icons reveal stagger">
        <div class="row"><h3><Icon name="herzlichkeit" size={32} />Herzlichkeit vor Automation</h3>
          <p>Technologie darf den Menschen entlasten — aber nie die Haltung des Gastgebers ersetzen. Menschlichkeit bleibt unser Maßstab.</p></div>
        <div class="row"><h3><Icon name="befaehigung" size={32} />Befähigung statt Abhängigkeit</h3>
          <p>Wir bauen Menschen und Betriebe, die souveräner werden — nicht abhängiger.</p></div>
        <div class="row"><h3><Icon name="exzellenz" size={32} />Exzellenz ohne Perfektionismus</h3>
          <p>Sorgfältig, hochwertig, verantwortungsvoll — und trotzdem handlungsfähig. Wir verbessern lieber sichtbar als endlos zu feilen.</p></div>
        <div class="row"><h3><Icon name="nachhaltigkeit" size={32} />Nachhaltigkeit in der Umsetzung</h3>
          <p>Lösungen müssen langfristig tragen: wirtschaftlich, menschlich und organisatorisch.</p></div>
        <div class="row"><h3><Icon name="mut" size={32} />Mut zur Veränderung</h3>
          <p>Wir gehen voran, probieren aus, lernen sichtbar — und nehmen andere auf diesem Weg mit.</p></div>
      </div>
    </div>
  </div>

  <!-- Klartext: Was wir sind / nicht sind -->
  <div class="floor--auto floor">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Klartext</p>
        <h2 class="reveal">Was wir sind — und was nicht.</h2>
      </div>
      <div class="offers reveal">
        <div class="offercard">
          <h3>Was wir sind</h3>
          <ul class="quali" style="margin-top:.6rem">
            <li>Transformationspartner für das inhabergeführte Gastgewerbe</li>
            <li>Bildung, Beratung und Begleitung aus einer Hand</li>
            <li>Führung und Teamkultur gehören zur Lösung — nicht optional</li>
            <li>Unser Ziel: Ihr Team arbeitet eigenständig mit KI</li>
          </ul>
        </div>
        <div class="offercard">
          <h3>Was wir nicht sind</h3>
          <ul class="quali quali--not" style="margin-top:.6rem">
            <li>Keine IT-Beratung, die Tools installiert und verschwindet</li>
            <li>Kein Bildungsträger, der Standardkurse auf Masse fährt</li>
            <li>Keine Konzepte, die in der Praxis nicht funktionieren</li>
            <li>Keine Abhängigkeit: Wenn wir gehen, läuft es weiter</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Ziele -->
  <div class="floor--auto floor">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Woran wir uns messen lassen wollen</p>
        <h2 class="reveal">Unsere Ziele — offen ausgesprochen.</h2>
      </div>
      <div class="stats reveal" style="max-width:760px;margin-left:auto;margin-right:auto">
        <div class="stat">
          <span class="stat__n" data-count="500">500</span>
          <span class="stat__l">Betriebe nachhaltig transformieren</span>
        </div>
        <div class="stat">
          <span class="stat__n" data-count="1000">1.000</span>
          <span class="stat__l">Menschen in ihrer Entwicklung befähigen</span>
        </div>
        <div class="stat">
          <span class="stat__n" style="font-size:clamp(1.6rem,4vw,2.4rem);line-height:1.3">Mainfranken</span>
          <span class="stat__l">als Vertrauensraum gewinnen</span>
        </div>
      </div>
      <p class="voice reveal" style="max-width:32em;margin:3rem auto 0;text-align:center">Und dahinter das eigentliche Ziel: dass Arbeit im Gastgewerbe wieder Perspektive, Stolz und Sinn bekommt — durch bessere Systeme, bessere Führung und bessere Bildung.</p>
    </div>
  </div>
</Base>

<style>
  .quali--not li::before{background:var(--faint)}

  /* Werte mit edlen Icons statt Punkt */
  .rows--icons .row h3::before{display:none}
  .rows--icons .row h3 :global(.ico){color:var(--wood);flex:none}

  /* Profilkarte */
  .profilkarte{display:grid;gap:2.2rem;align-items:start;
    background:var(--glass);border:1px solid var(--glass-edge);border-radius:24px;
    backdrop-filter:blur(18px) saturate(1.5);-webkit-backdrop-filter:blur(18px) saturate(1.5);
    box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.95);
    padding:clamp(1.6rem,4vw,2.8rem)}
  @media(min-width:880px){.profilkarte{grid-template-columns:320px 1fr;gap:3rem}}
  .profilkarte__text .lead{font-size:clamp(1rem,2.1vw,1.12rem)}

  /* Umdreh-Foto */
  .flip{perspective:1200px;cursor:pointer;max-width:320px;margin:0 auto;width:100%;
    border-radius:18px}
  .flip__inner{position:relative;aspect-ratio:3/4;
    transform-style:preserve-3d;transition:transform .75s cubic-bezier(.3,.1,.25,1)}
  .flip[aria-pressed="true"] .flip__inner{transform:rotateY(180deg)}
  .flip__front,.flip__back{position:absolute;inset:0;backface-visibility:hidden;
    -webkit-backface-visibility:hidden;border-radius:18px;overflow:hidden;
    border:1px solid var(--glass-edge);box-shadow:0 14px 34px rgba(62,50,34,.14)}
  .flip__front img{width:100%;height:100%;object-fit:cover}
  .flip__back{transform:rotateY(180deg);padding:1.6rem 1.4rem;
    display:flex;flex-direction:column;
    background:
      repeating-linear-gradient(transparent 0, transparent calc(1.7rem - 1px),
        rgba(185,136,92,.12) calc(1.7rem - 1px), rgba(185,136,92,.12) 1.7rem),
      var(--paper2)}
  .flip__back h3{font-size:1.25rem;margin-bottom:.6rem}
  .quali--flip{margin-top:0}
  .quali--flip li{padding:.62rem 0 .62rem 1.6rem;font-size:.88rem}
  .quali--flip li::before{top:1.05rem}
  .flip__hint{position:absolute;right:.9rem;bottom:.9rem;width:44px;height:44px;
    border-radius:50%;display:grid;place-items:center;color:var(--wood);
    background:rgba(247,244,239,.92);border:1px solid var(--hairline);
    box-shadow:0 6px 18px rgba(62,50,34,.22);transition:transform .25s}
  .flip:hover .flip__hint{transform:rotate(-45deg)}
  .flip:focus-visible{outline:2px solid var(--green);outline-offset:4px}
  /* Audio-Player Gründungsgeschichte */
  .audioplayer{display:flex;align-items:center;gap:1.2rem;margin:2.4rem auto 0;max-width:520px;
    background:var(--glass);border:1px solid var(--glass-edge);border-radius:18px;
    backdrop-filter:blur(18px) saturate(1.5);-webkit-backdrop-filter:blur(18px) saturate(1.5);
    box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.95);padding:1.2rem 1.5rem}
  .audioplayer__btn{flex:none;width:3.4rem;height:3.4rem;border-radius:50%;cursor:pointer;
    border:1px solid var(--hairline);display:grid;place-items:center;color:var(--wood);
    background:var(--paper);transition:transform .2s,box-shadow .2s}
  .audioplayer__btn:hover{transform:scale(1.05);box-shadow:var(--glow)}
  .audioplayer__body{flex:1;min-width:0}
  .audioplayer__top{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;margin-bottom:.6rem}
  .audioplayer__title{font-family:var(--body);font-weight:500;font-size:.95rem;color:var(--ink)}
  .audioplayer__time{font-size:.78rem;color:var(--faint);font-variant-numeric:tabular-nums;white-space:nowrap}
  .audioplayer__bar{height:6px;border-radius:999px;background:var(--paper2);cursor:pointer;
    position:relative;overflow:hidden;border:1px solid var(--hairline)}
  .audioplayer__fill{position:absolute;left:0;top:0;bottom:0;width:0;background:var(--wood);border-radius:999px}
  .audioplayer__note{text-align:center;margin:.9rem auto 0;max-width:520px}

  @media(prefers-reduced-motion:reduce){
    .flip__inner{transition:none}
  }
</style>

<script>
  /* Profilkarte: Foto umdrehen */
  const flip = document.getElementById('flip')!;
  function toggleFlip() {
    const flipped = flip.getAttribute('aria-pressed') === 'true';
    flip.setAttribute('aria-pressed', flipped ? 'false' : 'true');
  }
  flip.addEventListener('click', toggleFlip);
  flip.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleFlip(); }
  });

  /* Ziele zählen hoch, wenn sie ins Bild kommen */
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fmt = new Intl.NumberFormat('de-DE');
  document.querySelectorAll<HTMLElement>('.stat__n[data-count]').forEach((el) => {
    const target = parseInt(el.dataset.count!, 10);
    const render = (v: number) => { el.textContent = fmt.format(v); };
    if (reduced) { render(target); return; }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) { return; }
        io.unobserve(el);
        const t0 = performance.now();
        const dur = 1500;
        const tick = (t: number) => {
          const p = Math.min((t - t0) / dur, 1);
          render(Math.round(target * (1 - Math.pow(1 - p, 3))));
          if (p < 1) { requestAnimationFrame(tick); }
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: .5 });
    io.observe(el);
  });

  /* Audio-Player der Gründungsgeschichte */
  const ap = document.querySelector<HTMLElement>('.audioplayer');
  if (ap) {
    const audio = ap.querySelector('audio')!;
    const btn = ap.querySelector<HTMLButtonElement>('.audioplayer__btn')!;
    const iPlay = ap.querySelector<HTMLElement>('.audioplayer__i-play')!;
    const iPause = ap.querySelector<HTMLElement>('.audioplayer__i-pause')!;
    const fill = ap.querySelector<HTMLElement>('.audioplayer__fill')!;
    const curEl = ap.querySelector<HTMLElement>('.audioplayer__cur')!;
    const durEl = ap.querySelector<HTMLElement>('.audioplayer__dur')!;
    const bar = ap.querySelector<HTMLElement>('.audioplayer__bar')!;
    const fmtT = (s: number) => {
      if (!isFinite(s)) { return '–:––'; }
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ':' + String(sec).padStart(2, '0');
    };
    btn.addEventListener('click', () => { if (audio.paused) { audio.play(); } else { audio.pause(); } });
    audio.addEventListener('play', () => { iPlay.hidden = true; iPause.hidden = false; btn.setAttribute('aria-label', 'Gründungsgeschichte pausieren'); });
    audio.addEventListener('pause', () => { iPlay.hidden = false; iPause.hidden = true; btn.setAttribute('aria-label', 'Gründungsgeschichte abspielen'); });
    audio.addEventListener('loadedmetadata', () => { durEl.textContent = fmtT(audio.duration); });
    if (audio.readyState >= 1) { durEl.textContent = fmtT(audio.duration); }
    audio.addEventListener('timeupdate', () => {
      const p = audio.duration ? audio.currentTime / audio.duration : 0;
      fill.style.width = (p * 100) + '%';
      curEl.textContent = fmtT(audio.currentTime);
    });
    audio.addEventListener('ended', () => { fill.style.width = '0%'; curEl.textContent = '0:00'; });
    bar.addEventListener('click', (e) => {
      if (!isFinite(audio.duration)) { return; }
      const r = bar.getBoundingClientRect();
      const p = Math.min(Math.max((e.clientX - r.left) / r.width, 0), 1);
      audio.currentTime = p * audio.duration;
    });
  }
</script>

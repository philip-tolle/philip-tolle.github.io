---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Kompass from '../components/Kompass.astro';
import Startkarte from '../components/Startkarte.astro';
import logo from '../assets/nc-logo.png';
import bannerOperation from '../assets/banner-operation.png';

const uebernehmen = [
  { id: 'backoffice', icon: 'vorlage', titel: 'Backoffice & Unterlagen', items: [
    { icon: 'karte', text: 'Tages- & Menükarten' },
    { icon: 'mappe', text: 'Gästemappen & Infomaterial' },
    { icon: 'vorlage', text: 'Vorlagen & Templates' },
    { icon: 'analyse', text: 'Präsentationen, Listen & Analysen' },
  ] },
  { id: 'digital', icon: 'senden', titel: 'Kommunikation & Marketing', items: [
    { icon: 'tablet', text: 'Digitale Gästemappen' },
    { icon: 'senden', text: 'Newsletter & Social Media' },
    { icon: 'globus', text: 'Website & Online-Kanäle' },
    { icon: 'bewertung', text: 'Gästefeedback & Bewertungen' },
  ] },
  { id: 'projekte', icon: 'fest', titel: 'Projekte & Events', items: [
    { icon: 'fest', text: 'Team-Events & Feste' },
    { icon: 'handbuch', text: 'Leitfäden & Betriebshandbücher' },
    { icon: 'geschenk', text: 'Gastgeschenke & Aufmerksamkeiten' },
    { icon: 'ziel', text: 'Saisonaktionen & Kampagnen' },
  ] },
];

const stationen = [
  { num: '01', icon: 'zeit', title: 'Der 30-Tage-Test', pname: 'Operation Sprint', text: 'Ein Monat, fester Umfang — danach entscheiden Sie.', href: '/kontakt/', link: 'Test anfragen' },
  { num: '02', icon: 'kreislauf', title: 'Ihr Monatspaket', text: 'Wiederkehrendes, Monat für Monat erledigt.', id: 'desks', offers: [
    { title: 'Karten & Bankettunterlagen', pname: 'F&B Desk', text: 'Karten, Tischpläne, Aufsteller — pünktlich fertig.', href: '/kontakt/' },
    { title: 'Social Media, verlässlich bespielt', pname: 'Content Desk', text: 'Beiträge & Stories — geplant, gestaltet, veröffentlicht.', href: '/kontakt/' },
  ] },
  { num: '03', icon: 'gastlichkeit', title: 'Die volle Fachabteilung', pname: 'Operation Partner', text: 'Beide Pakete plus Projektstunden und Saisonplanung.', href: '/kontakt/', link: 'Partner besprechen' },
  { num: '04', icon: 'ziel', title: 'Feste, Geschenke & Mappen', text: 'Projekte mit Anfang, Ende und Festpreis.', href: '/kontakt/', link: 'Projekt besprechen' },
];
---
<Base
  title="Operation — NextCourse"
  description="NextCourse Operation entlastet Ihre Mitarbeiter: repetitive Aufgaben & Backoffice, digitale Gästekommunikation & Marketing, einmalige Projekte ohne eigene Abteilung — zuverlässig und gewissenhaft zum Festpreis. Für Hotels und Gastgeber in Mainfranken."
  accent="amber"
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerOperation} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Operation</p>
      <h1>Entlastung mit Wert.</h1>
      <p class="lead">NextCourse Operation entlastet Ihre Mitarbeiter und erledigt Aufgaben und Projekte, für die im Geschäftsalltag niemand Zeit hat — zuverlässig &amp; gewissenhaft zum Festpreis.</p>
    </div>
  </div>

  <!-- Das übernehmen wir: drei Bereiche mit Beispielen -->
  <div class="floor--auto floor" style="padding-top:clamp(3.5rem,7vw,5.5rem);padding-bottom:clamp(5rem,10vw,8rem)">
    <div class="wrap" style="max-width:1060px">
      <h2 class="sr-only">Das übernehmen wir</h2>
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">Das übernehmen wir</p>
      <Kompass bereiche={uebernehmen} />
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:clamp(4rem,8vw,6rem)">
    <div class="wrap">
      <div class="menuhead">
        <h2 class="sr-only">So entlasten wir</h2>
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">So entlasten wir</p>
        <p class="lead reveal">Sie steigen dort ein, wo es Ihrem Haus hilft.</p>
      </div>

      <!-- Startpunkt: Erstgespräch, mittig und kompakt — hier beginnt die Linie -->
      <Startkarte frage="Was bleibt bei Ihnen liegen?" />

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {stationen.map((s) => (
          <div class="station">
            <span class="station__num" aria-hidden="true">{s.num}</span>
            {s.offers ? (
              <>
                <button type="button" class="offercard station__card deckblatt reveal" aria-expanded="false" aria-controls={`off-${s.id}`}>
                  <Icon name={s.icon} size={38} class="station__icon" />
                  <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                  <p>{s.text}</p>
                  {s.wenn && <p class="wenn">{s.wenn}</p>}
                  <span class="deckblatt__toggle">Pakete ansehen
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </button>
                <div class="deckoffers" id={`off-${s.id}`} hidden>
                  {s.offers.map((o) => (
                    <a class="deckoffer" href={o.href}>
                      <h4>{o.title}{o.pname && <span class="pname">{o.pname}</span>}</h4>
                      <p>{o.text}</p>
                      {o.wenn && <p class="wenn">{o.wenn}</p>}
                      <span class="forkcard__go">Mehr erfahren</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a class="offercard station__card deckblatt reveal" href={s.href}>
                <Icon name={s.icon} size={38} class="station__icon" />
                <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                <p>{s.text}</p>
                {s.wenn && <p class="wenn">{s.wenn}</p>}
                <span class="forkcard__go">{s.link}</span>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Claim & Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="claim reveal">Erledigt.<span class="z2">Nicht vertagt.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">Entlastung für Hotels in Mainfranken — planbar, fachlich, verlässlich.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn btn--line btn--amber">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Produktname klein unter dem Klartext-Titel */
  .pname{display:block;font-family:var(--body);font-weight:500;font-size:.68rem;
    letter-spacing:.2em;text-transform:uppercase;color:var(--faint);margin-top:.35rem}
</style>

---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import logo from '../assets/nc-logo.png';
import bannerOperation from '../assets/banner-operation.png';

const stationen = [
  { num: '01', icon: 'gespraech', title: 'Kostenloses Erstgespräch', text: '30 Minuten: Was bleibt bei Ihnen liegen — und lohnt sich Entlastung von außen? Ehrlich, ohne Verkaufsdruck.', href: '/kontakt/', link: 'Gespräch vereinbaren' },
  { num: '02', icon: 'zeit', title: 'Der 30-Tage-Test', pname: 'Operation Sprint', text: 'Ein Monat, klar begrenzter Umfang, echte Ergebnisse. Danach entscheiden Sie in Ruhe, ob mehr daraus wird.', wenn: 'Für Sie, wenn Sie uns erst mit begrenztem Risiko prüfen wollen.', href: '/kontakt/', link: 'Test anfragen' },
  { num: '03', icon: 'kreislauf', title: 'Ihr Monatspaket', text: 'Wiederkehrende Aufgaben, Monat für Monat zuverlässig erledigt — Sie wählen, was wir übernehmen.', id: 'desks', offers: [
    { title: 'Karten & Bankettunterlagen', pname: 'F&B Desk', text: 'Wochen-, Saison- und Aktionskarten, Tischpläne, Aufsteller — pünktlich, auf Ihrer Vorlage.', wenn: 'Für Sie, wenn die Wochenkarte regelmäßig um 23 Uhr entsteht.', href: '/kontakt/' },
    { title: 'Social Media, verlässlich bespielt', pname: 'Content Desk', text: 'Beiträge und Stories für Instagram und Facebook — geplant, gestaltet, veröffentlicht.', wenn: 'Für Sie, wenn der letzte Post drei Monate her ist.', href: '/kontakt/' },
  ] },
  { num: '04', icon: 'gastlichkeit', title: 'Die volle Fachabteilung', pname: 'Operation Partner', text: 'Karten, Social Media und dazu Projektstunden mit Saisonplanung — eine Fachkraft, die Sie nicht einstellen müssen.', wenn: 'Für Sie, wenn beides liegen bleibt — und die Projekte dazu.', href: '/kontakt/', link: 'Partner besprechen' },
  { num: '05', icon: 'ziel', title: 'Feste, Geschenke & Mappen', text: 'Saisonkampagne, Weihnachtsgeschenke, Mitarbeiterfest, Gäste- oder Bankettmappe — ein Projekt mit Anfang, Ende und Festpreis.', wenn: 'Für Sie, wenn ein Projekt ansteht, aber niemand Zeit hat, es zu treiben.', href: '/kontakt/', link: 'Projekt besprechen' },
];
---
<Base
  title="Operation — NextCourse"
  description="NextCourse Operation entlastet Ihre Mitarbeiter: repetitive Aufgaben & Backoffice, digitale Gästekommunikation & Marketing, einmalige Projekte ohne eigene Abteilung — zuverlässig und gewissenhaft zum Festpreis. Für Hotels und Gastgeber in Mainfranken."
  accent="amber"
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerOperation} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Operation</p>
      <h1>Entlastung mit Wert.</h1>
      <p class="lead">NextCourse Operation entlastet Ihre Mitarbeiter und erledigt Aufgaben und Projekte, für die im Geschäftsalltag niemand Zeit hat — zuverlässig &amp; gewissenhaft zum Festpreis.</p>
    </div>
  </div>

  <!-- Das übernehmen wir: drei Bereiche mit Beispielen -->
  <div class="floor--auto floor" style="padding-top:clamp(3.5rem,7vw,5.5rem);padding-bottom:clamp(2rem,4vw,3rem)">
    <div class="wrap" style="max-width:1060px">
      <h2 class="sr-only">Das übernehmen wir</h2>
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">Das übernehmen wir</p>
      <div class="komp reveal">
        <div class="komp__wahl">
          <button type="button" class="kompbtn" data-bereich="backoffice" aria-pressed="false" aria-controls="komp-panel">
            <Icon name="vorlage" size={26} /><span>Backoffice &amp; Unterlagen</span>
          </button>
          <button type="button" class="kompbtn" data-bereich="digital" aria-pressed="false" aria-controls="komp-panel">
            <Icon name="senden" size={26} /><span>Kommunikation &amp; Marketing</span>
          </button>
          <button type="button" class="kompbtn" data-bereich="projekte" aria-pressed="false" aria-controls="komp-panel">
            <Icon name="fest" size={26} /><span>Projekte &amp; Events</span>
          </button>
        </div>
        <div class="komp__panel" id="komp-panel" aria-live="polite" hidden>
          <ul data-bereich="backoffice" hidden>
            <li><Icon name="karte" size={22} /><span>Tages- &amp; Menükarten</span></li>
            <li><Icon name="mappe" size={22} /><span>Gästemappen &amp; Infomaterial</span></li>
            <li><Icon name="vorlage" size={22} /><span>Vorlagen &amp; Templates</span></li>
            <li><Icon name="analyse" size={22} /><span>Präsentationen, Listen &amp; Analysen</span></li>
          </ul>
          <ul data-bereich="digital" hidden>
            <li><Icon name="tablet" size={22} /><span>Digitale Gästemappen</span></li>
            <li><Icon name="senden" size={22} /><span>Newsletter &amp; Social Media</span></li>
            <li><Icon name="globus" size={22} /><span>Website &amp; Online-Kanäle</span></li>
            <li><Icon name="bewertung" size={22} /><span>Gästefeedback &amp; Bewertungen</span></li>
          </ul>
          <ul data-bereich="projekte" hidden>
            <li><Icon name="fest" size={22} /><span>Team-Events &amp; Feste</span></li>
            <li><Icon name="handbuch" size={22} /><span>Leitfäden &amp; Betriebshandbücher</span></li>
            <li><Icon name="geschenk" size={22} /><span>Gastgeschenke &amp; Aufmerksamkeiten</span></li>
            <li><Icon name="ziel" size={22} /><span>Saisonaktionen &amp; Kampagnen</span></li>
          </ul>
        </div>
      </div>
      <noscript><style is:inline>
        .komp__panel[hidden]{display:block !important}
        .komp__panel ul[hidden]{display:grid !important}
      </style></noscript>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:clamp(2.5rem,5vw,4rem)">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">So entlasten wir</p>
        <h2 class="reveal">Ihr nächster Kurs — vom ersten Gespräch zur externen Fachabteilung.</h2>
        <p class="lead reveal">Sie steigen dort ein, wo es Ihrem Haus hilft — vom kostenlosen Gespräch bis zur laufenden Entlastung.</p>
      </div>

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {stationen.map((s) => (
          <div class="station">
            <span class="station__num" aria-hidden="true">{s.num}</span>
            {s.offers ? (
              <>
                <button type="button" class="offercard station__card deckblatt reveal" aria-expanded="false" aria-controls={`off-${s.id}`}>
                  <Icon name={s.icon} size={38} class="station__icon" />
                  <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                  <p>{s.text}</p>
                  {s.wenn && <p class="wenn">{s.wenn}</p>}
                  <span class="deckblatt__toggle">Pakete ansehen
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </button>
                <div class="deckoffers" id={`off-${s.id}`} hidden>
                  {s.offers.map((o) => (
                    <a class="deckoffer" href={o.href}>
                      <h4>{o.title}{o.pname && <span class="pname">{o.pname}</span>}</h4>
                      <p>{o.text}</p>
                      {o.wenn && <p class="wenn">{o.wenn}</p>}
                      <span class="forkcard__go">Mehr erfahren</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a class="offercard station__card deckblatt reveal" href={s.href}>
                <Icon name={s.icon} size={38} class="station__icon" />
                <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                <p>{s.text}</p>
                {s.wenn && <p class="wenn">{s.wenn}</p>}
                <span class="forkcard__go">{s.link}</span>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Abgrenzung: Was Operation ist — und was nicht -->
  <div class="floor--auto floor">
    <div class="wrap" style="max-width:860px">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Damit wir uns richtig verstehen</p>
        <h2 class="reveal">Was Operation ist — und was nicht.</h2>
      </div>
      <div class="vsrows stagger">
        <div class="vs reveal"><span class="vs__not">Keine Social-Media-Agentur.</span><span class="vs__but">Wir kommen aus der Hotellerie — Restaurant, Bankett, Rezeption.</span></div>
        <div class="vs reveal"><span class="vs__not">Keine neue Software.</span><span class="vs__but">Sie bekommen fertige Ergebnisse, keinen Login.</span></div>
        <div class="vs reveal"><span class="vs__not">Keine zusätzliche Stelle.</span><span class="vs__but">Fachkapazität genau im Umfang, den Ihr Haus braucht.</span></div>
      </div>
    </div>
  </div>

  <!-- Claim & Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="claim reveal">Erledigt.<span class="z2">Nicht vertagt.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">Entlastung für Hotels in Mainfranken — planbar, fachlich, verlässlich.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* „Das übernehmen wir": Bereichs-Wahl + Panel (Kompass-Muster) */
  .komp{margin-top:2.2rem}
  .komp__wahl{display:grid;gap:1.1rem;margin-bottom:1.4rem}
  @media(min-width:820px){.komp__wahl{grid-template-columns:repeat(3,1fr)}}
  .kompbtn{display:flex;align-items:center;justify-content:center;gap:.85rem;
    padding:1.05rem 1rem;border-radius:16px;
    cursor:pointer;background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    font-family:var(--body);font-size:.92rem;font-weight:500;color:var(--dim);text-align:left;
    line-height:1.3;white-space:nowrap;transition:all .25s ease}
  .kompbtn :global(.ico){flex:none;color:var(--wood);transition:color .25s}
  .kompbtn:hover{transform:translateY(-2px)}
  .kompbtn:hover,.kompbtn[aria-pressed="true"]{background:rgba(var(--acc-rgb),.09);
    border-color:rgba(var(--acc-rgb),.45);color:var(--ink);
    box-shadow:0 14px 30px -18px rgba(var(--acc-rgb),.55)}
  .kompbtn:hover :global(.ico),.kompbtn[aria-pressed="true"] :global(.ico){color:var(--acc)}
  .komp__panel{background:rgba(255,255,255,.6);border:1px solid rgba(var(--acc-rgb),.22);
    border-radius:20px;padding:clamp(1.5rem,3.5vw,2.1rem);
    backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);box-shadow:var(--shadow)}
  .komp__panel ul{list-style:none;margin:0;padding:0;display:grid;gap:.9rem 2.4rem;
    animation:kompin .3s ease both}
  @media(min-width:700px){.komp__panel ul{grid-template-columns:1fr 1fr}}
  .komp__panel ul[hidden]{display:none}
  .komp__panel li{display:flex;gap:.7rem;align-items:flex-start;font-size:.95rem;
    color:var(--dim);line-height:1.55}
  .komp__panel li :global(.ico){flex:none;color:var(--wood);margin-top:.05rem}
  @keyframes kompin{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
  @media(prefers-reduced-motion:reduce){.komp__panel ul{animation:none}}
</style>

<script>
  /* „Das übernehmen wir": Bereichs-Wahl öffnet das Panel; erneuter Klick schließt */
  const kompBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.kompbtn'));
  const kompLists = Array.from(document.querySelectorAll<HTMLElement>('.komp__panel ul[data-bereich]'));
  const kompPanel = document.getElementById('komp-panel');
  kompBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const schliessen = btn.getAttribute('aria-pressed') === 'true';
      kompBtns.forEach((b) => b.setAttribute('aria-pressed', !schliessen && b === btn ? 'true' : 'false'));
      if (kompPanel) { kompPanel.hidden = schliessen; }
      kompLists.forEach((ul) => { ul.hidden = schliessen || ul.dataset.bereich !== btn.dataset.bereich; });
    });
  });
</script>

<style>

  /* Produktname klein unter dem Klartext-Titel */
  .pname{display:block;font-family:var(--body);font-weight:500;font-size:.68rem;
    letter-spacing:.2em;text-transform:uppercase;color:var(--faint);margin-top:.35rem}

  /* „Für Sie, wenn …"-Anker */
  .wenn{font-family:var(--serif);font-style:italic;font-size:1.05rem;color:var(--wood);
    margin:.65rem 0 0}

  /* Abgrenzungszeilen: „Keine X. Sondern Y." */
  .vsrows{display:flex;flex-direction:column;margin:1.6rem auto 0}
  .vs{display:grid;gap:.15rem 2rem;padding:1.15rem .2rem;border-bottom:1px solid var(--line)}
  .vs:first-child{border-top:1px solid var(--line)}
  @media(min-width:700px){.vs{grid-template-columns:1fr 1.5fr;align-items:baseline}}
  .vs__not{font-family:var(--serif);font-style:italic;font-size:1.25rem;color:var(--faint)}
  .vs__but{color:var(--dim);line-height:1.6}
</style>

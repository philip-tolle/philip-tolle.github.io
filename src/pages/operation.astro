---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import logo from '../assets/nc-logo.png';

const stationen = [
  { num: '01', icon: 'gespraech', title: 'Kostenloses Erstgespräch', text: '30 Minuten: Was bleibt bei Ihnen liegen — und lohnt sich Entlastung von außen? Ehrlich, ohne Verkaufsdruck.', href: '/kontakt/', link: 'Gespräch vereinbaren' },
  { num: '02', icon: 'zeit', title: 'Der 30-Tage-Test', pname: 'Operation Sprint', text: 'Ein Monat, klar begrenzter Umfang, echte Ergebnisse. Danach entscheiden Sie in Ruhe, ob mehr daraus wird.', wenn: 'Für Sie, wenn Sie uns erst mit begrenztem Risiko prüfen wollen.', href: '/kontakt/', link: 'Test anfragen' },
  { num: '03', icon: 'kreislauf', title: 'Ihr Monatspaket', text: 'Wiederkehrende Aufgaben, Monat für Monat zuverlässig erledigt — Sie wählen, was wir übernehmen.', id: 'desks', offers: [
    { title: 'Karten & Bankettunterlagen', pname: 'F&B Desk', text: 'Wochen-, Saison- und Aktionskarten, Tischpläne, Aufsteller — pünktlich, auf Ihrer Vorlage.', wenn: 'Für Sie, wenn die Wochenkarte regelmäßig um 23 Uhr entsteht.', href: '/kontakt/' },
    { title: 'Social Media, verlässlich bespielt', pname: 'Content Desk', text: 'Beiträge und Stories für Instagram und Facebook — geplant, gestaltet, veröffentlicht.', wenn: 'Für Sie, wenn der letzte Post drei Monate her ist.', href: '/kontakt/' },
  ] },
  { num: '04', icon: 'gastlichkeit', title: 'Die volle Fachabteilung', pname: 'Operation Partner', text: 'Karten, Social Media und dazu Projektstunden mit Saisonplanung — eine Fachkraft, die Sie nicht einstellen müssen.', wenn: 'Für Sie, wenn beides liegen bleibt — und die Projekte dazu.', href: '/kontakt/', link: 'Partner besprechen' },
  { num: '05', icon: 'ziel', title: 'Feste, Geschenke & Mappen', text: 'Saisonkampagne, Weihnachtsgeschenke, Mitarbeiterfest, Gäste- oder Bankettmappe — ein Projekt mit Anfang, Ende und Festpreis.', wenn: 'Für Sie, wenn ein Projekt ansteht, aber niemand Zeit hat, es zu treiben.', href: '/kontakt/', link: 'Projekt besprechen' },
];
---
<Base
  title="Operation — NextCourse"
  description="NextCourse Operation übernimmt, was im Hotelalltag liegen bleibt: Speise- und Bankettkarten, Social Media, Feste, Geschenke und Mappen — für inhabergeführte Hotels in Mainfranken, zuverlässig zum festen Monatspreis."
  accent="amber"
>
  <div class="pagehead">
    <span class="ghostglyph" aria-hidden="true">&amp;</span>
    <div class="wrap">
      <p class="eyebrow">NextCourse Operation</p>
      <h1>Wir übernehmen, was liegen bleibt.</h1>
      <p class="lead">Speisekarten, Social Media, Bankettunterlagen, Feste: NextCourse Operation erledigt die Aufgaben, für die im Hotelalltag niemand Zeit hat — zuverlässig, zum festen Monatspreis.</p>
    </div>
  </div>

  <!-- Das übernehmen wir: Sofort-Überblick -->
  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:1020px">
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Das übernehmen wir</p>
      <div class="trio reveal">
        <div class="trio__cell"><span class="trio__big">Speise- &amp; Bankettkarten</span><span class="trio__sub">von der Wochenkarte bis zum Tischplan</span></div>
        <div class="trio__cell"><span class="trio__big">Instagram &amp; Facebook</span><span class="trio__sub">geplant, gestaltet, veröffentlicht</span></div>
        <div class="trio__cell"><span class="trio__big">Feste, Geschenke &amp; Mappen</span><span class="trio__sub">Projekte mit Anfang, Ende und Festpreis</span></div>
      </div>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:clamp(2.5rem,5vw,4rem)">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">So entlasten wir</p>
        <h2 class="reveal">Ihr nächster Kurs — vom ersten Gespräch zur externen Fachabteilung.</h2>
        <p class="lead reveal">Sie steigen dort ein, wo es Ihrem Haus hilft — vom kostenlosen Gespräch bis zur laufenden Entlastung.</p>
      </div>

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {stationen.map((s) => (
          <div class="station">
            <span class="station__num" aria-hidden="true">{s.num}</span>
            {s.offers ? (
              <>
                <button type="button" class="offercard station__card deckblatt reveal" aria-expanded="false" aria-controls={`off-${s.id}`}>
                  <Icon name={s.icon} size={38} class="station__icon" />
                  <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                  <p>{s.text}</p>
                  {s.wenn && <p class="wenn">{s.wenn}</p>}
                  <span class="deckblatt__toggle">Pakete ansehen
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </button>
                <div class="deckoffers" id={`off-${s.id}`} hidden>
                  {s.offers.map((o) => (
                    <a class="deckoffer" href={o.href}>
                      <h4>{o.title}{o.pname && <span class="pname">{o.pname}</span>}</h4>
                      <p>{o.text}</p>
                      {o.wenn && <p class="wenn">{o.wenn}</p>}
                      <span class="forkcard__go">Mehr erfahren</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a class="offercard station__card deckblatt reveal" href={s.href}>
                <Icon name={s.icon} size={38} class="station__icon" />
                <h3>{s.title}{s.pname && <span class="pname">{s.pname}</span>}</h3>
                <p>{s.text}</p>
                {s.wenn && <p class="wenn">{s.wenn}</p>}
                <span class="forkcard__go">{s.link}</span>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Abgrenzung: Was Operation ist — und was nicht -->
  <div class="floor--auto floor">
    <div class="wrap" style="max-width:860px">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Damit wir uns richtig verstehen</p>
        <h2 class="reveal">Was Operation ist — und was nicht.</h2>
      </div>
      <div class="vsrows stagger">
        <div class="vs reveal"><span class="vs__not">Keine Social-Media-Agentur.</span><span class="vs__but">Wir kommen aus der Hotellerie — Restaurant, Bankett, Rezeption.</span></div>
        <div class="vs reveal"><span class="vs__not">Keine neue Software.</span><span class="vs__but">Sie bekommen fertige Ergebnisse, keinen Login.</span></div>
        <div class="vs reveal"><span class="vs__not">Keine zusätzliche Stelle.</span><span class="vs__but">Fachkapazität genau im Umfang, den Ihr Haus braucht.</span></div>
      </div>
    </div>
  </div>

  <!-- Claim & Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <span class="ornament__dot"></span>
      </div>
      <p class="claim reveal">Erledigt.<span class="z2">Nicht vertagt.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">Entlastung für Hotels in Mainfranken — planbar, fachlich, verlässlich.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Produktname klein unter dem Klartext-Titel */
  .pname{display:block;font-family:var(--body);font-weight:500;font-size:.68rem;
    letter-spacing:.2em;text-transform:uppercase;color:var(--faint);margin-top:.35rem}

  /* „Für Sie, wenn …"-Anker */
  .wenn{font-family:var(--serif);font-style:italic;font-size:1.05rem;color:var(--wood);
    margin:.65rem 0 0}

  /* Abgrenzungszeilen: „Keine X. Sondern Y." */
  .vsrows{display:flex;flex-direction:column;margin:1.6rem auto 0}
  .vs{display:grid;gap:.15rem 2rem;padding:1.15rem .2rem;border-bottom:1px solid var(--line)}
  .vs:first-child{border-top:1px solid var(--line)}
  @media(min-width:700px){.vs{grid-template-columns:1fr 1.5fr;align-items:baseline}}
  .vs__not{font-family:var(--serif);font-style:italic;font-size:1.25rem;color:var(--faint)}
  .vs__but{color:var(--dim);line-height:1.6}
</style>

---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const kurse = await getCollection('kurse');
  return kurse.map((kurs) => ({ params: { id: kurs.id }, props: { kurs } }));
}

const { kurs } = Astro.props;
const { Content } = await render(kurs);
const d = kurs.data;

const courseSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: d.title,
  description: d.kurz,
  provider: { '@type': 'Organization', name: 'NextCourse', sameAs: 'https://philip-tolle.github.io/' },
  availableLanguage: 'de',
});
---
<Base title={`${d.title} — NextCourse Akademie`} description={d.kurz} accent="blue">
  <script type="application/ld+json" set:html={courseSchema} slot="head" />
  <div class="pagehead" style="min-height:42svh">
    <div class="wrap">
      <p class="eyebrow">Academy · {d.kategorie}</p>
      <h1>{d.title}</h1>
      <p class="lead" style="font-family:var(--serif);font-style:italic;font-size:clamp(1.15rem,2.6vw,1.4rem)">„{d.botschaft}“</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:960px">

      <div class="trio reveal">
        {d.trio.map((t) => (
          <div class="trio__cell"><span class="trio__big">{t.wert}</span><span class="trio__sub">{t.label}</span></div>
        ))}
      </div>

      <div class="offer" style="margin-top:3.5rem">
        <div>
          <h2 class="reveal" style="margin-top:0">Worum es geht</h2>
          <div class="prose reveal" style="max-width:none;margin:0">
            <Content />
          </div>

          <h2 class="reveal">Die Module</h2>
          <ol class="tl reveal stagger">
            {d.module.map((m, i) => (
              <li>
                <h3><span class="tl__num">{String(i + 1).padStart(2, '0')}</span>{m.titel}</h3>
                <p>{m.text}</p>
              </li>
            ))}
          </ol>

          <h2 class="reveal">Was Sie mitnehmen</h2>
          <ul class="quali reveal stagger">
            {d.ergebnisse.map((e) => <li>{e}</li>)}
          </ul>

          <p class="voice reveal" style="margin-top:2.6rem">{d.zielgruppe}</p>
          <a class="arrowlink reveal" href="/akademie/">Alle Kurse der Akademie</a>
        </div>

        <aside class="offer__aside reveal">
          <div class="bill" style="margin:0">
            <p class="bill__head">Auf einen Blick</p>
            <div class="bl"><b>Dauer</b><span class="dots"></span><span>{d.dauer}</span></div>
            <div class="bl"><b>Format</b><span class="dots"></span><span style="text-align:right">{d.format}</span></div>
            <div class="bl"><b>Förderung</b><span class="dots"></span><span style="text-align:right">{d.foerderung}</span></div>
            <p class="bill__head" style="margin-top:1.6rem;border-top:1px solid var(--line);padding-top:1.4rem">Termine</p>
            {d.termine.length > 0 ? d.termine.map((t) => (
              <div class="bl"><b>{t.label}</b>{t.hinweis && <><span class="dots"></span><span style="text-align:right;white-space:normal">{t.hinweis}</span></>}</div>
            )) : (
              <div class="bl"><b>Termine auf Anfrage</b></div>
            )}
            <div class="btnrow" style="justify-content:center;margin-top:1.6rem">
              <a href="/kontakt/" class="btn">{d.status === 'geplant' ? 'Auf die Interessentenliste' : 'Platz anfragen'}</a>
            </div>
            {d.status === 'geplant' && (
              <p class="bill__fine">Unverbindlich — Sie erfahren als Erstes vom Start.</p>
            )}
            {d.status === 'buchbar' && (
              <p class="bill__fine">Oder direkt: <a href="https://cal.com/philip-tolle-yxp7ih/erstgesprach" target="_blank" rel="noopener" style="color:var(--green)">Erstgespräch buchen</a></p>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Trio-Blaupause liegt in global.css — hier nur der Akademie-Akzent */
  .trio__big{color:var(--blue)}
  .bl b{white-space:normal}
</style>

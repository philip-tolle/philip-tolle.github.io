---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import BlogCover from '../components/BlogCover.astro';
import logo from '../assets/nc-logo.png';
import philip from '../assets/philip.png';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const marquee = posts.length >= 3;
const bandItems = marquee ? [...posts, ...posts] : posts;
---
<Base
  title="NextCourse — Bildungs-, Beratungs- und Umsetzungspartner für das Gastgewerbe"
  description="NextCourse ist der Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung und Digitalisierung für Betriebe, Kurse und Weiterbildung in der Akademie — aus Würzburg, im Einsatz in Mainfranken."
>
  <meta slot="head" name="theme-color" content="#F7F4EF" data-home-theme-color>
  <script is:inline slot="head">
    (() => {
      const root = document.documentElement;
      const storageKey = 'nextcourse-home-theme';
      let stored = null;
      try {
        stored = localStorage.getItem(storageKey);
      } catch {
        // Die Systemeinstellung bleibt der sichere Fallback.
      }
      const theme = stored === 'dark' || stored === 'light'
        ? stored
        : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      root.classList.add('home-theme');
      root.dataset.homeTheme = theme;
      root.style.colorScheme = theme;
      document.querySelector('meta[data-home-theme-color]')
        ?.setAttribute('content', theme === 'dark' ? '#08121F' : '#F7F4EF');
    })();
  </script>

  <!-- FLOOR 1: Das Logo als Bühne -->
  <div class="floor hero">
    <div class="wrap" style="text-align:center">
      <div class="heroLogo" id="heroLogo" role="button" tabindex="0"
        aria-label="Zur Auswahl: Consulting, Academy oder Operation">
        <Image src={logo} alt="NextCourse Logo — Wellen und Pfeil aus warmem Holz, hinterleuchtet"
          width={1080} format="webp" quality={82} loading="eager" />
      </div>
      <h1 class="heroWord">NextCourse<span class="sr-only"> — Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe</span></h1>
      <p class="heroSub">Der Bildungs-, Beratungs- und Umsetzungspartner<br>für das deutsche Gastgewerbe.</p>
      <a class="scrollhint" href="#wahl" aria-label="Weiter zur Auswahl der drei Bereiche">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 2: Drei klar getrennte Wege -->
  <section class="floor wege-section" id="wahl" aria-labelledby="wege-heading">
    <div class="wege-panel">
      <div class="wege-panel__inner">
        <div class="wege-intro reveal">
          <p class="wege-kicker">Drei Wege</p>
          <h2 class="wege-title" id="wege-heading">
            <span>Ein Partner.</span>
            <span>Drei Formen der</span>
            <span>Entlastung.</span>
          </h2>
          <p class="wege-copy">Was führt Sie zu uns? Wählen Sie den Weg, der zu Ihrer aktuellen Aufgabe passt.</p>
        </div>

        <nav class="wege-nav" aria-label="Leistungsbereiche">
          <ol class="wege-list">
            <li class="wege-item reveal" style="--wege-delay:.04s">
              <a class="wege-link" href="/consulting/">
                <span class="wege-link__number" aria-hidden="true">01</span>
                <span class="wege-link__body">
                  <span class="wege-link__title">Consulting</span>
                  <span class="wege-link__claim">Beratung, die ankommt.</span>
                  <span class="wege-link__audience">Für Betriebe, die Lösungen suchen</span>
                </span>
                <span class="wege-link__arrow" aria-hidden="true">↗</span>
              </a>
            </li>
            <li class="wege-item reveal" style="--wege-delay:.10s">
              <a class="wege-link" href="/akademie/">
                <span class="wege-link__number" aria-hidden="true">02</span>
                <span class="wege-link__body">
                  <span class="wege-link__title">Academy</span>
                  <span class="wege-link__claim">Weiterbildung, die wirkt.</span>
                  <span class="wege-link__audience">Für alle, die weiterkommen wollen</span>
                </span>
                <span class="wege-link__arrow" aria-hidden="true">↗</span>
              </a>
            </li>
            <li class="wege-item reveal" style="--wege-delay:.16s">
              <a class="wege-link" href="/operation/">
                <span class="wege-link__number" aria-hidden="true">03</span>
                <span class="wege-link__body">
                  <span class="wege-link__title">Operation</span>
                  <span class="wege-link__claim">Entlastung mit Wert.</span>
                  <span class="wege-link__audience">Für Häuser mit mehr Aufgaben als Zeit</span>
                </span>
                <span class="wege-link__arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          </ol>
        </nav>
      </div>

      <a class="scrollhint wege-scrollhint" href="#idee" aria-label="Weiter zur Idee hinter NextCourse">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <!-- FLOOR 3: Die Idee hinter NextCourse — ein Bildschirm -->
  <div class="floor" id="idee" style="padding:5rem 0 1.6rem">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Die Idee hinter NextCourse</p>
        <h2 class="reveal" style="font-size:clamp(1.8rem,4.2vw,2.7rem)">Kein Wissensproblem. Ein Zeitproblem.</h2>
      </div>

      <div class="idee2">
        <div class="idee2col reveal">
          <p class="eyebrow eyebrow--c" style="--acc:var(--amber)">Das Problem</p>
          <div class="idee2__viz">
          <div class="forces__stage" id="forces">
            <svg viewBox="0 0 520 320" preserveAspectRatio="none" aria-hidden="true">
              <path d="M256,31 C304,31 312,98 354,138"/>
              <path d="M256,111 C304,111 314,142 352,154"/>
              <path d="M256,191 C304,191 314,178 352,166"/>
              <path d="M256,271 C304,271 312,222 354,182"/>
            </svg>
            <div class="forces__pill" data-f="0" style="top:0">
              <span>Margendruck</span><b>sechs Verlustjahre in Folge</b>
            </div>
            <div class="forces__pill" data-f="1" style="top:80px">
              <span>Qualifikationsdefizit</span><b>KI-Wissen fehlt im Alltag</b>
            </div>
            <div class="forces__pill" data-f="2" style="top:160px">
              <span>Digitalisierungsrückstand</span><b>≈ 70 % analoge Prozesse</b>
            </div>
            <div class="forces__pill" data-f="3" style="top:240px">
              <span>Bürokratische Hürden</span><b>EU AI Act, DSGVO &amp; Co.</b>
            </div>
            <div class="zeitmuenze">
              <span>Es kostet vor allem</span>
              <b>Zeit</b>
              <span>die im Betrieb fehlt</span>
            </div>
          </div>
          </div>
        </div>
        <span class="idee2__div" aria-hidden="true"></span>
        <div class="idee2col reveal">
          <p class="eyebrow eyebrow--c" style="--acc:var(--green)">Unsere Antwort</p>
          <div class="idee2__viz">
          <div class="deck" id="deck">
        <div class="deckcard" data-pos="0" style="--dacc:var(--blue)">
          <span class="deckcard__ico" aria-hidden="true"><Icon name="ausbildung" size={30} /></span>
          <h3>Academy</h3>
          <p class="deckcard__verb">Lernen</p>
          <p class="deckcard__antwort">Weil Technik nur hilft, wenn Menschen sie verstehen. Wissen im Team macht unabhängig — und spart vom ersten Tag an Zeit.</p>
        </div>
        <div class="deckcard" data-pos="1" style="--dacc:var(--green)">
          <span class="deckcard__ico" aria-hidden="true"><Icon name="ziel" size={30} /></span>
          <h3>Consulting</h3>
          <p class="deckcard__verb">Umsetzen</p>
          <p class="deckcard__antwort">Weil gute Systeme kein Zufall sind. Erst der ehrliche Blick, dann die messbare Umsetzung — Schritt für Schritt statt Großprojekt.</p>
        </div>
        <div class="deckcard" data-pos="2" style="--dacc:var(--amber)">
          <span class="deckcard__ico" aria-hidden="true"><Icon name="gastlichkeit" size={30} /></span>
          <h3>Operation</h3>
          <p class="deckcard__verb">Abgeben</p>
          <p class="deckcard__antwort">Weil manche Aufgaben gar nicht erst bei Ihnen landen müssen. Abgeben schafft sofort Luft — ohne eine neue Stelle zu besetzen.</p>
        </div>
          </div>
          <div class="deck__dots" aria-label="Bereich wählen">
            <button class="deck__dot is-on" data-i="0" style="--dc:var(--blue)" aria-label="Academy zeigen"></button>
            <button class="deck__dot" data-i="1" style="--dc:var(--green)" aria-label="Consulting zeigen"></button>
            <button class="deck__dot" data-i="2" style="--dc:var(--amber)" aria-label="Operation zeigen"></button>
          </div>
          </div>
        </div>
      </div>
      <a class="scrollhint" href="#blog" style="margin-top:.6rem" aria-label="Weiter zu den neuesten Blog-Artikeln">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 3b: Aus dem Blog — Band mit den 3 neuesten Artikeln -->
  <div class="floor--auto floor" id="blog">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Aus dem Blog</p>
        <h2 class="reveal">Frisch aus der Praxis.</h2>
        <p class="lead reveal">KI, Digitalisierung und Weiterbildung fürs Gastgewerbe — praxisnah statt paragraphenlastig.</p>
      </div>

      {posts.length > 0 ? (
        <div class:list={['blogband reveal', marquee ? 'blogband--marquee' : 'blogband--static']}>
          <div class="blogband__track">
            {bandItems.map((post, i) => (
              <a
                class="bandcard"
                href={`/blog/${post.id}/`}
                aria-hidden={marquee && i >= posts.length ? 'true' : undefined}
                tabindex={marquee && i >= posts.length ? -1 : undefined}
              >
                <span class="bandcard__cover cover-frame"><BlogCover post={post} width={420} /></span>
                <span class="bandcard__body">
                  <time class="bandcard__date" datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
                  <span class="bandcard__title">{post.data.title}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <p class="dim reveal" style="text-align:center;margin-top:2rem">Die ersten Artikel erscheinen in Kürze.</p>
      )}

      <div class="reveal" style="text-align:center;margin-top:2rem">
        <a class="arrowlink" href="/blog/">Alle Artikel im Blog</a>
      </div>
      <a class="scrollhint" href="#aktuelles" aria-label="Weiter zu Neuigkeiten und Angeboten">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 3c: Neuigkeiten & Angebote -->
  <div class="floor--auto floor" id="aktuelles">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Neuigkeiten &amp; Angebote</p>
        <h2 class="reveal">Was gerade bei uns läuft.</h2>
      </div>
      <div class="news reveal stagger">
        <a class="offercard newscard newscard--neu" href="/consulting/implementierungsprojekte/">
          <span class="newscard__kick newscard__kick--neu">Neu</span>
          <h3>KI-Bausteine zum Festpreis</h3>
          <p>Implementierungsprojekte — vom Telefonassistenten bis zum CorporateLLM — jetzt als eigene Übersicht.</p>
          <span class="forkcard__go">Projekte ansehen</span>
        </a>
        <a class="offercard newscard newscard--termin" href="/kontakt/">
          <span class="newscard__kick newscard__kick--termin">Termin</span>
          <h3>KI-Praxisstart: das erste Seminar</h3>
          <p>Unser erstes KI-Seminar fürs Gastgewerbe. Die Plätze sind begrenzt.</p>
          <span class="newscard__hl">3. August 2026</span>
          <span class="forkcard__go">Platz anfragen</span>
        </a>
        <a class="offercard newscard newscard--angebot" href="/consulting/mystery-check/">
          <span class="newscard__kick newscard__kick--angebot">Angebot</span>
          <h3>Mystery Check zum Pilotpreis</h3>
          <p>Ihren Betrieb mit den Augen der Gäste sehen — als Einstieg ins Consulting.</p>
          <span class="newscard__hl">950 €<s>1.490 €</s></span>
          <span class="forkcard__go">Mehr zum Mystery Check</span>
        </a>
      </div>
    </div>
  </div>

  <!-- FLOOR 4: Abschluss -->
  <div class="floor" id="abschluss">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="coin reveal" data-tilt style="--coin:160px;margin:0 auto 1.8rem">
        <Image src={philip} alt="Philip Tolle, Gründer von NextCourse" width={380} format="webp" quality={82} />
      </div>
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Der nächste Schritt</p>
      <h2 class="reveal" style="max-width:none">Sprechen wir über Ihren Betrieb.</h2>
      <p class="voice reveal" style="max-width:29em;margin:1.2rem auto 0">Ein Gespräch, kein Verkaufstermin. Erzählen Sie, wo es klemmt — ich höre zu und sage Ihnen ehrlich, ob und wie wir helfen können.</p>
      <ul class="assure reveal" aria-label="Was Sie erwartet">
        <li>Kostenlos &amp; unverbindlich</li>
        <li>Am Telefon oder bei Ihnen im Haus</li>
        <li>Für Mainfranken &amp; Bayern</li>
      </ul>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn btn--line btn--amber">Kostenloses Erstgespräch</a>
        <a href="https://cal.com/philip-tolle-yxp7ih/erstgesprach" target="_blank" rel="noopener" class="btn btn--line">Direkt Termin buchen</a>
      </div>
      <p class="reveal small faint" style="margin-top:1.7rem;font-style:italic;font-family:var(--serif);font-size:1.05rem">— Philip Tolle, Gründer von NextCourse</p>
    </div>
  </div>

</Base>

<style>
  /* Drei Wege: eigenständige Editorial-Fläche, ohne Einfluss auf den Rest der Seite */
  .wege-section{
    --wege-edge:.75rem;
    --wege-outer:#F7F4EF;
    --wege-panel:#EFEAE2;
    --wege-text:#26221B;
    --wege-claim:#5C564B;
    --wege-muted:#807669;
    --wege-accent:#3F5E7E;
    --wege-line:rgba(63,94,126,.2);
    --wege-hover:rgba(63,94,126,.045);
    min-height:0;
    align-items:stretch;
    padding:4rem 0 1.5rem;
    background:var(--wege-outer);
    overflow:clip;
  }
  :global(html.home-theme[data-home-theme="dark"]) .wege-section{
    --wege-outer:#061522;
    --wege-panel:#0D2232;
    --wege-text:#F3F7FA;
    --wege-claim:#D1DAE1;
    --wege-muted:#93A7B5;
    --wege-accent:#82B9DB;
    --wege-line:rgba(130,185,219,.18);
    --wege-hover:rgba(130,185,219,.05);
  }
  .wege-panel{
    position:relative;
    width:calc(100% - var(--wege-edge));
    min-height:0;
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding:3.75rem 0 3.4rem;
    color:var(--wege-text);
    background:var(--wege-panel);
  }
  .wege-panel__inner{
    display:grid;
    gap:2.75rem;
    width:100%;
    padding:0 1.25rem;
  }
  .wege-intro{max-width:42rem}
  .wege-kicker{
    margin:0 0 1.65rem;
    color:var(--wege-accent);
    font-family:var(--body);
    font-size:.72rem;
    font-weight:500;
    line-height:1.4;
    letter-spacing:.32em;
    text-transform:uppercase;
  }
  .wege-panel .wege-title{
    max-width:none;
    margin:0;
    color:var(--wege-text);
    font-family:var(--disp);
    font-size:clamp(2.35rem,10.6vw,3rem);
    font-weight:400;
    line-height:1.04;
    letter-spacing:-.018em;
  }
  .wege-title span{display:block}
  .wege-title span:nth-child(2){white-space:nowrap}
  .wege-copy{
    max-width:31ch;
    margin:1.8rem 0 0;
    color:var(--wege-claim);
    font-size:1rem;
    line-height:1.65;
  }
  .wege-nav{min-width:0}
  .wege-list{
    position:relative;
    margin:0;
    padding:0;
    list-style:none;
  }
  .wege-list::before,
  .wege-item::after{
    content:"";
    position:absolute;
    left:0;
    right:-.5rem;
    height:1px;
    background:var(--wege-line);
    pointer-events:none;
  }
  .wege-list::before{top:0}
  .wege-item{position:relative;transition-delay:var(--wege-delay,0s)}
  .wege-item::after{bottom:0}
  .wege-link{
    position:relative;
    isolation:isolate;
    min-height:6.5rem;
    display:grid;
    grid-template-columns:2rem minmax(0,1fr) 1.4rem;
    gap:.8rem;
    align-items:center;
    padding:1.5rem 0;
    color:var(--wege-text);
    text-decoration:none;
  }
  .wege-link::before{
    content:"";
    position:absolute;
    z-index:0;
    inset:0 -.5rem 0 0;
    background:var(--wege-hover);
    opacity:0;
    transition:opacity .24s ease;
  }
  .wege-link > span{position:relative;z-index:1}
  .wege-link__number{
    align-self:center;
    color:var(--wege-accent);
    font-family:var(--body);
    font-size:.76rem;
    font-weight:500;
    letter-spacing:.08em;
    font-variant-numeric:tabular-nums;
  }
  .wege-link__body{
    min-width:0;
    display:flex;
    flex-direction:column;
    align-items:flex-start;
    transition:transform .24s ease;
  }
  .wege-link__title{
    color:var(--wege-text);
    font-family:var(--disp);
    font-size:clamp(1.75rem,8vw,2rem);
    font-weight:400;
    line-height:1.08;
    letter-spacing:-.012em;
    transition:color .24s ease;
  }
  .wege-link__claim{
    margin-top:.5rem;
    color:var(--wege-claim);
    font-size:1rem;
    line-height:1.4;
  }
  .wege-link__audience{
    margin-top:.42rem;
    color:var(--wege-muted);
    font-size:.82rem;
    line-height:1.5;
  }
  .wege-link__arrow{
    justify-self:end;
    color:var(--wege-accent);
    font-family:var(--body);
    font-size:1.15rem;
    font-weight:300;
    line-height:1;
    transition:color .24s ease,transform .24s ease;
  }
  .wege-link:hover::before,
  .wege-link:focus-visible::before{opacity:1}
  .wege-link:hover .wege-link__title,
  .wege-link:focus-visible .wege-link__title{color:var(--wege-accent)}
  .wege-link:hover .wege-link__body,
  .wege-link:focus-visible .wege-link__body{transform:translateX(.25rem)}
  .wege-link:hover .wege-link__arrow,
  .wege-link:focus-visible .wege-link__arrow{transform:translate(.18rem,-.18rem)}
  .wege-link:focus-visible{
    outline:2px solid var(--wege-accent);
    outline-offset:-3px;
    border-radius:0;
  }
  .wege-scrollhint{
    position:absolute;
    left:50vw;
    bottom:.85rem;
    margin:0;
    transform:translateX(-50%);
  }
  .wege-scrollhint .hintword{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)}
  .wege-scrollhint .bar{
    width:48px;
    height:6px;
    border:1px solid var(--wege-line);
    border-radius:999px;
    background:transparent;
  }
  .wege-scrollhint .bar::after{display:none}

  @media(min-width:720px){
    .wege-section{
      --wege-edge:2rem;
      padding:5rem 0 2rem;
    }
    .wege-panel{padding:4.5rem 0 4rem}
    .wege-panel__inner{
      gap:3.5rem;
      padding:0 clamp(2rem,6vw,4rem);
    }
    .wege-panel .wege-title{font-size:clamp(3.5rem,7vw,4.5rem)}
    .wege-copy{max-width:34ch;font-size:1.08rem}
    .wege-list::before,
    .wege-item::after{right:-1rem}
    .wege-link{
      min-height:8.4rem;
      grid-template-columns:3.5rem minmax(0,1fr) 2rem;
      gap:1rem;
      padding:1.7rem 0;
    }
    .wege-link::before{right:-1rem}
    .wege-link__number{font-size:.82rem}
    .wege-link__title{font-size:clamp(2rem,4.5vw,2.65rem)}
    .wege-link__claim{font-size:1.06rem}
    .wege-link__audience{font-size:.88rem}
    .wege-link__arrow{font-size:1.28rem}
  }

  @media(min-width:1120px){
    .wege-section{
      --wege-edge:7.5vw;
      min-height:100svh;
      padding:8svh 0 2svh;
    }
    .wege-panel{
      min-height:90svh;
      padding:0;
    }
    .wege-panel__inner{
      grid-template-columns:minmax(0,.78fr) minmax(0,1fr);
      gap:6vw;
      align-items:center;
      padding:0 0 0 7.4vw;
    }
    .wege-panel .wege-title{
      font-size:clamp(3.6rem,4.9vw,6.25rem);
      line-height:1.03;
    }
    .wege-copy{
      margin-top:2.15rem;
      font-size:clamp(1.05rem,1.05vw,1.15rem);
    }
    .wege-list::before,
    .wege-item::after{right:calc(var(--wege-edge) * -.5)}
    .wege-link{
      min-height:clamp(10rem,20.2svh,13.3rem);
      grid-template-columns:4.5rem minmax(0,1fr) 2.25rem;
      gap:1.4rem;
      padding:clamp(1.65rem,2.5vw,2.5rem) 0;
    }
    .wege-link::before{right:calc(var(--wege-edge) * -.5)}
    .wege-link__title{font-size:clamp(2.15rem,2.55vw,3.1rem)}
    .wege-link__claim{font-size:clamp(1rem,1.2vw,1.25rem)}
    .wege-link__audience{font-size:clamp(.88rem,.82vw,.94rem)}
    .wege-link__arrow{
      --wege-arrow-shift:calc(var(--wege-edge) * .48);
      transform:translateX(var(--wege-arrow-shift));
    }
    .wege-link:hover .wege-link__arrow,
    .wege-link:focus-visible .wege-link__arrow{
      transform:translate(calc(var(--wege-arrow-shift) + .18rem),-.18rem);
    }
  }

  @media(prefers-reduced-motion:reduce){
    .wege-item{transition-delay:0s}
    .wege-link::before,
    .wege-link__body,
    .wege-link__title,
    .wege-link__arrow{transition:none}
    .wege-link:hover .wege-link__body,
    .wege-link:focus-visible .wege-link__body{transform:none}
  }

  /* Aus dem Blog: laufendes Band */
  .blogband{margin-top:2.6rem;overflow:hidden}
  .blogband--marquee{
    -webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);
    mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)}
  .blogband__track{display:flex;gap:1.6rem;width:max-content}
  .blogband--marquee .blogband__track{animation:bandscroll 46s linear infinite}
  .blogband--marquee:hover .blogband__track{animation-play-state:paused}
  @keyframes bandscroll{from{transform:translateX(0)}to{transform:translateX(calc(-50% - .8rem))}}
  .blogband--static .blogband__track{width:auto;justify-content:center;flex-wrap:wrap}

  .bandcard{flex:none;width:min(330px,82vw);text-decoration:none;color:var(--ink);
    background:var(--glass);border:1px solid var(--glass-edge);border-radius:20px;overflow:hidden;
    box-shadow:var(--shadow);transition:transform .25s,box-shadow .25s;
    backdrop-filter:blur(14px) saturate(1.4);-webkit-backdrop-filter:blur(14px) saturate(1.4)}
  .bandcard:hover{transform:translateY(-5px);box-shadow:var(--shadow),var(--glow)}
  .bandcard__cover{display:block;aspect-ratio:3/2;overflow:hidden}
  .bandcard__body{display:flex;flex-direction:column;gap:.4rem;padding:1.2rem 1.4rem 1.5rem}
  .bandcard__date{font-size:.76rem;letter-spacing:.06em;color:var(--faint)}
  .bandcard__title{font-family:var(--disp);font-size:1.18rem;line-height:1.25;color:var(--ink);
    transition:color .25s;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .bandcard:hover .bandcard__title{color:var(--green)}

  /* Neuigkeiten & Angebote */
  .news{display:grid;gap:1.6rem;margin-top:2.4rem}
  @media(min-width:820px){.news{grid-template-columns:repeat(3,1fr)}}
  .newscard{align-items:flex-start;--nc:var(--wood);
    transition:transform .25s,box-shadow .25s,background .25s,border-color .25s}
  .newscard--neu{--nc:var(--green);--nc-tint:rgba(51,96,79,.09);--nc-bd:rgba(51,96,79,.5);--nc-sh:rgba(51,96,79,.4)}
  .newscard--termin{--nc:var(--blue);--nc-tint:rgba(63,94,126,.1);--nc-bd:rgba(63,94,126,.5);--nc-sh:rgba(63,94,126,.42)}
  .newscard--angebot{--nc:var(--amber);--nc-tint:rgba(176,105,15,.09);--nc-bd:rgba(176,105,15,.5);--nc-sh:rgba(176,105,15,.4)}
  .offercard.newscard:hover{background:var(--nc-tint);border-color:var(--nc-bd);
    box-shadow:0 18px 42px -20px var(--nc-sh),inset 0 1px 0 rgba(255,255,255,.9)}
  .offercard.newscard:hover h3{color:var(--nc)}
  .newscard:hover .newscard__kick{background:var(--nc);border-color:var(--nc);color:var(--paper)}
  .newscard__kick{align-self:flex-start;font-family:var(--body);font-weight:500;font-size:.72rem;
    letter-spacing:.16em;text-transform:uppercase;padding:.3em .9em;border-radius:999px;
    border:1px solid var(--hairline);color:var(--wood);background:rgba(255,255,255,.55);margin-bottom:.3rem;
    transition:background .25s,border-color .25s,color .25s}
  .newscard__kick--neu{color:var(--green);border-color:rgba(51,96,79,.4)}
  .newscard__kick--termin{color:var(--blue);border-color:rgba(63,94,126,.4)}
  .newscard__kick--angebot{color:var(--amber);border-color:rgba(176,105,15,.4)}
  .newscard__hl{font-family:var(--disp);font-size:1.35rem;color:var(--ink);margin-top:.1rem}
  .newscard__hl s{color:var(--faint);font-size:.72em;margin-left:.5em}

  /* Abschluss: Vertrauens-Zeile */
  .assure{list-style:none;display:flex;flex-wrap:wrap;justify-content:center;gap:.5rem 1.5rem;
    margin:1.8rem auto 0;padding:0;max-width:38em}
  .assure li{display:inline-flex;align-items:center;gap:.5rem;font-size:.9rem;color:var(--dim)}
  .assure li::before{content:"✓";color:var(--wood);font-weight:600}

  @media(prefers-reduced-motion:reduce){
    .blogband--marquee{overflow-x:auto;-webkit-mask-image:none;mask-image:none}
    .blogband--marquee .blogband__track{animation:none}
    .bandcard[aria-hidden="true"]{display:none}
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Hero-Logo: Tilt + Lichtreflex + Münzdrehung ---------- */
  const heroFloor = document.querySelector('.floor.hero') as HTMLElement;
  const heroLogo = document.getElementById('heroLogo')!;
  let spinning = false;

  if (heroFloor && heroLogo && window.matchMedia('(pointer:fine)').matches && !reduced) {
    heroFloor.addEventListener('pointermove', (e) => {
      if (spinning) { return; }
      const r = heroFloor.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - .5;
      const y = (e.clientY - r.top) / r.height - .5;
      heroLogo.style.transform = 'perspective(900px) rotateX(' + (-y * 14).toFixed(2) +
        'deg) rotateY(' + (x * 14).toFixed(2) + 'deg)';
      heroLogo.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
      heroLogo.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
    });
    heroFloor.addEventListener('pointerleave', () => {
      if (spinning) { return; }
      heroLogo.style.transform = '';
      heroLogo.style.setProperty('--gx', '50%');
      heroLogo.style.setProperty('--gy', '35%');
    });
  }

  function spinAndGo() {
    const target = document.getElementById('wahl');
    if (reduced || spinning) {
      target?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      return;
    }
    spinning = true;
    heroLogo.style.transform = '';
    heroLogo.classList.add('is-spinning');
    setTimeout(() => { target?.scrollIntoView({ behavior: 'smooth' }); }, 550);
    const stop = () => {
      heroLogo.classList.remove('is-spinning');
      spinning = false;
    };
    heroLogo.addEventListener('animationend', stop, { once: true });
    setTimeout(stop, 1500);
  }
  heroLogo.addEventListener('click', spinAndGo);
  heroLogo.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); spinAndGo(); }
  });

  /* ---------- Idee: Drei Kräfte → Zeit ---------- */
  const forces = document.getElementById('forces')!;
  const pills = Array.from(document.querySelectorAll<HTMLElement>('.forces__pill'));
  let fActive = 0;
  let fPaused = false;
  let fTimer: ReturnType<typeof setInterval> | null = null;
  let fResume: ReturnType<typeof setTimeout> | null = null;

  const setForce = (i: number) => {
    fActive = (i + pills.length) % pills.length;
    forces.dataset.active = String(fActive);
    pills.forEach((p, k) => p.classList.toggle('is-active', k === fActive));
  };
  const holdForce = (ms = 4500) => {
    fPaused = true;
    if (fResume) { clearTimeout(fResume); }
    fResume = setTimeout(() => { fPaused = false; }, ms);
  };

  setForce(0);
  if (!reduced && pills.length) {
    // sanftes Durchlaufen, sobald die Sektion sichtbar ist
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !fTimer) {
          fTimer = setInterval(() => { if (!fPaused) { setForce(fActive + 1); } }, 2600);
        }
      });
    }, { threshold: 0.35 });
    io.observe(forces);
  }
  const finePointer = window.matchMedia('(pointer:fine)').matches;
  pills.forEach((pill, i) => {
    if (finePointer) {
      pill.addEventListener('pointerenter', () => { fPaused = true; setForce(i); });
      pill.addEventListener('pointerleave', () => { fPaused = false; });
    }
    pill.addEventListener('click', () => { setForce(i); holdForce(); });
  });

  /* ---------- Kartenstapel: sanftes Durchlaufen + Punkt-Indikatoren ---------- */
  const deck = document.getElementById('deck')!;
  const cards = Array.from(deck.querySelectorAll<HTMLElement>('.deckcard'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.deck__dot'));
  let order = [0, 1, 2];
  let blaettert = false;

  function applyOrder() {
    order.forEach((cardIdx, pos) => { cards[cardIdx].dataset.pos = String(pos); });
    dots.forEach((d, i) => d.classList.toggle('is-on', order[0] === i));
  }
  function advance() {
    if (blaettert) { return; }
    blaettert = true;
    const top = cards[order[0]];
    if (reduced) {
      order.push(order.shift()!);
      applyOrder();
      blaettert = false;
      return;
    }
    top.classList.add('is-leaving');
    setTimeout(() => {
      order.push(order.shift()!);
      applyOrder();
      top.classList.remove('is-leaving');
      blaettert = false;
    }, 480);
  }
  function retreat() {
    if (blaettert) { return; }
    order.unshift(order.pop()!);
    applyOrder();
  }
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const ziel = parseInt(dot.dataset.i!, 10);
      if (order[0] === ziel || blaettert) { return; }
      order = [ziel, (ziel + 1) % 3, (ziel + 2) % 3];
      applyOrder();
    });
  });

  /* Klick blättert, am Handy wischen (links = weiter, rechts = zurück) */
  let swiped = false;
  let startX = 0;
  let startY = 0;
  deck.addEventListener('pointerdown', (e) => { startX = e.clientX; startY = e.clientY; });
  deck.addEventListener('pointerup', (e) => {
    const dx = e.clientX - startX;
    const dy = e.clientY - startY;
    if (Math.abs(dx) > 44 && Math.abs(dx) > Math.abs(dy)) {
      swiped = true;
      if (dx < 0) { advance(); } else { retreat(); }
      setTimeout(() => { swiped = false; }, 350);
    }
  });
  deck.addEventListener('click', () => { if (!swiped) { advance(); } });
</script>

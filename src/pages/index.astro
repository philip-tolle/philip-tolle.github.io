---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import logo from '../assets/nc-logo.png';
import roboter from '../assets/roboter.png';
---
<Base
  title="NextCourse — Bildungs-, Beratungs- und Umsetzungspartner für das Gastgewerbe"
  description="NextCourse ist der Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung und Digitalisierung für Betriebe, Kurse und Weiterbildung in der Akademie — aus Würzburg, im Einsatz in Mainfranken."
>

  <!-- FLOOR 1: Das Logo als Bühne -->
  <div class="floor hero">
    <div class="wrap" style="text-align:center">
      <div class="heroLogo" id="heroLogo" role="button" tabindex="0"
        aria-label="Zur Auswahl: Consulting oder Akademie">
        <Image src={logo} alt="NextCourse Logo — Wellen und Pfeil aus warmem Holz, hinterleuchtet"
          width={1080} format="webp" quality={82} loading="eager" />
      </div>
      <h1 class="heroWord">NextCourse<span class="sr-only"> — Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe</span></h1>
      <p class="heroSub">Der Bildungs-, Beratungs- und Umsetzungspartner<br>für das deutsche Gastgewerbe.</p>
      <a class="scrollhint" href="#wahl" aria-label="Weiter zur Auswahl Consulting oder Akademie">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 2: Die Weiche — Consulting oder Akademie -->
  <div class="floor" id="wahl">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Zwei Wege</p>
        <h2 class="reveal">Was führt Sie zu uns?</h2>
      </div>
      <div class="fork">
        <span class="fork__or" aria-hidden="true">oder</span>
        <a class="forkcard reveal" href="/consulting/">
          <p class="forkcard__aud">Für Betriebe &amp; Unternehmer</p>
          <h3>Consulting</h3>
          <p class="voice">Digitalisierung und KI, die im Betrieb ankommen.</p>
          <span class="forkcard__go">Zum Consulting</span>
        </a>
        <a class="forkcard forkcard--akademie reveal" href="/akademie/">
          <p class="forkcard__aud">Für alle, die weiterkommen wollen</p>
          <h3>Akademie</h3>
          <p class="voice">Kurse, die man morgen im Betrieb spürt.</p>
          <span class="forkcard__go">Zur Akademie</span>
        </a>
      </div>
      <a class="scrollhint" href="#idee" aria-label="Weiter zur Idee hinter NextCourse">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 3: Die Idee hinter NextCourse -->
  <div class="floor--auto floor" id="idee">
    <div class="wrap">
      <p class="eyebrow reveal" style="--acc:var(--wood)">Die Idee hinter NextCourse</p>
      <h2 class="reveal">Das Gastgewerbe hat kein Wissensproblem. Es hat ein Zeitproblem.</h2>
      <p class="lead reveal">Fachkräfte fehlen, die Verwaltung frisst die Abende, und Digitalisierung klingt nach einem weiteren Projekt, für das niemand Zeit hat. Deshalb ist NextCourse kein Kursanbieter und keine klassische Beratung — sondern beides, verbunden zu einem Kreislauf, der im Betrieb ankommt:</p>

      <div class="deck reveal" id="deck">
        <button class="deckcard" data-step="lernen" data-pos="0" aria-haspopup="dialog">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M50 14 C 38 6, 22 6, 14 12 L14 46 C 22 40, 38 40, 50 48"/>
            <path d="M50 14 C 62 6, 78 6, 86 12 L86 46 C 78 40, 62 40, 50 48"/>
            <path d="M50 14 L50 48"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">01</span>
          <h3>Lernen</h3>
          <p class="voice">Wissen, das man am nächsten Tag benutzt.</p>
          <span class="deckcard__hint">Mehr erfahren</span>
        </button>
        <button class="deckcard" data-step="umsetzen" data-pos="1" aria-haspopup="dialog">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 42 C 24 28, 40 48, 56 36 C 64 30, 70 26, 78 22"/>
            <path d="M70 14 L82 20 L74 31"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">02</span>
          <h3>Umsetzen</h3>
          <p class="voice">Projekte, die man am Monatsende misst.</p>
          <span class="deckcard__hint">Mehr erfahren</span>
        </button>
        <button class="deckcard" data-step="dranbleiben" data-pos="2" aria-haspopup="dialog">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M32 14 A 24 20 0 0 1 70 20"/>
            <path d="M64 10 L72 21 L58 24"/>
            <path d="M68 46 A 24 20 0 0 1 30 40"/>
            <path d="M36 50 L28 39 L42 36"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">03</span>
          <h3>Dranbleiben</h3>
          <p class="voice">Systeme, die auch nächstes Jahr noch laufen.</p>
          <span class="deckcard__hint">Mehr erfahren</span>
        </button>
      </div>
      <div class="deck__dots" role="group" aria-label="Karte wählen">
        <button type="button" data-dot="0" aria-label="Karte 1: Lernen" aria-current="true"></button>
        <button type="button" data-dot="1" aria-label="Karte 2: Umsetzen"></button>
        <button type="button" data-dot="2" aria-label="Karte 3: Dranbleiben"></button>
      </div>
    </div>
  </div>

  <dialog class="stepdialog" id="stepdialog">
    <button class="stepdialog__close" type="button" aria-label="Schließen">×</button>
    <div class="stepdialog__in">
      <article data-panel="lernen" hidden>
        <span class="deckcard__num">01 · Lernen</span>
        <h3>Veränderung beginnt mit Verstehen.</h3>
        <p>Wer KI einmal selbst ausprobiert hat, hört auf, sie zu fürchten — und fängt an, sie einzusetzen. Darum steht am Anfang nicht die Technik, sondern das Wissen im Team.</p>
        <p class="modell">Bei NextCourse ist das die <b>Akademie</b>: Kurse und Seminare mit KI-Modul in jedem Format — vom KI-Grundlagentag bis zur AEVO-Vorbereitung.</p>
        <a class="arrowlink" href="/akademie/">Zur Akademie</a>
      </article>
      <article data-panel="umsetzen" hidden>
        <span class="deckcard__num">02 · Umsetzen</span>
        <h3>Wissen allein ändert keinen Dienstplan.</h3>
        <p>Den Unterschied macht die Umsetzung im eigenen Haus — klein geschnitten, messbar und ohne den laufenden Betrieb lahmzulegen.</p>
        <p class="modell">Bei NextCourse ist das das <b>Consulting</b>: vom Quick-Check über den Mystery Check bis zum Pilotprojekt zum Festpreis.</p>
        <a class="arrowlink" href="/consulting/">Zum Consulting</a>
      </article>
      <article data-panel="dranbleiben" hidden>
        <span class="deckcard__num">03 · Dranbleiben</span>
        <h3>Die meisten Projekte scheitern nicht am Start — sondern am dritten Monat.</h3>
        <p>Damit Wissen im Haus bleibt und eingeführte Systeme weiterlaufen, braucht es jemanden, der dranbleibt. Genau das unterscheidet einen Partner von einem Anbieter.</p>
        <p class="modell">Bei NextCourse ist das die <b>Begleitung</b>: digitales Betriebshandbuch, laufender Support, Monitoring.</p>
        <a class="arrowlink" href="/consulting/">Zum Consulting</a>
      </article>
    </div>
  </dialog>

  <!-- FLOOR 3b: Gründungsgeschichte -->
  <div class="floor--auto floor">
    <div class="wrap">
      <p class="eyebrow reveal" style="--acc:var(--wood)">Die Gründungsgeschichte</p>
      <h2 class="reveal">Angefangen hat alles in Neuseeland.</h2>
      <p class="lead reveal">Warum NextCourse? Die Antwort beginnt am anderen Ende der Welt. Die ganze Geschichte erzählt Philip hier bald selbst — zum Anhören.</p>
      <div class="storybox reveal">
        <span class="storybox__play" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M5 3.5 L14 9 L5 14.5 Z"/></svg>
        </span>
        <p>Die Geschichte zum Anhören — folgt in Kürze.</p>
      </div>
      <blockquote class="quote reveal">„Wir nutzen die Herzlichkeit des Gastgebers und verstärken sie durch die Intelligenz der KI.“<br><span class="small faint" style="font-style:normal">Philip Tolle, Gründer</span></blockquote>
      <a class="arrowlink reveal" href="/ueber/">Mehr über NextCourse</a>
    </div>
  </div>

  <!-- FLOOR 4: Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="robothero reveal">
        <Image src={roboter} alt="NextCourse Roboter-Maskottchen im Kupferstich-Stil"
          width={420} format="webp" quality={82} />
      </div>
      <h2 class="reveal" style="max-width:none">Sprechen wir über Ihren Betrieb.</h2>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>

</Base>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Hero-Logo: Tilt + Lichtreflex + Münzdrehung ---------- */
  const heroFloor = document.querySelector('.floor.hero') as HTMLElement;
  const heroLogo = document.getElementById('heroLogo')!;
  let spinning = false;

  if (heroFloor && heroLogo && window.matchMedia('(pointer:fine)').matches && !reduced) {
    heroFloor.addEventListener('pointermove', (e) => {
      if (spinning) { return; }
      const r = heroFloor.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - .5;
      const y = (e.clientY - r.top) / r.height - .5;
      heroLogo.style.transform = 'perspective(900px) rotateX(' + (-y * 14).toFixed(2) +
        'deg) rotateY(' + (x * 14).toFixed(2) + 'deg)';
      heroLogo.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
      heroLogo.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
    });
    heroFloor.addEventListener('pointerleave', () => {
      if (spinning) { return; }
      heroLogo.style.transform = '';
      heroLogo.style.setProperty('--gx', '50%');
      heroLogo.style.setProperty('--gy', '35%');
    });
  }

  function spinAndGo() {
    const target = document.getElementById('wahl');
    if (reduced || spinning) {
      target?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      return;
    }
    spinning = true;
    heroLogo.style.transform = '';
    heroLogo.classList.add('is-spinning');
    setTimeout(() => { target?.scrollIntoView({ behavior: 'smooth' }); }, 550);
    const stop = () => {
      heroLogo.classList.remove('is-spinning');
      spinning = false;
    };
    heroLogo.addEventListener('animationend', stop, { once: true });
    setTimeout(stop, 1500);
  }
  heroLogo.addEventListener('click', spinAndGo);
  heroLogo.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); spinAndGo(); }
  });

  /* ---------- Konzept-Kartenstapel ---------- */
  const deck = document.getElementById('deck')!;
  const cards = Array.from(deck.querySelectorAll<HTMLButtonElement>('.deckcard'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.deck__dots button'));
  let order = [0, 1, 2];

  function applyOrder() {
    order.forEach((cardIdx, pos) => { cards[cardIdx].dataset.pos = String(pos); });
    dots.forEach((d, i) => {
      d.setAttribute('aria-current', i === order[0] ? 'true' : 'false');
    });
  }
  function cycle() {
    order.push(order.shift()!);
    applyOrder();
  }
  function bringToFront(cardIdx: number) {
    while (order[0] !== cardIdx) { order.push(order.shift()!); }
    applyOrder();
  }

  /* Drüberfahren blättert zur nächsten Karte (nur Maus, nicht Touch) */
  if (window.matchMedia('(hover:hover) and (pointer:fine)').matches && !reduced) {
    deck.addEventListener('pointerenter', () => cycle());
  }
  dots.forEach((d, i) => d.addEventListener('click', () => bringToFront(i)));

  /* Klick öffnet das Overlay mit der Begründung */
  const dialog = document.getElementById('stepdialog') as HTMLDialogElement;
  const panels = Array.from(dialog.querySelectorAll<HTMLElement>('[data-panel]'));
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const step = card.dataset.step;
      panels.forEach((p) => { p.hidden = p.dataset.panel !== step; });
      dialog.showModal();
    });
  });
  dialog.querySelector('.stepdialog__close')!.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) { dialog.close(); }
  });
</script>

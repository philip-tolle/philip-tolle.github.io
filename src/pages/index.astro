---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import logo from '../assets/nc-logo.png';
import roboter from '../assets/roboter.png';
---
<Base title="NextCourse — Menschliche Kompetenz. Digitale Kraft.">

  <!-- FLOOR 1: Das Logo als Bühne -->
  <div class="floor hero">
    <span class="deco deco--amber" style="width:400px;height:400px;right:6%;top:10%" aria-hidden="true"></span>
    <span class="deco deco--green" style="width:340px;height:340px;left:2%;bottom:8%" aria-hidden="true"></span>
    <div class="wrap" style="text-align:center">
      <div class="heroLogo" id="heroLogo" role="button" tabindex="0"
        aria-label="Zur Auswahl: Consulting oder Akademie">
        <Image src={logo} alt="NextCourse Logo — Wellen und Pfeil aus warmem Holz, hinterleuchtet"
          width={1080} format="webp" quality={82} loading="eager" />
      </div>
      <h1 class="heroWord">NextCourse<span class="sr-only"> — KI-Beratung, Bildung und Begleitung für das Gastgewerbe in Mainfranken</span></h1>
      <p class="heroSub">Menschliche Kompetenz. Digitale Kraft.</p>
      <a class="scrollhint" href="#wahl" aria-label="Weiter zur Auswahl Consulting oder Akademie">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 2: Die Weiche — Consulting oder Akademie -->
  <div class="floor" id="wahl">
    <span class="deco deco--green" style="width:440px;height:440px;left:-4%;top:18%" aria-hidden="true"></span>
    <span class="deco deco--blue" style="width:420px;height:420px;right:-4%;bottom:10%" aria-hidden="true"></span>
    <span class="deco deco--amber" style="width:320px;height:320px;right:14%;top:-2%" aria-hidden="true"></span>
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Zwei Wege</p>
        <h2 class="reveal">Was führt Sie zu uns?</h2>
      </div>
      <div class="fork">
        <span class="fork__or" aria-hidden="true">oder</span>
        <a class="forkcard reveal" href="/consulting/">
          <p class="forkcard__aud">Für Betriebe &amp; Unternehmer</p>
          <h3>Consulting</h3>
          <p class="voice">Digitalisierung und KI, die im Betrieb ankommen.</p>
          <ul class="forkcard__list">
            <li>Beratung &amp; Pilotprojekte</li>
            <li>Begleitung &amp; Support</li>
            <li>Flying Academy — Schulungen bei Ihnen im Haus</li>
          </ul>
          <span class="gang__go">Zum Consulting</span>
        </a>
        <a class="forkcard forkcard--akademie reveal" href="/akademie/">
          <p class="forkcard__aud">Für alle, die weiterkommen wollen</p>
          <h3>Akademie</h3>
          <p class="voice">Weiterbildung aus der Praxis — mit KI-Modul in jedem Kurs.</p>
          <ul class="forkcard__list">
            <li>KI-Grundlagen für Gastgeber &amp; KMU</li>
            <li>AEVO-Vorbereitung &amp; Barista</li>
            <li>AZAV-geförderte Kurse — in Vorbereitung</li>
          </ul>
          <span class="gang__go">Zur Akademie</span>
        </a>
      </div>
    </div>
  </div>

  <!-- FLOOR 3: Claim -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="ornament reveal" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 34 34">
          <path d="M3 12 C 9 8, 15 14, 21 10" fill="none" stroke="#B9885C" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 18 C 9 14, 15 20, 21 16" fill="none" stroke="#B9885C" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 24 C 9 20, 15 26, 21 22" fill="none" stroke="#B9885C" stroke-width="2" stroke-linecap="round"/>
          <path d="M23 9 L 31 17 L 23 25" fill="none" stroke="#E5A254" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <p class="claim reveal">Menschliche Kompetenz.<span class="z2">Digitale Kraft.</span></p>
      <p class="voice reveal" style="max-width:26em;margin:0 auto">KI-Beratung, Bildung &amp; Begleitung für das Gastgewerbe in Mainfranken.</p>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>

  <!-- FLOOR 4: Modellrechnung -->
  <div class="floor--auto floor">
    <span class="deco deco--green" style="width:400px;height:400px;left:-4%;top:34%" aria-hidden="true"></span>
    <span class="deco deco--amber" style="width:360px;height:360px;right:-3%;bottom:6%" aria-hidden="true"></span>
    <div class="wrap">
      <p class="eyebrow reveal">Modellrechnung</p>
      <h2 class="reveal">Was wäre bei Ihnen möglich?</h2>
      <p class="lead reveal">Stellen Sie Ihren Betrieb ein — wir rechnen unsere Modellwerte auf Ihre Größe um. Ein erster Anhaltspunkt, kein Versprechen.</p>
      <div class="calc">
        <div class="calc__panel reveal">
          <div class="ctl">
            <label for="c-rooms">Zimmer im Haus <output id="o-rooms" for="c-rooms">65 Zimmer</output></label>
            <input type="range" id="c-rooms" min="20" max="150" step="5" value="65">
          </div>
          <div class="ctl">
            <label for="c-adr">Durchschnittlicher Zimmerpreis <output id="o-adr" for="c-adr">120 EUR</output></label>
            <input type="range" id="c-adr" min="80" max="250" step="5" value="120">
          </div>
          <p class="calc__note">Jeder Betrieb ist anders. Wo Ihre Hebel wirklich liegen, klären wir im Erstgespräch — auch für Restaurants ohne Zimmer.</p>
        </div>
        <div class="bill reveal" aria-live="polite">
          <p class="bill__head">Ihre Modellrechnung</p>
          <div class="bl"><b>KI-Telefonassistent</b><span class="dots"></span><span id="r-tel">+77.000 EUR</span></div>
          <div class="bl"><b>Revenue Management</b><span class="dots"></span><span id="r-rev">+93.000 EUR</span></div>
          <div class="bl"><b>Digitale Dienstplanung</b><span class="dots"></span><span id="r-plan">+28.000 EUR</span></div>
          <div class="bl"><b>Workflow-Automatisierung</b><span class="dots"></span><span id="r-flow">+18.000 EUR</span></div>
          <div class="bl"><b>Wareneinsatzoptimierung</b><span class="dots"></span><span id="r-ware">+14.000 EUR</span></div>
          <div class="bl bl--sum"><b>Jahreseffekt</b><span class="dots"></span><span id="r-sum">+230.000 EUR</span></div>
          <p class="bill__fine" id="r-note">Für 65 Zimmer bei 120 EUR Zimmerpreis — gerundet.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- FLOOR 5: Abschluss -->
  <div class="floor">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="robothero reveal">
        <Image src={roboter} alt="NextCourse Roboter-Maskottchen im Kupferstich-Stil"
          width={420} format="webp" quality={82} />
      </div>
      <h2 class="reveal" style="max-width:none">Sprechen wir über Ihren Betrieb.</h2>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>

</Base>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Hero-Logo: Tilt + Lichtreflex + Münzdrehung ---------- */
  const heroFloor = document.querySelector('.floor.hero') as HTMLElement;
  const heroLogo = document.getElementById('heroLogo')!;
  let spinning = false;

  if (heroFloor && heroLogo && window.matchMedia('(pointer:fine)').matches && !reduced) {
    heroFloor.addEventListener('pointermove', (e) => {
      if (spinning) { return; }
      const r = heroFloor.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - .5;
      const y = (e.clientY - r.top) / r.height - .5;
      heroLogo.style.transform = 'perspective(900px) rotateX(' + (-y * 14).toFixed(2) +
        'deg) rotateY(' + (x * 14).toFixed(2) + 'deg)';
      heroLogo.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
      heroLogo.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
    });
    heroFloor.addEventListener('pointerleave', () => {
      if (spinning) { return; }
      heroLogo.style.transform = '';
      heroLogo.style.setProperty('--gx', '50%');
      heroLogo.style.setProperty('--gy', '35%');
    });
  }

  function spinAndGo() {
    const target = document.getElementById('wahl');
    if (reduced || spinning) {
      target?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      return;
    }
    spinning = true;
    heroLogo.style.transform = '';
    heroLogo.classList.add('is-spinning');
    setTimeout(() => { target?.scrollIntoView({ behavior: 'smooth' }); }, 550);
    const stop = () => {
      heroLogo.classList.remove('is-spinning');
      spinning = false;
    };
    heroLogo.addEventListener('animationend', stop, { once: true });
    setTimeout(stop, 1500);
  }
  heroLogo.addEventListener('click', spinAndGo);
  heroLogo.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); spinAndGo(); }
  });

  /* ---------- ROI-Kalkulator ---------- */
  const BASE_ROOMS = 65, BASE_ADR = 120;
  const ITEMS = [
    { id: 'r-tel', base: 77000, mode: 'rev' },
    { id: 'r-rev', base: 93000, mode: 'rev' },
    { id: 'r-plan', base: 28000, mode: 'ops' },
    { id: 'r-flow', base: 18000, mode: 'ops' },
    { id: 'r-ware', base: 14000, mode: 'ops' },
  ];
  const slRooms = document.getElementById('c-rooms') as HTMLInputElement;
  const slAdr = document.getElementById('c-adr') as HTMLInputElement;
  function fmtEur(v: number) {
    return '+' + (Math.round(v / 1000) * 1000).toLocaleString('de-DE') + ' EUR';
  }
  function calc() {
    const rooms = parseInt(slRooms.value, 10);
    const adr = parseInt(slAdr.value, 10);
    const fRev = (rooms * adr) / (BASE_ROOMS * BASE_ADR);
    const fOps = rooms / BASE_ROOMS;
    let sum = 0;
    ITEMS.forEach((it) => {
      const v = it.base * (it.mode === 'rev' ? fRev : fOps);
      sum += v;
      document.getElementById(it.id)!.textContent = fmtEur(v);
    });
    document.getElementById('r-sum')!.textContent = fmtEur(sum);
    document.getElementById('o-rooms')!.textContent = rooms + ' Zimmer';
    document.getElementById('o-adr')!.textContent = adr + ' EUR';
    document.getElementById('r-note')!.textContent =
      'Für ' + rooms + ' Zimmer bei ' + adr + ' EUR Zimmerpreis — gerundet.';
  }
  slRooms.addEventListener('input', calc);
  slAdr.addEventListener('input', calc);
  calc();
</script>

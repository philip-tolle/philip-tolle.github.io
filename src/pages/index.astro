---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BlogCover from '../components/BlogCover.astro';
import logo from '../assets/nc-logo.png';
import philip from '../assets/philip.png';
import bannerConsulting from '../assets/banner-consulting-v4.png';
import bannerAkademie from '../assets/banner-akademie-v4.png';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const marquee = posts.length >= 3;
const bandItems = marquee ? [...posts, ...posts] : posts;
---
<Base
  title="NextCourse — Bildungs-, Beratungs- und Umsetzungspartner für das Gastgewerbe"
  description="NextCourse ist der Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung und Digitalisierung für Betriebe, Kurse und Weiterbildung in der Akademie — aus Würzburg, im Einsatz in Mainfranken."
>

  <!-- FLOOR 1: Das Logo als Bühne -->
  <div class="floor hero">
    <div class="wrap" style="text-align:center">
      <div class="heroLogo" id="heroLogo" role="button" tabindex="0"
        aria-label="Zur Auswahl: Consulting oder Akademie">
        <Image src={logo} alt="NextCourse Logo — Wellen und Pfeil aus warmem Holz, hinterleuchtet"
          width={1080} format="webp" quality={82} loading="eager" />
      </div>
      <h1 class="heroWord">NextCourse<span class="sr-only"> — Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe</span></h1>
      <p class="heroSub">Der Bildungs-, Beratungs- und Umsetzungspartner<br>für das deutsche Gastgewerbe.</p>
      <a class="scrollhint" href="#wahl" aria-label="Weiter zur Auswahl Consulting oder Akademie">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 2: Die Weiche — Consulting oder Akademie -->
  <div class="floor" id="wahl">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Zwei Wege</p>
        <h2 class="reveal">Was führt Sie zu uns?</h2>
      </div>
      <div class="fork">
        <span class="fork__or" aria-hidden="true">oder</span>
        <a class="forkcard reveal" href="/consulting/">
          <Image class="forkcard__img" src={bannerConsulting} alt="" width={760} format="webp" quality={72} />
          <h3>NextCourse Consulting</h3>
          <p class="voice">Digitalisierung und KI, die im Betrieb ankommen.</p>
          <p class="forkcard__aud">Für Betriebe &amp; Unternehmer</p>
        </a>
        <a class="forkcard forkcard--akademie reveal" href="/akademie/">
          <Image class="forkcard__img" src={bannerAkademie} alt="" width={760} format="webp" quality={72} />
          <h3>NextCourse Academy</h3>
          <p class="voice">Kurse, die man morgen im Betrieb spürt.</p>
          <p class="forkcard__aud">Für alle, die weiterkommen wollen</p>
        </a>
      </div>
      <a class="scrollhint" href="#idee" aria-label="Weiter zur Idee hinter NextCourse">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 3: Die Idee hinter NextCourse -->
  <div class="floor--auto floor" id="idee">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Die Idee hinter NextCourse</p>
        <h2 class="reveal">Kein Wissensproblem. Ein Zeitproblem.</h2>
        <p class="voice reveal" style="max-width:28em;margin:.9rem auto 0">„Technologie übernimmt die Last. Menschen gestalten das Erlebnis. NextCourse macht beides möglich.“</p>
      </div>

      <div class="idee2">
        <div class="idee2col reveal">
          <p class="eyebrow eyebrow--c" style="--acc:var(--amber)">Die Probleme der Branche</p>
          <div class="idee2__viz">
          <div class="forces__stage" id="forces">
            <svg viewBox="0 0 640 400" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <marker id="ncArrow" markerWidth="9" markerHeight="9" refX="6" refY="4.5" orient="auto">
                  <path d="M0,0 L8,4.5 L0,9 z" fill="rgba(138,114,80,.5)"/>
                </marker>
              </defs>
              <path d="M255,65 C345,65 385,120 435,165" marker-end="url(#ncArrow)"/>
              <path d="M255,200 C345,200 385,200 435,200" marker-end="url(#ncArrow)"/>
              <path d="M255,335 C345,335 385,280 435,235" marker-end="url(#ncArrow)"/>
            </svg>
            <div class="forces__pill" data-f="0" style="top:35px">
              <span>Fachkräftemangel</span><b>50.000+ unbesetzte Stellen</b>
            </div>
            <div class="forces__pill" data-f="1" style="top:170px">
              <span>Digitalisierungsrückstand</span><b>≈ 70 % analoge Prozesse</b>
            </div>
            <div class="forces__pill" data-f="2" style="top:305px">
              <span>EU AI Act &amp; neue Pflichten</span><b>gelten ab August 2026</b>
            </div>
            <div class="forces__node">
              <span>Es kostet vor allem</span>
              <b>Zeit</b>
              <span>die im Betrieb fehlt</span>
            </div>
          </div>
          </div>
          <p class="idee2__cap">Sechs Verlustjahre in Folge — und drei Kräfte, die sich gegenseitig verstärken.</p>
        </div>
        <span class="idee2__div" aria-hidden="true"></span>
        <div class="idee2col reveal">
          <p class="eyebrow eyebrow--c" style="--acc:var(--green)">Die Unterstützung von NextCourse</p>
          <div class="idee2__viz">
          <div class="deck" id="deck">
        <div class="deckcard" data-step="lernen" data-pos="0">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M50 14 C 38 6, 22 6, 14 12 L14 46 C 22 40, 38 40, 50 48"/>
            <path d="M50 14 C 62 6, 78 6, 86 12 L86 46 C 78 40, 62 40, 50 48"/>
            <path d="M50 14 L50 48"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">01</span>
          <h3>Lernen</h3>
          <p class="voice">Wissen, das man am nächsten Tag benutzt.</p>
          <button class="deckcard__more" data-step="lernen" aria-haspopup="dialog">Mehr erfahren</button>
        </div>
        <div class="deckcard" data-step="umsetzen" data-pos="1">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 42 C 24 28, 40 48, 56 36 C 64 30, 70 26, 78 22"/>
            <path d="M70 14 L82 20 L74 31"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">02</span>
          <h3>Umsetzen</h3>
          <p class="voice">Projekte, die man am Monatsende misst.</p>
          <button class="deckcard__more" data-step="umsetzen" aria-haspopup="dialog">Mehr erfahren</button>
        </div>
        <div class="deckcard" data-step="dranbleiben" data-pos="2">
          <svg class="deckcard__art" viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M32 14 A 24 20 0 0 1 70 20"/>
            <path d="M64 10 L72 21 L58 24"/>
            <path d="M68 46 A 24 20 0 0 1 30 40"/>
            <path d="M36 50 L28 39 L42 36"/>
          </svg>
          <span class="deckcard__num" aria-hidden="true">03</span>
          <h3>Dranbleiben</h3>
          <p class="voice">Systeme, die auch nächstes Jahr noch laufen.</p>
          <button class="deckcard__more" data-step="dranbleiben" aria-haspopup="dialog">Mehr erfahren</button>
        </div>
          </div>
          <div class="deck__controls">
            <button class="deck__next" id="decknext" aria-label="Nächste Karte des Stapels zeigen">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12 a9 9 0 1 0 3.5 -7"/>
                <path d="M3 3 v6 h6"/>
              </svg>
              Weiterblättern
            </button>
          </div>
          </div>
          <p class="idee2__cap">Kein Kursanbieter. Keine klassische Beratung. Sondern beides — als ein Kreislauf.</p>
        </div>
      </div>
      <a class="scrollhint" href="#blog" aria-label="Weiter zu den neuesten Blog-Artikeln">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <dialog class="stepdialog" id="stepdialog">
    <button class="stepdialog__close" type="button" aria-label="Schließen">×</button>
    <div class="stepdialog__in">
      <article data-panel="lernen" hidden>
        <span class="deckcard__num">01 · Lernen</span>
        <h3>Veränderung beginnt mit Verstehen.</h3>
        <p>Wer KI einmal selbst ausprobiert hat, hört auf, sie zu fürchten — und fängt an, sie einzusetzen. Darum steht am Anfang nicht die Technik, sondern das Wissen im Team.</p>
        <p class="modell">Bei NextCourse ist das die <b>Akademie</b>: Kurse und Seminare mit KI-Modul in jedem Format — vom KI-Grundlagentag bis zur AEVO-Vorbereitung.</p>
        <a class="arrowlink" href="/akademie/">Zur Akademie</a>
      </article>
      <article data-panel="umsetzen" hidden>
        <span class="deckcard__num">02 · Umsetzen</span>
        <h3>Wissen allein ändert keinen Dienstplan.</h3>
        <p>Den Unterschied macht die Umsetzung im eigenen Haus — klein geschnitten, messbar und ohne den laufenden Betrieb lahmzulegen.</p>
        <p class="modell">Bei NextCourse ist das das <b>Consulting</b>: vom Quick-Check über den Mystery Check bis zum Pilotprojekt zum Festpreis.</p>
        <a class="arrowlink" href="/consulting/">Zum Consulting</a>
      </article>
      <article data-panel="dranbleiben" hidden>
        <span class="deckcard__num">03 · Dranbleiben</span>
        <h3>Die meisten Projekte scheitern nicht am Start — sondern am dritten Monat.</h3>
        <p>Damit Wissen im Haus bleibt und eingeführte Systeme weiterlaufen, braucht es jemanden, der dranbleibt. Genau das unterscheidet einen Partner von einem Anbieter.</p>
        <p class="modell">Bei NextCourse ist das die <b>Begleitung</b>: digitales Betriebshandbuch, laufender Support, Monitoring.</p>
        <a class="arrowlink" href="/consulting/">Zum Consulting</a>
      </article>
    </div>
  </dialog>

  <!-- FLOOR 3b: Aus dem Blog — Band mit den 3 neuesten Artikeln -->
  <div class="floor--auto floor" id="blog">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Aus dem Blog</p>
        <h2 class="reveal">Frisch aus der Praxis.</h2>
        <p class="lead reveal">KI, Digitalisierung und Weiterbildung fürs Gastgewerbe — praxisnah statt paragraphenlastig.</p>
      </div>

      {posts.length > 0 ? (
        <div class:list={['blogband reveal', marquee ? 'blogband--marquee' : 'blogband--static']}>
          <div class="blogband__track">
            {bandItems.map((post, i) => (
              <a
                class="bandcard"
                href={`/blog/${post.id}/`}
                aria-hidden={marquee && i >= posts.length ? 'true' : undefined}
                tabindex={marquee && i >= posts.length ? -1 : undefined}
              >
                <span class="bandcard__cover"><BlogCover post={post} width={420} /></span>
                <span class="bandcard__body">
                  <time class="bandcard__date" datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
                  <span class="bandcard__title">{post.data.title}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <p class="dim reveal" style="text-align:center;margin-top:2rem">Die ersten Artikel erscheinen in Kürze.</p>
      )}

      <div class="reveal" style="text-align:center;margin-top:2rem">
        <a class="arrowlink" href="/blog/">Alle Artikel im Blog</a>
      </div>
      <a class="scrollhint" href="#aktuelles" aria-label="Weiter zu Neuigkeiten und Angeboten">
        <span class="hintword">Entdecken</span><span class="bar" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <!-- FLOOR 3c: Neuigkeiten & Angebote -->
  <div class="floor--auto floor" id="aktuelles">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Neuigkeiten &amp; Angebote</p>
        <h2 class="reveal">Was gerade bei uns läuft.</h2>
      </div>
      <div class="news reveal stagger">
        <a class="offercard newscard newscard--neu" href="/consulting/pilotprojekte/">
          <span class="newscard__kick newscard__kick--neu">Neu</span>
          <h3>KI-Bausteine zum Festpreis</h3>
          <p>Fünf Pilotprojekte — vom Telefonassistenten bis zur Wareneinsatzoptimierung — jetzt als eigene Übersicht.</p>
          <span class="forkcard__go">Pilotprojekte ansehen</span>
        </a>
        <a class="offercard newscard newscard--termin" href="/kontakt/">
          <span class="newscard__kick newscard__kick--termin">Termin</span>
          <h3>KI-Praxisstart: das erste Seminar</h3>
          <p>Unser erstes KI-Seminar fürs Gastgewerbe. Die Plätze sind begrenzt.</p>
          <span class="newscard__hl">3. August 2026</span>
          <span class="forkcard__go">Platz anfragen</span>
        </a>
        <a class="offercard newscard newscard--angebot" href="/consulting/mystery-check/">
          <span class="newscard__kick newscard__kick--angebot">Angebot</span>
          <h3>Mystery Check zum Pilotpreis</h3>
          <p>Ihren Betrieb mit den Augen der Gäste sehen — als Einstieg ins Consulting.</p>
          <span class="newscard__hl">950 €<s>1.490 €</s></span>
          <span class="forkcard__go">Mehr zum Mystery Check</span>
        </a>
      </div>
    </div>
  </div>

  <!-- FLOOR 4: Abschluss -->
  <div class="floor" id="abschluss">
    <div class="wrap wrap--menu" style="text-align:center">
      <div class="coin reveal" data-tilt style="--coin:160px;margin:0 auto 1.8rem">
        <Image src={philip} alt="Philip Tolle, Gründer von NextCourse" width={380} format="webp" quality={82} />
      </div>
      <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">Der nächste Schritt</p>
      <h2 class="reveal" style="max-width:none">Sprechen wir über Ihren Betrieb.</h2>
      <p class="voice reveal" style="max-width:29em;margin:1.2rem auto 0">Ein Gespräch, kein Verkaufstermin. Erzählen Sie, wo es klemmt — ich höre zu und sage Ihnen ehrlich, ob und wie wir helfen können.</p>
      <ul class="assure reveal" aria-label="Was Sie erwartet">
        <li>Kostenlos &amp; unverbindlich</li>
        <li>Am Telefon oder bei Ihnen im Haus</li>
        <li>Für Mainfranken &amp; Bayern</li>
      </ul>
      <div class="btnrow reveal" style="justify-content:center">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
        <a href="https://cal.com/philip-tolle-yxp7ih/erstgesprach" target="_blank" rel="noopener" class="btn btn--line">Direkt Termin buchen</a>
      </div>
      <p class="reveal small faint" style="margin-top:1.7rem;font-style:italic;font-family:var(--serif);font-size:1.05rem">— Philip Tolle, Gründer von NextCourse</p>
    </div>
  </div>

</Base>

<style>
  /* Aus dem Blog: laufendes Band */
  .blogband{margin-top:2.6rem;overflow:hidden}
  .blogband--marquee{
    -webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);
    mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)}
  .blogband__track{display:flex;gap:1.6rem;width:max-content}
  .blogband--marquee .blogband__track{animation:bandscroll 46s linear infinite}
  .blogband--marquee:hover .blogband__track{animation-play-state:paused}
  @keyframes bandscroll{from{transform:translateX(0)}to{transform:translateX(calc(-50% - .8rem))}}
  .blogband--static .blogband__track{width:auto;justify-content:center;flex-wrap:wrap}

  .bandcard{flex:none;width:min(330px,82vw);text-decoration:none;color:var(--ink);
    background:var(--glass);border:1px solid var(--glass-edge);border-radius:20px;overflow:hidden;
    box-shadow:var(--shadow);transition:transform .25s,box-shadow .25s;
    backdrop-filter:blur(14px) saturate(1.4);-webkit-backdrop-filter:blur(14px) saturate(1.4)}
  .bandcard:hover{transform:translateY(-5px);box-shadow:var(--shadow),var(--glow)}
  .bandcard__cover{display:block;aspect-ratio:3/2;overflow:hidden;border-bottom:1px solid var(--line)}
  .bandcard__body{display:flex;flex-direction:column;gap:.4rem;padding:1.2rem 1.4rem 1.5rem}
  .bandcard__date{font-size:.76rem;letter-spacing:.06em;color:var(--faint)}
  .bandcard__title{font-family:var(--disp);font-size:1.18rem;line-height:1.25;color:var(--ink);
    transition:color .25s;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .bandcard:hover .bandcard__title{color:var(--green)}

  /* Neuigkeiten & Angebote */
  .news{display:grid;gap:1.6rem;margin-top:2.4rem}
  @media(min-width:820px){.news{grid-template-columns:repeat(3,1fr)}}
  .newscard{align-items:flex-start;--nc:var(--wood);
    transition:transform .25s,box-shadow .25s,background .25s,border-color .25s}
  .newscard--neu{--nc:var(--green);--nc-tint:rgba(51,96,79,.09);--nc-bd:rgba(51,96,79,.5);--nc-sh:rgba(51,96,79,.4)}
  .newscard--termin{--nc:var(--blue);--nc-tint:rgba(63,94,126,.1);--nc-bd:rgba(63,94,126,.5);--nc-sh:rgba(63,94,126,.42)}
  .newscard--angebot{--nc:var(--amber);--nc-tint:rgba(176,105,15,.09);--nc-bd:rgba(176,105,15,.5);--nc-sh:rgba(176,105,15,.4)}
  .offercard.newscard:hover{background:var(--nc-tint);border-color:var(--nc-bd);
    box-shadow:0 18px 42px -20px var(--nc-sh),inset 0 1px 0 rgba(255,255,255,.9)}
  .offercard.newscard:hover h3{color:var(--nc)}
  .newscard:hover .newscard__kick{background:var(--nc);border-color:var(--nc);color:var(--paper)}
  .newscard__kick{align-self:flex-start;font-family:var(--body);font-weight:500;font-size:.72rem;
    letter-spacing:.16em;text-transform:uppercase;padding:.3em .9em;border-radius:999px;
    border:1px solid var(--hairline);color:var(--wood);background:rgba(255,255,255,.55);margin-bottom:.3rem;
    transition:background .25s,border-color .25s,color .25s}
  .newscard__kick--neu{color:var(--green);border-color:rgba(51,96,79,.4)}
  .newscard__kick--termin{color:var(--blue);border-color:rgba(63,94,126,.4)}
  .newscard__kick--angebot{color:var(--amber);border-color:rgba(176,105,15,.4)}
  .newscard__hl{font-family:var(--disp);font-size:1.35rem;color:var(--ink);margin-top:.1rem}
  .newscard__hl s{color:var(--faint);font-size:.72em;margin-left:.5em}

  /* Abschluss: Vertrauens-Zeile */
  .assure{list-style:none;display:flex;flex-wrap:wrap;justify-content:center;gap:.5rem 1.5rem;
    margin:1.8rem auto 0;padding:0;max-width:38em}
  .assure li{display:inline-flex;align-items:center;gap:.5rem;font-size:.9rem;color:var(--dim)}
  .assure li::before{content:"✓";color:var(--wood);font-weight:600}

  @media(prefers-reduced-motion:reduce){
    .blogband--marquee{overflow-x:auto;-webkit-mask-image:none;mask-image:none}
    .blogband--marquee .blogband__track{animation:none}
    .bandcard[aria-hidden="true"]{display:none}
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- Hero-Logo: Tilt + Lichtreflex + Münzdrehung ---------- */
  const heroFloor = document.querySelector('.floor.hero') as HTMLElement;
  const heroLogo = document.getElementById('heroLogo')!;
  let spinning = false;

  if (heroFloor && heroLogo && window.matchMedia('(pointer:fine)').matches && !reduced) {
    heroFloor.addEventListener('pointermove', (e) => {
      if (spinning) { return; }
      const r = heroFloor.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - .5;
      const y = (e.clientY - r.top) / r.height - .5;
      heroLogo.style.transform = 'perspective(900px) rotateX(' + (-y * 14).toFixed(2) +
        'deg) rotateY(' + (x * 14).toFixed(2) + 'deg)';
      heroLogo.style.setProperty('--gx', (50 + x * 46).toFixed(1) + '%');
      heroLogo.style.setProperty('--gy', (38 + y * 46).toFixed(1) + '%');
    });
    heroFloor.addEventListener('pointerleave', () => {
      if (spinning) { return; }
      heroLogo.style.transform = '';
      heroLogo.style.setProperty('--gx', '50%');
      heroLogo.style.setProperty('--gy', '35%');
    });
  }

  function spinAndGo() {
    const target = document.getElementById('wahl');
    if (reduced || spinning) {
      target?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      return;
    }
    spinning = true;
    heroLogo.style.transform = '';
    heroLogo.classList.add('is-spinning');
    setTimeout(() => { target?.scrollIntoView({ behavior: 'smooth' }); }, 550);
    const stop = () => {
      heroLogo.classList.remove('is-spinning');
      spinning = false;
    };
    heroLogo.addEventListener('animationend', stop, { once: true });
    setTimeout(stop, 1500);
  }
  heroLogo.addEventListener('click', spinAndGo);
  heroLogo.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); spinAndGo(); }
  });

  /* ---------- Idee: Drei Kräfte → Zeit ---------- */
  const forces = document.getElementById('forces')!;
  const pills = Array.from(document.querySelectorAll<HTMLElement>('.forces__pill'));
  let fActive = 0;
  let fPaused = false;
  let fTimer: ReturnType<typeof setInterval> | null = null;
  let fResume: ReturnType<typeof setTimeout> | null = null;

  const setForce = (i: number) => {
    fActive = (i + pills.length) % pills.length;
    forces.dataset.active = String(fActive);
    pills.forEach((p, k) => p.classList.toggle('is-active', k === fActive));
  };
  const holdForce = (ms = 4500) => {
    fPaused = true;
    if (fResume) { clearTimeout(fResume); }
    fResume = setTimeout(() => { fPaused = false; }, ms);
  };

  setForce(0);
  if (!reduced && pills.length) {
    // sanftes Durchlaufen, sobald die Sektion sichtbar ist
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !fTimer) {
          fTimer = setInterval(() => { if (!fPaused) { setForce(fActive + 1); } }, 2600);
        }
      });
    }, { threshold: 0.35 });
    io.observe(forces);
  }
  const finePointer = window.matchMedia('(pointer:fine)').matches;
  pills.forEach((pill, i) => {
    if (finePointer) {
      pill.addEventListener('pointerenter', () => { fPaused = true; setForce(i); });
      pill.addEventListener('pointerleave', () => { fPaused = false; });
    }
    pill.addEventListener('click', () => { setForce(i); holdForce(); });
  });

  /* ---------- Kartenstapel: Umblättern + Overlay ---------- */
  const deck = document.getElementById('deck')!;
  const cards = Array.from(deck.querySelectorAll<HTMLElement>('.deckcard'));
  const dialog = document.getElementById('stepdialog') as HTMLDialogElement;
  const panels = Array.from(dialog.querySelectorAll<HTMLElement>('[data-panel]'));
  let order = [0, 1, 2];
  let blaettert = false;

  function applyOrder() {
    order.forEach((cardIdx, pos) => { cards[cardIdx].dataset.pos = String(pos); });
  }
  function advance() {
    if (blaettert) { return; }
    blaettert = true;
    const top = cards[order[0]];
    if (reduced) {
      order.push(order.shift()!);
      applyOrder();
      blaettert = false;
      return;
    }
    top.classList.add('is-leaving');
    setTimeout(() => {
      order.push(order.shift()!);
      applyOrder();
      top.classList.remove('is-leaving');
      blaettert = false;
    }, 480);
  }
  deck.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.deckcard__more')) { return; }
    advance();
  });
  document.getElementById('decknext')!.addEventListener('click', advance);

  document.querySelectorAll<HTMLButtonElement>('.deckcard__more').forEach((btn) => {
    btn.addEventListener('click', () => {
      const step = btn.dataset.step;
      panels.forEach((p) => { p.hidden = p.dataset.panel !== step; });
      dialog.showModal();
    });
  });
  dialog.querySelector('.stepdialog__close')!.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) { dialog.close(); }
  });
</script>

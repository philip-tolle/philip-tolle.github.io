---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BlogCover from '../components/BlogCover.astro';
import logo from '../assets/nc-logo.png';
import philip from '../assets/philip.png';
import '../styles/home.css';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const featuredPost = posts[0];
const morePosts = posts.slice(1);

const servicePaths = [
  {
    href: '/consulting/',
    title: 'Consulting',
    claim: 'Beratung, die ankommt.',
    audience: 'Für Betriebe, die Lösungen suchen',
  },
  {
    href: '/akademie/',
    title: 'Academy',
    claim: 'Weiterbildung, die wirkt.',
    audience: 'Für alle, die weiterkommen wollen',
  },
  {
    href: '/operation/',
    title: 'Operation',
    claim: 'Entlastung mit Wert.',
    audience: 'Für Häuser mit mehr Aufgaben als Zeit',
  },
];

const pressures = [
  ['Margendruck', 'Wenig Spielraum für Experimente'],
  ['Qualifikationsdefizit', 'Neues Wissen erreicht den Alltag zu langsam'],
  ['Digitalisierungsrückstand', 'Zu viele Abläufe bleiben unnötig manuell'],
  ['Bürokratische Hürden', 'Regeln binden Aufmerksamkeit und Kapazität'],
];

const answers = [
  {
    href: '/consulting/',
    area: 'Consulting',
    verb: 'Umsetzen',
    text: 'Erst der ehrliche Blick, dann die messbare Umsetzung — Schritt für Schritt statt Großprojekt.',
  },
  {
    href: '/akademie/',
    area: 'Academy',
    verb: 'Lernen',
    text: 'Wissen im Team macht unabhängig und spart vom ersten Tag an Zeit.',
  },
  {
    href: '/operation/',
    area: 'Operation',
    verb: 'Abgeben',
    text: 'Aufgaben auslagern schafft sofort Luft — ohne eine neue Stelle zu besetzen.',
  },
];
---
<Base
  title="NextCourse — Bildungs-, Beratungs- und Umsetzungspartner für das Gastgewerbe"
  description="NextCourse ist der Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe: KI-Beratung und Digitalisierung für Betriebe, Kurse und Weiterbildung in der Akademie — aus Würzburg, im Einsatz in Mainfranken."
>
  <meta slot="head" name="theme-color" content="#EDF3F6" data-home-theme-color>
  <script is:inline slot="head">
    (() => {
      const root = document.documentElement;
      const storageKey = 'nextcourse-home-theme';
      let stored = null;
      try {
        stored = localStorage.getItem(storageKey);
      } catch {
        // Die Systemeinstellung bleibt der sichere Fallback.
      }
      const theme = stored === 'dark' || stored === 'light'
        ? stored
        : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      root.classList.add('home-theme');
      root.dataset.homeTheme = theme;
      root.style.colorScheme = theme;
      document.querySelector('meta[data-home-theme-color]')
        ?.setAttribute('content', theme === 'dark' ? '#061522' : '#EDF3F6');
    })();
  </script>

  <div class="home-page">
    <section class="home-hero" id="homeHero" aria-labelledby="home-title">
      <div class="home-shell home-hero__inner">
        <a
          class="home-hero__logo"
          id="heroLogo"
          href="#wahl"
          aria-label="Zu Consulting, Academy und Operation"
        >
          <Image
            src={logo}
            alt="NextCourse Logo — Wellen und Pfeil aus warmem Holz"
            width={780}
            format="webp"
            quality={84}
            loading="eager"
          />
        </a>
        <p class="home-kicker reveal">Bildung · Beratung · Umsetzung</p>
        <h1 class="home-hero__word reveal" id="home-title">
          NextCourse
          <span class="sr-only"> — Bildungs-, Beratungs- und Umsetzungspartner für das deutsche Gastgewerbe</span>
        </h1>
        <p class="home-hero__claim reveal">
          Der Bildungs-, Beratungs- und Umsetzungspartner<br>
          für das deutsche Gastgewerbe.
        </p>
        <a class="home-scroll" href="#wahl">
          <span>Entdecken</span>
          <i aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <section class="home-section home-section--left home-paths" id="wahl" aria-labelledby="paths-title">
      <div class="home-shell home-paths__layout">
        <div class="home-section__intro reveal">
          <p class="home-kicker">Drei Wege</p>
          <h2 id="paths-title">Ein Partner.<br>Drei Formen der Entlastung.</h2>
          <p>Was führt Sie zu uns? Wählen Sie den Weg, der zu Ihrer aktuellen Aufgabe passt.</p>
        </div>

        <nav class="home-index" aria-label="Leistungsbereiche">
          {servicePaths.map((service, index) => (
            <a class="home-index__row reveal" href={service.href}>
              <span class="home-index__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <span class="home-index__copy">
                <strong>{service.title}</strong>
                <span>{service.claim}</span>
                <small>{service.audience}</small>
              </span>
              <span class="home-index__arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </nav>
      </div>
    </section>

    <section class="home-section home-section--right home-idea" id="idee" aria-labelledby="idea-title">
      <div class="home-time-object" aria-hidden="true">
        <span>Zeit</span>
      </div>
      <div class="home-shell">
        <div class="home-idea__content">
          <div class="home-section__intro reveal">
            <p class="home-kicker">Der Gedanke dahinter</p>
            <h2 id="idea-title">Kein Wissensproblem.<br><span>Ein Zeitproblem.</span></h2>
            <p>
              Gute Ideen sind meist vorhanden. Im Betriebsalltag fehlt jedoch die Zeit,
              sie zu prüfen, zu übersetzen und konsequent umzusetzen.
            </p>
          </div>

          <ol class="home-pressure-list">
            {pressures.map(([title, detail], index) => (
              <li class="reveal">
                <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                <strong>{title}</strong>
                <small>{detail}</small>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="home-section home-section--left home-answers" aria-labelledby="answers-title">
      <div class="home-shell home-answers__layout">
        <div class="home-section__intro reveal">
          <p class="home-kicker">Unsere Antwort</p>
          <h2 id="answers-title">Wissen, das Arbeit abnimmt.</h2>
          <p>
            NextCourse verbindet Analyse, Befähigung und operative Entlastung —
            immer so viel, wie Ihr Betrieb wirklich braucht.
          </p>
        </div>

        <div class="home-answer-list">
          {answers.map((answer, index) => (
            <a class="home-answer-row reveal" href={answer.href}>
              <span class="home-answer-row__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <span class="home-answer-row__title">
                <small>{answer.area}</small>
                <strong>{answer.verb}</strong>
              </span>
              <span class="home-answer-row__text">{answer.text}</span>
              <span class="home-answer-row__arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section home-section--right home-editorial" id="blog" aria-labelledby="blog-title">
      <div class="home-shell">
        <div class="home-editorial__head reveal">
          <div class="home-section__intro">
            <p class="home-kicker">Aus dem Blog</p>
            <h2 id="blog-title">Frisch aus der Praxis.</h2>
          </div>
          <p>
            KI, Digitalisierung und Weiterbildung fürs Gastgewerbe —
            praxisnah statt paragraphenlastig.
          </p>
        </div>

        {featuredPost ? (
          <div class="home-editorial__grid">
            <a class="home-featured reveal" href={`/blog/${featuredPost.id}/`}>
              <span class="home-featured__cover">
                <BlogCover post={featuredPost} width={760} />
              </span>
              <span class="home-featured__body">
                <time datetime={featuredPost.data.pubDate.toISOString()}>{fmt.format(featuredPost.data.pubDate)}</time>
                <strong>{featuredPost.data.title}</strong>
                <span>Artikel lesen <i aria-hidden="true">↗</i></span>
              </span>
            </a>

            <div class="home-article-list">
              {morePosts.map((post) => (
                <a class="home-article-row reveal" href={`/blog/${post.id}/`}>
                  <time datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
                  <strong>{post.data.title}</strong>
                  <span aria-hidden="true">↗</span>
                </a>
              ))}
              <a class="home-text-link reveal" href="/blog/">Alle Artikel im Blog <span aria-hidden="true">→</span></a>
            </div>
          </div>
        ) : (
          <p class="home-empty reveal">Die ersten Artikel erscheinen in Kürze.</p>
        )}
      </div>
    </section>

    <section class="home-section home-section--left home-news" id="aktuelles" aria-labelledby="news-title">
      <div class="home-shell home-news__layout">
        <div class="home-section__intro reveal">
          <p class="home-kicker">Neuigkeiten &amp; Angebote</p>
          <h2 id="news-title">Was gerade bei uns läuft.</h2>
          <p>Drei konkrete Möglichkeiten, NextCourse kennenzulernen oder direkt einzusteigen.</p>
        </div>

        <div class="home-news-list">
          <a class="home-news-row reveal" href="/consulting/implementierungsprojekte/">
            <span class="home-news-row__type">Neu</span>
            <span class="home-news-row__copy">
              <strong>KI-Bausteine zum Festpreis</strong>
              <small>Vom Telefonassistenten bis zum CorporateLLM — jetzt als eigene Übersicht.</small>
            </span>
            <span class="home-news-row__meta">Projekte ansehen</span>
            <span class="home-news-row__arrow" aria-hidden="true">↗</span>
          </a>

          <a class="home-news-row reveal" href="/kontakt/">
            <span class="home-news-row__type">Termin</span>
            <span class="home-news-row__copy">
              <strong>KI-Praxisstart: das erste Seminar</strong>
              <small>Unser erstes KI-Seminar fürs Gastgewerbe. Die Plätze sind begrenzt.</small>
            </span>
            <time class="home-news-row__meta" datetime="2026-08-03">3. August 2026</time>
            <span class="home-news-row__arrow" aria-hidden="true">↗</span>
          </a>

          <a class="home-news-row reveal" href="/consulting/mystery-check/">
            <span class="home-news-row__type">Angebot</span>
            <span class="home-news-row__copy">
              <strong>Mystery Check zum Pilotpreis</strong>
              <small>Ihren Betrieb mit den Augen der Gäste sehen — als Einstieg ins Consulting.</small>
            </span>
            <span class="home-news-row__meta">950 € <s>1.490 €</s></span>
            <span class="home-news-row__arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <section class="home-section home-section--right home-contact" id="abschluss" aria-labelledby="contact-title">
      <div class="home-shell home-contact__layout">
        <div class="home-contact__portrait reveal">
          <Image
            src={philip}
            alt="Philip Tolle, Gründer von NextCourse"
            width={480}
            format="webp"
            quality={84}
          />
        </div>

        <div class="home-contact__copy">
          <p class="home-kicker reveal">Der nächste Schritt</p>
          <h2 class="reveal" id="contact-title">Sprechen wir über Ihren Betrieb.</h2>
          <p class="home-contact__lead reveal">
            Ein Gespräch, kein Verkaufstermin. Erzählen Sie, wo es klemmt —
            ich höre zu und sage Ihnen ehrlich, ob und wie wir helfen können.
          </p>

          <ul class="home-assurance reveal" aria-label="Was Sie erwartet">
            <li>Kostenlos &amp; unverbindlich</li>
            <li>Am Telefon oder bei Ihnen im Haus</li>
            <li>Für Mainfranken &amp; Bayern</li>
          </ul>

          <div class="home-contact__actions reveal">
            <a href="/kontakt/" class="home-button">Kostenloses Erstgespräch</a>
            <a
              href="https://cal.com/philip-tolle-yxp7ih/erstgesprach"
              target="_blank"
              rel="noopener"
              class="home-text-link"
            >Direkt Termin buchen <span aria-hidden="true">↗</span></a>
          </div>
          <p class="home-signature reveal">— Philip Tolle, Gründer von NextCourse</p>
        </div>
      </div>
    </section>
  </div>
</Base>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroStage = document.getElementById('homeHero');
  const heroLogo = document.getElementById('heroLogo');

  if (
    heroStage instanceof HTMLElement
    && heroLogo instanceof HTMLElement
    && window.matchMedia('(pointer:fine)').matches
    && !reducedMotion
  ) {
    heroStage.addEventListener('pointermove', (event) => {
      const rect = heroStage.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width - .5;
      const y = (event.clientY - rect.top) / rect.height - .5;
      heroLogo.style.transform = `perspective(900px) rotateX(${(-y * 7).toFixed(2)}deg) rotateY(${(x * 7).toFixed(2)}deg)`;
      heroLogo.style.setProperty('--gx', `${(50 + x * 34).toFixed(1)}%`);
      heroLogo.style.setProperty('--gy', `${(38 + y * 34).toFixed(1)}%`);
    });

    heroStage.addEventListener('pointerleave', () => {
      heroLogo.style.transform = '';
      heroLogo.style.setProperty('--gx', '50%');
      heroLogo.style.setProperty('--gy', '35%');
    });
  }
</script>

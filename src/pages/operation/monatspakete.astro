---
import Base from '../../layouts/Base.astro';

const pakete = [
  { pname: 'F&B Desk', titel: 'Karten & Bankettunterlagen', preis: 'ab 890 €', einrichtung: 'Einrichtung ab 890 € — entfällt beim Einstieg über den 30-Tage-Test', fuer: 'Für Häuser mit täglich wechselnden Karten — von der Tagung bis zur Halbpension.', einheiten: [
    { titel: 'Übernahme aller laufenden Karten', sub: 'Tages-, Wochen-, Tagungs- & HP' },
    { titel: 'Menü- & Preisänderungen inklusive', sub: 'termingerecht druckfertig' },
    { titel: '4 Event-Menükarten pro Monat', sub: 'aus Vorlagen — individuell gegen Aufpreis' },
    { titel: '1 Zusatzmaterial pro Monat', sub: 'Tischplan, Aufsteller oder Display' },
    { titel: 'Alle Formate geliefert', sub: 'Druck-PDF, Web-PDF & Grafik' },
    { titel: '30 Minuten Planungsgespräch', sub: 'jeden Monat, fester Termin' },
  ] },
  { pname: 'Content Desk', titel: 'Social Media & Newsletter', preis: 'ab 1.490 €', einrichtung: 'Einrichtung ab 1.290 €', fuer: 'Für Häuser, die sichtbar bleiben wollen — ohne eigene Contentstelle.', einheiten: [
    { titel: 'Monatlicher Redaktionsplan', sub: 'saisonale Themen eingebunden' },
    { titel: '6 Beiträge pro Monat', sub: 'Instagram & Facebook' },
    { titel: '8 Story-Elemente', sub: 'passend zu den Beiträgen' },
    { titel: 'Komplett aus einer Hand', sub: 'Text, Gestaltung, Veröffentlichung' },
    { titel: 'Monatsbericht', sub: 'Zahlen statt Bauchgefühl' },
    { titel: '45 Minuten Planungsgespräch', sub: 'jeden Monat, fester Termin' },
  ] },
  { pname: 'Operation Partner', titel: 'Die volle Fachabteilung', preis: 'ab 2.690 €', einrichtung: 'Einrichtung ab 1.890 €', fuer: 'Für Häuser mit Restaurant, Bankett und regelmäßigem Projektbedarf.', einheiten: [
    { titel: 'Beide Desks komplett', sub: 'F&B + Content in vollem Umfang' },
    { titel: '12 Projektstunden pro Quartal', sub: 'flexibel einsetzbar' },
    { titel: 'Saison- & Kampagnenplanung', sub: 'viermal im Jahr' },
    { titel: 'Bevorzugte Bearbeitung', sub: 'festes Servicefenster' },
    { titel: '60 Minuten Steuerungsgespräch', sub: 'jeden Monat, fester Termin' },
    { titel: 'Projekt- & Aufgabenübersicht', sub: 'Status jederzeit einsehbar' },
  ] },
];
---
<Base
  title="Monatspakete — NextCourse Operation"
  description="Die Monatspakete von NextCourse Operation: F&B Desk (Karten & Bankettunterlagen, ab 890 €), Content Desk (Social Media & Newsletter, ab 1.490 €) und Operation Partner (die volle Fachabteilung, ab 2.690 €) — wiederkehrende Aufgaben, Monat für Monat zuverlässig erledigt."
  accent="amber"
>
  <div class="pagehead">
    <span class="ghostglyph" aria-hidden="true">3</span>
    <div class="wrap" style="text-align:center">
      <p class="eyebrow eyebrow--c">Operation · Monatspakete</p>
      <h1 style="max-width:none;margin:0 auto">Wiederkehrendes, zuverlässig erledigt.</h1>
      <p class="voice" style="max-width:34em;margin:1.6rem auto 0">Drei Pakete, ein Prinzip: Sie geben ab, wir liefern — Monat für Monat, zum planbaren Preis.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:1120px">

      <!-- Kennzahlen-Trio -->
      <div class="trio reveal">
        <div class="trio__cell"><span class="trio__big">3 Pakete</span><span class="trio__sub">vom Karten-Desk bis zur vollen Fachabteilung</span></div>
        <div class="trio__cell"><span class="trio__big">Fester Monatspreis</span><span class="trio__sub">Ab-Preise — individuell vereinbart</span></div>
        <div class="trio__cell"><span class="trio__big">Monatliches Gespräch</span><span class="trio__sub">Sie behalten die Steuerung</span></div>
      </div>

      <!-- Paket-Vergleich -->
      <div class="mcsection reveal">
        <h2 class="sr-only">Die drei Pakete im Vergleich</h2>
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">Die drei Pakete</p>
        <p class="mcsection__hint">Jedes Paket ist klar umrissen — Sie wissen vorher, was Sie bekommen.</p>
        <p class="pakete__anker reveal">Zum Vergleich: Eine Teilzeitkraft für diese Aufgaben kostet ab rund 1.400 € im Monat — plus Einarbeitung, Urlaub und Krankheit.</p>
        <div class="pakete stagger">
          {pakete.map((p) => (
            <div class="paket reveal">
              <span class="paket__pname">{p.pname}</span>
              <h3>{p.titel}</h3>
              <p class="paket__preis">{p.preis}<small>/ Monat</small></p>
              <p class="paket__einrichtung">{p.einrichtung}</p>
              <div class="kacheln">
                {p.einheiten.map((e) => (
                  <div class="kachel">
                    <span class="kachel__titel">{e.titel}</span>
                    <span class="kachel__sub">{e.sub}</span>
                  </div>
                ))}
              </div>
              <p class="paket__fuer">{p.fuer}</p>
              <a class="forkcard__go" href="/kontakt/" style="--facc:var(--acc)">Paket anfragen</a>
            </div>
          ))}
        </div>
        <p class="pakete__note reveal">Alle Preise netto, als Ab-Preise — der genaue Umfang wird individuell vereinbart. Im Zweifel: erst der <a href="/operation/30-tage-test/">30-Tage-Test</a>.</p>
      </div>

      <!-- Spielregeln -->
      <div class="mcsection reveal">
        <h2 class="sr-only">So arbeiten wir zusammen</h2>
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)" aria-hidden="true">So arbeiten wir zusammen</p>
        <p class="mcsection__hint">Klare Spielregeln — damit Entlastung entspannt bleibt.</p>
        <div class="regeln stagger">
          <div class="regel reveal"><span class="regel__satz">Eine Korrekturrunde ist inklusive.</span><span class="regel__weil">Unsere eigenen Fehler korrigieren wir selbstverständlich immer.</span></div>
          <div class="regel reveal"><span class="regel__satz">Feste Abgabezeiten.</span><span class="regel__weil">So sind Ihre Materialien pünktlich fertig — verlässlich, jede Woche.</span></div>
          <div class="regel reveal"><span class="regel__satz">Eine Kontaktperson mit Freigaberecht.</span><span class="regel__weil">Kurze Wege, schnelle Ergebnisse, keine Schleifen.</span></div>
          <div class="regel reveal"><span class="regel__satz">Preise, Allergene &amp; Gästedaten gibt Ihr Haus frei.</span><span class="regel__weil">Die fachliche Verantwortung bleibt, wo sie hingehört.</span></div>
          <div class="regel reveal"><span class="regel__satz">Mindestlaufzeit sechs Monate.</span><span class="regel__weil">Entlastung wirkt, wenn sie Routine wird — danach flexibel.</span></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="ctabox reveal">
        <p class="ctabox__eyebrow">Nächster Schritt</p>
        <h3>Welches Paket passt zu Ihrem Haus?</h3>
        <div class="btnrow" style="justify-content:center;margin-top:2rem">
          <a href="/kontakt/" class="btn">Monatspaket besprechen</a>
        </div>
        <p class="ctabox__note">Umfang und Preis klären wir im kostenlosen Erstgespräch — oder Sie starten mit dem <a href="/operation/30-tage-test/" style="color:#F4ECDD">30-Tage-Test</a>.<br>
        Gleich einen <a href="https://cal.com/philip-tolle-yxp7ih/erstgesprach" target="_blank" rel="noopener" style="color:#F4ECDD">Termin fürs Erstgespräch buchen</a>.</p>
      </div>

      <p class="abgrenzung reveal">Monatspakete sind keine Flatrate: Der Umfang ist klar definiert — was darüber hinausgeht, wird als Projekt oder Zusatz fair vereinbart. Fremdkosten wie Druck, Versand oder Werbebudget zahlt Ihr Haus direkt.</p>

      <div style="text-align:center;margin-top:2.4rem" class="reveal">
        <a class="arrowlink" href="/operation/">Alle Operation-Leistungen</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Paket-Vergleich: drei Glaskarten */
  .pakete{display:grid;gap:1.4rem}
  @media(min-width:900px){.pakete{grid-template-columns:repeat(3,1fr)}}
  .paket{display:flex;flex-direction:column;background:rgba(255,255,255,.6);
    border:1px solid var(--glass-edge);border-radius:20px;padding:1.8rem 1.7rem;
    backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);box-shadow:var(--shadow);
    transition:transform .25s,box-shadow .25s,border-color .25s}
  .paket:hover{transform:translateY(-4px);border-color:rgba(var(--acc-rgb),.45);
    box-shadow:var(--shadow),0 20px 44px -22px rgba(var(--acc-rgb),.4)}
  .paket__pname{font-family:var(--body);font-weight:500;font-size:.68rem;letter-spacing:.2em;
    text-transform:uppercase;color:var(--faint)}
  .paket h3{font-size:1.35rem;margin:.3rem 0 .9rem;line-height:1.25}
  .paket__preis{margin:0;font-family:var(--disp);font-size:2rem;color:var(--acc);
    display:flex;align-items:baseline;gap:.45rem}
  .paket__preis small{font-family:var(--body);font-size:.75rem;letter-spacing:.08em;
    text-transform:uppercase;color:var(--faint)}
  .paket__einrichtung{margin:.15rem 0 1.1rem;font-size:.8rem;color:var(--faint)}

  /* Leistungseinheiten als quadratische Kacheln */
  .kacheln{display:grid;grid-template-columns:1fr 1fr;gap:1px;margin-bottom:1.2rem;
    background:var(--hairline);border:1px solid var(--hairline);border-radius:16px;
    overflow:hidden}
  .kachel{aspect-ratio:1/1;background:rgba(255,255,255,.6);display:flex;
    flex-direction:column;align-items:center;justify-content:center;gap:.4rem;
    padding:.85rem;text-align:center}
  .kachel__titel{font-family:var(--disp);font-size:.98rem;line-height:1.3;
    color:var(--acc);text-wrap:balance}
  .kachel__sub{font-size:.7rem;line-height:1.35;color:var(--faint)}
  .paket__fuer{margin:auto 0 1rem;font-family:var(--serif);font-style:italic;
    font-size:.98rem;color:var(--faint)}
  .pakete__anker{margin:-0.6rem auto 1.6rem;text-align:center;font-size:.92rem;
    color:var(--dim);max-width:44em}
  .pakete__note{margin:1.6rem auto 0;text-align:center;font-size:.85rem;color:var(--faint);max-width:44em}
  .pakete__note a{color:var(--acc);font-weight:500}

  /* Spielregeln */
  .regeln{display:flex;flex-direction:column;max-width:860px;margin:0 auto}
  .regel{display:grid;gap:.15rem 2rem;padding:1.05rem .2rem;border-bottom:1px solid var(--line)}
  .regel:first-child{border-top:1px solid var(--line)}
  @media(min-width:700px){.regel{grid-template-columns:1.05fr 1fr;align-items:baseline}}
  .regel__satz{font-family:var(--serif);font-style:italic;font-size:1.12rem;color:var(--ink)}
  .regel__weil{color:var(--dim);font-size:.92rem;line-height:1.6}
  .ctabox__note a{font-weight:500}
</style>

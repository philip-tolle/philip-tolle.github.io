---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogCover from '../../components/BlogCover.astro';
import bannerBlog from '../../assets/banner-blog.png';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base
  title="Blog — NextCourse"
  description="KI, Digitalisierung und Weiterbildung für das Gastgewerbe — praxisnah erklärt. Der NextCourse-Blog für Hoteliers, Gastronomen und alle, die weiterkommen wollen."
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerBlog} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">Blog</p>
      <h1>Wissen für Gastgeber.</h1>
      <p class="lead">KI, Digitalisierung und Weiterbildung im Gastgewerbe — praxisnah statt paragraphenlastig.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap" style="max-width:840px">
      <div class="postlist reveal stagger">
        {posts.map((post) => (
          <a class="offercard postcard" href={`/blog/${post.id}/`}>
            <span class="postcard__cover"><BlogCover post={post} width={560} /></span>
            <span class="postcard__main">
              <p class="postmeta">
                <time datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
                {post.data.tags.map((t) => <span class="chip">{t}</span>)}
              </p>
              <h2 class="postcard__title">{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="forkcard__go">Weiterlesen</span>
            </span>
          </a>
        ))}
      </div>
      {posts.length === 0 && (
        <p class="dim" style="text-align:center;margin-top:3rem">Die ersten Artikel erscheinen in Kürze.</p>
      )}
    </div>
  </div>
</Base>

<style>
  .postcard{padding:0;overflow:hidden}
  .postcard__cover{display:block;aspect-ratio:16/10;overflow:hidden}
  .postcard__main{display:flex;flex-direction:column;gap:.55rem;padding:1.7rem 1.8rem}
  @media(min-width:640px){
    .postcard{display:grid;grid-template-columns:clamp(220px,34%,320px) 1fr;align-items:stretch}
    .postcard__cover{aspect-ratio:auto;height:100%;min-height:100%;
      border-right:1px solid var(--line)}
  }
</style>

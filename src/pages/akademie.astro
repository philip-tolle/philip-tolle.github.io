---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import bannerAkademie from '../assets/banner-akademie-v4.png';
import logo from '../assets/nc-logo.png';

const bereiche = [
  { icon: 'ki', title: 'Seminare & Webinare', text: 'Kompakter Einstieg — an einem Tag oder online, direkt im Alltag anwendbar.', href: '/akademie/ki-grundlagen/', link: 'Zu den Seminaren', available: true },
  { icon: 'gastlichkeit', title: 'Flying Academy', text: 'Wir kommen zu Ihnen: Inhouse-Schulung im eigenen Betrieb, ganz ohne Kursraum.', href: '/kontakt/', link: 'Inhouse anfragen', available: true },
  { icon: 'ausbildung', title: 'Kurse', text: 'Mehrtägige Qualifizierung mit Abschluss.', available: false },
  { icon: 'befaehigung', title: 'Workshops', text: 'Fokussierte Praxis zu einem Thema, hands-on.', available: false },
  { icon: 'lernen', title: 'Lehrgänge · AZAV', text: 'Geförderte Lehrgänge über Bildungsgutschein.', available: false },
];
---
<Base
  title="Akademie — NextCourse"
  description="Weiterbildung für das Gastgewerbe in Würzburg: KI-Grundlagen (EU AI Act Art. 4), AEVO-Vorbereitung, Barista-Kurs und der AZAV-Lehrgang Führen & Kommunizieren mit KI — bis zu 100 % gefördert über Bildungsgutschein."
  accent="blue"
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerAkademie} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Academy</p>
      <h1>Weiterbildung, die wirkt.</h1>
      <p class="lead">Aus der Praxis fürs Gastgewerbe — und in jedem Format steckt ein KI-Modul.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:clamp(3rem,6vw,4.5rem)">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">So lernen Sie bei uns</p>
        <h2 class="reveal">Fünf Formate, ein Ziel.</h2>
        <p class="lead reveal">Vom Kurztag bis zum geförderten Lehrgang — jedes Format mit KI-Modul, spezifisch fürs Gastgewerbe.</p>
      </div>

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {bereiche.map((b) => (
          <div class="station">
            <span class="station__node" aria-hidden="true"></span>
            {b.available ? (
              <a class="offercard station__card deckblatt reveal" href={b.href}>
                <Icon name={b.icon} size={38} class="station__icon" />
                <h3>{b.title}</h3>
                <p>{b.text}</p>
                <span class="forkcard__go">{b.link}</span>
              </a>
            ) : (
              <div class="offercard station__card deckblatt deckblatt--soon reveal">
                <span class="deckblatt__stamp" aria-hidden="true">In Vorbereitung</span>
                <Icon name={b.icon} size={38} class="station__icon" />
                <h3>{b.title}</h3>
                <p>{b.text}</p>
                <span class="sr-only">Dieses Format ist in Vorbereitung.</span>
              </div>
            )}
          </div>
        ))}
      </div>

      <p class="dim reveal" style="max-width:44em;margin:3.4rem auto 0;text-align:center">In jedem Format steckt ein verpflichtendes KI-Modul — als einziger Anbieter spezifisch für das Gastgewerbe. Die Inhalte werden alle 12–18 Monate aktualisiert, und über unser Consulting-Netzwerk vermitteln wir Absolventen direkt in die Praxis. Weitere geförderte Lehrgänge (System- &amp; Change-Manager Gastgewerbe, KI-gestützter Guest-Relation-Manager) folgen 2027/2028.</p>
      <div class="reveal" style="text-align:center;margin-top:1.4rem">
        <a class="arrowlink" href="/akademie/foerderung/">Förderung: Wer zahlt was?</a>
      </div>
      <div class="btnrow reveal" style="justify-content:center;margin-top:1.6rem">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Academy: Deckblätter (gleiche Größe) */
  .deckblatt{--facc:var(--acc);text-align:center;align-items:center;justify-content:center;
    min-height:290px;gap:.5rem;
    transition:transform .25s,box-shadow .25s,background .25s,border-color .25s}
  .deckblatt .station__icon{color:var(--acc);margin-bottom:.2rem}
  .deckblatt h3{font-size:clamp(1.5rem,4vw,2rem)}
  .deckblatt p{max-width:22em}
  .deckblatt .forkcard__go{margin-top:.6rem}

  /* aktiv: blau + gläserner Hover (wie Startseite) */
  a.deckblatt:hover{transform:translateY(-5px);
    background:rgba(63,94,126,.09);border-color:rgba(63,94,126,.5);
    box-shadow:0 20px 44px -22px rgba(63,94,126,.5),inset 0 1px 0 rgba(255,255,255,.9);
    backdrop-filter:blur(20px) saturate(1.6);-webkit-backdrop-filter:blur(20px) saturate(1.6)}
  a.deckblatt:hover h3{color:var(--acc)}

  /* in Vorbereitung: verdunkelt + edler Stempel */
  .deckblatt--soon{position:relative;overflow:hidden;border-style:dashed;
    border-color:rgba(63,94,126,.3)}
  .deckblatt--soon::before{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;
    background:rgba(38,34,27,.16)}
  .deckblatt--soon .station__icon,.deckblatt--soon h3,.deckblatt--soon p{opacity:.5}
  .deckblatt__stamp{position:absolute;top:50%;left:50%;
    transform:translate(-50%,-50%) rotate(-7deg);z-index:3;
    font-family:var(--body);font-weight:600;font-size:.82rem;letter-spacing:.28em;
    text-transform:uppercase;color:var(--blue);
    background:rgba(247,244,239,.82);border:2px solid var(--blue);border-radius:7px;
    padding:.55em 1.2em;white-space:nowrap;box-shadow:0 5px 16px rgba(62,50,34,.2)}
</style>

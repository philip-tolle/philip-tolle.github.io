---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import bannerAkademie from '../assets/banner-akademie.png';

const kurse = (await getCollection('kurse'))
  .sort((a, b) => a.data.reihenfolge - b.data.reihenfolge);

const kursIcon: Record<string, string> = {
  'ki-grundlagen': 'ki',
  'aevo': 'ausbildung',
  'barista': 'barista',
  'fuehren-mit-ki': 'beratung',
};
---
<Base
  title="Akademie — NextCourse"
  description="Weiterbildung für das Gastgewerbe in Würzburg: KI-Grundlagen (EU AI Act Art. 4), AEVO-Vorbereitung, Barista-Kurs und der AZAV-Lehrgang Führen & Kommunizieren mit KI — bis zu 100 % gefördert über Bildungsgutschein."
  accent="blue"
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerAkademie} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Academy</p>
      <h1>Weiterbildung, die wirkt.</h1>
      <p class="lead">Aus der Praxis fürs Gastgewerbe — und in jedem Format steckt ein KI-Modul.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:1rem">
    <div class="wrap">
      <div class="kartei reveal stagger">
        {kurse.map((kurs) => (
          <a class="karteikarte" href={`/akademie/${kurs.id}/`}>
            <span class="karteikarte__tab">{kurs.data.kategorie}</span>
            <span class:list={['karteikarte__status', kurs.data.status === 'geplant' && 'karteikarte__status--geplant']}>
              {kurs.data.status === 'buchbar' ? 'Buchbar' : 'In Planung'}
            </span>
            <Icon name={kursIcon[kurs.id] ?? 'lernen'} size={40} class="karteikarte__icon" />
            <h2>{kurs.data.title}</h2>
            <p class="voice">„{kurs.data.botschaft}“</p>
            <p class="karteikarte__kurz">{kurs.data.kurz}</p>
            <div class="chips">
              <span class="chip">{kurs.data.dauer}</span>
              <span class="chip">{kurs.data.foerderung}</span>
            </div>
            <span class="forkcard__go" style="--facc:var(--blue)">Zum Kurs</span>
          </a>
        ))}
      </div>

      <p class="dim reveal" style="margin-top:2.6rem;max-width:44em">In jedem Kurs steckt ein verpflichtendes KI-Modul — als einziger Anbieter spezifisch für das Gastgewerbe. Die Inhalte werden alle 12–18 Monate aktualisiert, und über unser Consulting-Netzwerk vermitteln wir Absolventen direkt in die Praxis. Weitere geförderte Lehrgänge (System- &amp; Change-Manager Gastgewerbe, KI-gestützter Guest-Relation-Manager) folgen 2027/2028.</p>
      <a class="arrowlink reveal" href="/akademie/foerderung/">Förderung: Wer zahlt was?</a>
      <div class="btnrow reveal">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

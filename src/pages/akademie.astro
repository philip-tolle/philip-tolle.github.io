---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import bannerAkademie from '../assets/banner-akademie-v4.png';
import logo from '../assets/nc-logo.png';

const bereiche = [
  { icon: 'ki', title: 'Seminare & Webinare', text: 'Kompakter Einstieg — an einem Tag oder online, direkt im Alltag anwendbar.', available: true, id: 'seminare', offers: [
    { title: 'KI im Geschäftsalltag „Gastgewerbe“', text: 'Praxisnaher Einstieg: KI im Betriebsalltag sinnvoll und sicher einsetzen.', href: '/kontakt/' },
    { title: 'Digitaler Wandel & Mitarbeiterzufriedenheit', text: 'Wie Digitalisierung das Team entlastet, statt es zu überfordern.', href: '/kontakt/' },
  ] },
  { icon: 'gastlichkeit', title: 'Flying Academy', text: 'Wir kommen zu Ihnen: Inhouse-Schulung im eigenen Betrieb, ganz ohne Kursraum.', available: true, id: 'flying', offers: [
    { title: 'EU AI Act Grundschulung für Ihre Mitarbeiter', text: 'Die Schulungspflicht nach Art. 4 EU AI Act — kompakt bei Ihnen im Haus.', href: '/kontakt/' },
    { title: 'Individuelle Schulung nach Absprache', text: 'Inhalte und Umfang genau auf Ihren Betrieb zugeschnitten.', href: '/kontakt/' },
  ] },
  { icon: 'ausbildung', title: 'Kurse', text: 'Mehrtägige Qualifizierung mit Abschluss.', available: false },
  { icon: 'befaehigung', title: 'Workshops', text: 'Fokussierte Praxis zu einem Thema, hands-on.', available: false },
  { icon: 'lernen', title: 'Lehrgänge · AZAV', text: 'Geförderte Lehrgänge über Bildungsgutschein.', available: false },
];
---
<Base
  title="Akademie — NextCourse"
  description="Weiterbildung für das Gastgewerbe in Würzburg: KI-Grundlagen (EU AI Act Art. 4), AEVO-Vorbereitung, Barista-Kurs und der AZAV-Lehrgang Führen & Kommunizieren mit KI — bis zu 100 % gefördert über Bildungsgutschein."
  accent="blue"
>
  <div class="pagehead pagehead--art">
    <Image class="pagehead__bg" src={bannerAkademie} alt="" width={1600} format="webp" quality={78} loading="eager" />
    <div class="wrap">
      <p class="eyebrow">NextCourse Academy</p>
      <h1>Weiterbildung, die wirkt.</h1>
      <p class="lead">Aus der Praxis fürs Gastgewerbe — und in jedem Format steckt ein KI-Modul.</p>
    </div>
  </div>

  <div class="floor--auto floor" style="padding-top:clamp(3rem,6vw,4.5rem)">
    <div class="wrap">
      <div class="menuhead">
        <p class="eyebrow eyebrow--c reveal" style="--acc:var(--wood)">So lernen Sie bei uns</p>
        <h2 class="reveal">Fünf Formate, ein Ziel.</h2>
        <p class="lead reveal">Vom Kurztag bis zum geförderten Lehrgang — jedes Format mit KI-Modul, spezifisch fürs Gastgewerbe.</p>
      </div>

      <div class="kurs" id="kurs">
        <svg class="kurs__line" viewBox="0 0 130 1600" preserveAspectRatio="none" aria-hidden="true">
          <path class="kurs__track" d="M65 0 L65 1600"/>
          <path class="kurs__path" d="M65 0 L65 1600"/>
        </svg>
        <div class="kurs__pen">
          <span class="kurs__logo"><Image src={logo} alt="" width={120} format="webp" quality={82} loading="eager" /></span>
        </div>
        {bereiche.map((b) => (
          <div class="station">
            <span class="station__node" aria-hidden="true"></span>
            {b.available ? (
              <>
                <button type="button" class="offercard station__card deckblatt reveal" aria-expanded="false" aria-controls={`off-${b.id}`}>
                  <Icon name={b.icon} size={38} class="station__icon" />
                  <h3>{b.title}</h3>
                  <p>{b.text}</p>
                  <span class="deckblatt__toggle">Angebote ansehen
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </button>
                <div class="deckoffers" id={`off-${b.id}`} hidden>
                  {b.offers.map((o) => (
                    <a class="deckoffer" href={o.href}>
                      <h4>{o.title}</h4>
                      <p>{o.text}</p>
                      <span class="forkcard__go">Anfragen</span>
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <div class="offercard station__card deckblatt deckblatt--soon reveal">
                <span class="deckblatt__stamp" aria-hidden="true">In Vorbereitung</span>
                <Icon name={b.icon} size={38} class="station__icon" />
                <h3>{b.title}</h3>
                <p>{b.text}</p>
                <span class="sr-only">Dieses Format ist in Vorbereitung.</span>
              </div>
            )}
          </div>
        ))}
      </div>

      <p class="dim reveal" style="max-width:44em;margin:3.4rem auto 0;text-align:center">In jedem Format steckt ein verpflichtendes KI-Modul — als einziger Anbieter spezifisch für das Gastgewerbe. Die Inhalte werden alle 12–18 Monate aktualisiert, und über unser Consulting-Netzwerk vermitteln wir Absolventen direkt in die Praxis. Weitere geförderte Lehrgänge (System- &amp; Change-Manager Gastgewerbe, KI-gestützter Guest-Relation-Manager) folgen 2027/2028.</p>
      <div class="reveal" style="text-align:center;margin-top:1.4rem">
        <a class="arrowlink" href="/akademie/foerderung/">Förderung: Wer zahlt was?</a>
      </div>
      <div class="btnrow reveal" style="justify-content:center;margin-top:1.6rem">
        <a href="/kontakt/" class="btn">Kostenloses Erstgespräch</a>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Academy: Deckblätter (gleiche Größe) */
  .deckblatt{--facc:var(--acc);font-family:var(--body);text-align:center;width:100%;
    align-items:center;justify-content:center;min-height:300px;gap:.5rem;
    transition:transform .25s,box-shadow .25s,background .25s,border-color .25s}
  button.deckblatt{cursor:pointer;color:inherit}
  .deckblatt .station__icon{color:var(--acc);margin-bottom:.2rem}
  .deckblatt h3{font-size:clamp(1.5rem,4vw,2rem)}
  .deckblatt p{max-width:22em}
  .deckblatt__toggle{margin-top:.7rem;display:inline-flex;align-items:center;gap:.45rem;
    font-weight:500;font-size:.9rem;letter-spacing:.02em;color:var(--acc)}
  .deckblatt__toggle svg{transition:transform .3s}
  .deckblatt[aria-expanded="true"] .deckblatt__toggle svg{transform:rotate(180deg)}

  /* aktiv: blau + gläserner Hover (wie Startseite) */
  .deckblatt:not(.deckblatt--soon):hover{transform:translateY(-5px);
    background:rgba(63,94,126,.09);border-color:rgba(63,94,126,.5);
    box-shadow:0 20px 44px -22px rgba(63,94,126,.5),inset 0 1px 0 rgba(255,255,255,.9);
    backdrop-filter:blur(20px) saturate(1.6);-webkit-backdrop-filter:blur(20px) saturate(1.6)}
  .deckblatt:not(.deckblatt--soon):hover h3{color:var(--acc)}

  /* in Vorbereitung: blau getönt + edler Stempel in der Ecke */
  .deckblatt--soon{position:relative;overflow:hidden;border-style:dashed;
    border-color:rgba(63,94,126,.35);background:rgba(63,94,126,.06)}
  .deckblatt--soon::before{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;
    background:rgba(63,94,126,.16)}
  .deckblatt--soon .station__icon,.deckblatt--soon h3,.deckblatt--soon p{opacity:.55}
  .deckblatt__stamp{position:absolute;top:1.1rem;right:1.1rem;z-index:3;transform:rotate(6deg);
    font-family:var(--body);font-weight:600;font-size:.72rem;letter-spacing:.24em;
    text-transform:uppercase;color:var(--blue);
    background:rgba(247,244,239,.85);border:2px solid var(--blue);border-radius:7px;
    padding:.4em .9em;white-space:nowrap;box-shadow:0 4px 12px rgba(62,50,34,.18)}
  @media(min-width:860px){
    .station:nth-of-type(even) .deckblatt__stamp{right:auto;left:1.1rem;transform:rotate(-6deg)}
  }

  /* Angebote unter dem Deckblatt (Akkordeon) */
  .deckoffers{display:grid;gap:1rem;margin-top:1.4rem}
  .deckoffers[hidden]{display:none}
  @media(min-width:860px){.deckoffers{grid-column:1 / -1;grid-template-columns:1fr 1fr}}
  @media(max-width:859px){.deckoffers{margin-left:64px}}
  .deckoffer{display:flex;flex-direction:column;gap:.35rem;text-align:left;text-decoration:none;
    color:var(--ink);background:rgba(255,255,255,.6);border:1px solid var(--glass-edge);
    border-radius:16px;padding:1.3rem 1.5rem;box-shadow:var(--shadow);
    transition:transform .2s,box-shadow .2s;animation:deckin .35s ease both}
  .deckoffer:hover{transform:translateY(-3px);box-shadow:var(--shadow),var(--glow)}
  .deckoffer h4{font-family:var(--disp);font-weight:400;font-size:1.18rem;color:var(--ink);margin:0}
  .deckoffer:hover h4{color:var(--acc)}
  .deckoffer p{margin:0;font-size:.9rem;color:var(--dim);line-height:1.5}
  .deckoffer .forkcard__go{--facc:var(--acc);margin-top:.4rem}
  @keyframes deckin{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  @media(prefers-reduced-motion:reduce){.deckoffer{animation:none}}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.deckblatt[aria-controls]').forEach((btn) => {
    const panel = document.getElementById(btn.getAttribute('aria-controls') as string);
    if (!panel) { return; }
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      panel.hidden = open;
      window.dispatchEvent(new Event('resize'));
    });
  });
</script>
